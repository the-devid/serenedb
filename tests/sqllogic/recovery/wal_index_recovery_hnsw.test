control substitution on

# WAL recovery for HNSW columns.
#
# HNSW vectors live exclusively in the new cs (ARRAY<FLOAT,N> typed
# column + per-segment HNSW graph in footer slot 102). On a crash before
# the iresearch commit, the vectors only exist in the RocksDB WAL slice;
# WAL recovery must re-feed the cs writer so the next commit produces a
# segment whose .cs has the vectors AND the auto-rebuilt graph.
#
# Pre-crash row goes through a normal commit so the on-disk .cs is the
# reference. Post-crash rows land in the WAL only -- we freeze
# SearchCommitTask::commitUnsafe before INSERTing them so the iresearch
# trx never gets to flush.

statement ok
CREATE TABLE wal_hnsw_t(pk INTEGER PRIMARY KEY, emb FLOAT[3]);

statement ok
INSERT INTO wal_hnsw_t VALUES (1, [1.0, 0.0, 0.0]::FLOAT[3]);

statement ok
CREATE INDEX wal_hnsw_idx ON wal_hnsw_t
  USING inverted(emb hnsw (metric = 'l2'));

statement ok
VACUUM (UPDATE_INDEXES) wal_hnsw_t;

# Plan check: ANN top-K served by the HNSW graph in the inverted index.
query
EXPLAIN SELECT pk FROM wal_hnsw_idx ORDER BY emb <-> [1.0, 0.0, 0.0]::FLOAT[3] LIMIT 1;
----
QUERY PLAN
┌───────────────────────────┐
│     IRESEARCH_ANN_SCAN    │
│    ────────────────────   │
│    Index: wal_hnsw_idx    │
│      Lookup: rocksdb      │
│          TopK: 1          │
│          Dims: 3          │
│      Projections: pk      │
│                           │
│           ~1 row          │
└───────────────────────────┘

# Pre-crash row reads from the on-disk .cs + graph.
query
SELECT pk FROM wal_hnsw_idx ORDER BY emb <-> [1.0, 0.0, 0.0]::FLOAT[3] LIMIT 1;
----
pk
1

# Freeze iresearch commits BEFORE the second batch lands. The next two
# rows reach RocksDB (and its WAL) but the iresearch trx is never
# committed -- their vectors only exist as WAL bytes when we crash.
statement ok
SET sdb_faults = 'SearchCommitTask::commitUnsafe';

statement ok
INSERT INTO wal_hnsw_t VALUES (2, [0.0, 1.0, 0.0]::FLOAT[3]),
                              (3, [0.0, 0.0, 1.0]::FLOAT[3]);

statement ok
SET sdb_faults = 'crash_on_packet';

statement error connection closed
SELECT 1;


# --- server restarts here ---

connection wal_after
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
VACUUM (UPDATE_INDEXES) wal_hnsw_t;

# Pre-crash row still queryable.
connection wal_after
query
SELECT pk FROM wal_hnsw_idx ORDER BY emb <-> [1.0, 0.0, 0.0]::FLOAT[3] LIMIT 1;
----
pk
1

# Post-crash vectors must have round-tripped through recovery -- ANN
# nearest neighbour to the second vector returns pk=2, third returns pk=3.
connection wal_after
query
SELECT pk FROM wal_hnsw_idx ORDER BY emb <-> [0.0, 1.0, 0.0]::FLOAT[3] LIMIT 1;
----
pk
2

connection wal_after
query
SELECT pk FROM wal_hnsw_idx ORDER BY emb <-> [0.0, 0.0, 1.0]::FLOAT[3] LIMIT 1;
----
pk
3

# All three rows visible.
connection wal_after
query
SELECT COUNT(*) AS n FROM wal_hnsw_idx;
----
n
3
