control substitution on

# Long string values + many tokens per doc. Stresses tokenizer + iresearch
# index file growth during recovery.

statement ok
CREATE TEXT SEARCH DICTIONARY ls_dict(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE TABLE ls_t(id INTEGER PRIMARY KEY, body TEXT);

statement ok
CREATE INDEX ls_idx ON ls_t USING inverted(id, body ls_dict);

statement ok
VACUUM (UPDATE_INDEXES) ls_t;

statement ok
SET sdb_faults = 'SearchCommitTask::commitUnsafe';

# Build very long bodies of repeating tokens. Each row has ~500 unique-ish
# tokens, total bytes around 4-8 KB per row.
#   row N: 'tag_<N> filler1 filler2 ... filler500 marker_<N>'

statement ok
INSERT INTO ls_t SELECT
  i,
  'tag_' || i || ' ' ||
  list_aggregate(list_transform(range(0, 500), j -> 'word' || j), 'string_agg', ' ')
  || ' marker_' || i
FROM range(0, 200) AS t(i);

statement ok
SET sdb_faults = 'crash_on_packet';

query error connection closed
SELECT 1;

# --- restart ---

connection ls_after
statement ok retry 60 backoff 1s
VACUUM (UPDATE_INDEXES) ls_t;

connection ls_after
query
SELECT COUNT(*) FROM ls_t;
----
count
200

connection ls_after
query
SELECT COUNT(*) FROM ls_idx;
----
count
200

# Per-row unique tag tokens.
connection ls_after
query
SELECT id FROM ls_t WHERE body @@ ts_phrase('tag_0');
----
id
0

connection ls_after
query
SELECT id FROM ls_t WHERE body @@ ts_phrase('tag_99');
----
id
99

connection ls_after
query
SELECT id FROM ls_t WHERE body @@ ts_phrase('tag_199');
----
id
199

# Marker tokens.
connection ls_after
query
SELECT id FROM ls_t WHERE body @@ ts_phrase('marker_50');
----
id
50

connection ls_after
query
SELECT id FROM ls_t WHERE body @@ ts_phrase('marker_175');
----
id
175

# Common token shared across all docs.
connection ls_after
query
SELECT COUNT(*) FROM ls_t WHERE body @@ ts_phrase('word250');
----
count
200
