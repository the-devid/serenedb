hash-threshold 100

# ---------------------------------------------------------------------------
# Verify that WAND metadata survives index consolidation. A review pass on
# `merge_writer.cpp` flagged that `Flush` builds a `FlushState` with
# `norms = nullptr` (the new field on `FlushState` was added for the initial
# flush; merge never sets it). If true, `PostingsWriterBase::PrepareWriters`
# early-returns and `_valid_writer` stays null, so no WAND metadata is
# written for merged segments. BM25 top-K queries on those segments would
# silently fall back to a full posting walk.
#
# Test shape:
#   1. Build a WAND-enabled inverted index across TWO segments (insert,
#      VACUUM, insert, VACUUM).
#   2. Pre-merge: arm `irs::WandIterator` fault -- query trips, proving
#      both initial-flush segments wrote wand metadata.
#   3. PRAGMA serenedb_vacuum('compact_indexes', ...) -- merges into one
#      segment via MergeWriter::Flush.
#   4. Post-merge: arm `irs::WandIterator` fault -- if wand metadata is in
#      the merged segment, the fault trips again. If not, the query
#      returns clean rows and we have a regression.
#
# Lives under recovery/ because `sdb_faults` requires SDB_FAULT_INJECTION=On
# (same reasoning as inverted_index_wand_faults.test).
# ---------------------------------------------------------------------------

statement ok
CREATE TEXT SEARCH DICTIONARY en_wand(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


statement ok
CREATE TABLE wand_cons (id INTEGER PRIMARY KEY, body VARCHAR);


statement ok
CREATE INDEX wand_cons_idx ON wand_cons USING inverted(id, body en_wand)
  WITH (optimize_top_k = 'bm25(1.2, 0.75)');


# Segment 1: 100 rows.
statement ok
INSERT INTO wand_cons SELECT i, CASE i % 5
    WHEN 0 THEN 'fox quick brown'
    WHEN 1 THEN 'fox lazy dog'
    WHEN 2 THEN 'cat sleeping in box'
    WHEN 3 THEN 'rabbit and fox'
    ELSE        'rare_token bird sings'
  END
  FROM generate_series(1, 100) AS s(i);


statement ok
VACUUM (UPDATE_INDEXES) wand_cons;


# Segment 2: 100 more rows under a disjoint pk range.
statement ok
INSERT INTO wand_cons SELECT i, CASE i % 5
    WHEN 0 THEN 'fox quick brown'
    WHEN 1 THEN 'fox lazy dog'
    WHEN 2 THEN 'cat sleeping in box'
    WHEN 3 THEN 'rabbit and fox'
    ELSE        'rare_token bird sings'
  END
  FROM generate_series(1000, 1099) AS s(i);


statement ok
VACUUM (UPDATE_INDEXES) wand_cons;


# === Pre-merge sanity: WAND fires on the initial-flush segments. ===

statement ok
SET sdb_faults = 'irs::WandIterator';


statement error db error: ERROR: intentional debug error
SELECT id FROM wand_cons_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(wand_cons_idx.tableoid) DESC LIMIT 3;


statement ok
SET sdb_faults = '-irs::WandIterator';


# === Force consolidation into one merged segment. ===

statement ok
PRAGMA serenedb_vacuum('compact_indexes', 'wand_cons');


# Correctness sanity: the merged segment returns the right docs.
# 'fox' appears in buckets 0, 1, 3 -- 60 per 100-doc batch x 2 batches = 120.
query I
SELECT COUNT(*) FROM (
  SELECT id FROM wand_cons_idx
  WHERE body @@ ts_phrase('fox')
  ORDER BY BM25(wand_cons_idx.tableoid) DESC LIMIT 100
) x;
----
count
100


# === Post-merge: did the merged segment write WAND metadata? ===
# If yes, the fault trips. If no, the query returns clean rows.

statement ok
SET sdb_faults = 'irs::WandIterator';


statement error db error: ERROR: intentional debug error
SELECT id FROM wand_cons_idx
WHERE body @@ ts_phrase('fox')
ORDER BY BM25(wand_cons_idx.tableoid) DESC LIMIT 3;


statement ok
SET sdb_faults = '-irs::WandIterator';
