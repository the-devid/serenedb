control substitution on

# WAL index recovery: Put-after-Delete in the same window.
#
# In normal operation a Delete is always followed by an Insert with a fresh
# pk -- the WAL never contains Delete then Put for the same primary key.
# But the recovery's accumulator (Row::indexed_cols) MUST clear stale column
# views on Delete: if a future bug or unusual write path produces
# Put-after-Delete in the same flush window, the stale Put cells from before
# the Delete must not be re-inserted into iresearch.
#
# This test exercises the path: insert, crash, recover. We can't easily craft
# Put-after-Delete in a single WAL window from SQL (the engine doesn't expose
# that), so this test pins down the simpler invariant: pk reused after a
# delete (across windows) ends up with the new content, not a mix.

statement ok
CREATE TEXT SEARCH DICTIONARY del_then_insert_dict(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE TABLE del_then_insert_t(a INTEGER PRIMARY KEY, b TEXT);

statement ok
CREATE INDEX del_then_insert_idx ON del_then_insert_t
  USING inverted(a, b del_then_insert_dict);

statement ok
VACUUM (UPDATE_INDEXES) del_then_insert_t;

# Block iresearch commit so all subsequent ops only land in the WAL.
statement ok
SET sdb_faults = 'SearchCommitTask::commitUnsafe';

statement ok
INSERT INTO del_then_insert_t VALUES (1, 'stale token apple');

statement ok
DELETE FROM del_then_insert_t WHERE a = 1;

statement ok
INSERT INTO del_then_insert_t VALUES (1, 'fresh token banana');

statement ok
SET sdb_faults = 'crash_on_packet';

query error connection closed
SELECT 1;

# --- restart ---

connection after
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
VACUUM (UPDATE_INDEXES) del_then_insert_t;

# The stale token must NOT be searchable: if Delete didn't clear indexed_cols
# in the recovery accumulator, the pre-delete Put would leak through.
connection after
query
SELECT COUNT(*) FROM del_then_insert_idx WHERE b @@ ts_phrase('apple');
----
count
0

connection after
query
SELECT COUNT(*) FROM del_then_insert_idx WHERE b @@ ts_phrase('stale');
----
count
0

# Fresh content is searchable.
connection after
query
SELECT a FROM del_then_insert_idx WHERE b @@ ts_phrase('fresh');
----
a
1

connection after
query
SELECT a FROM del_then_insert_idx WHERE b @@ ts_phrase('banana');
----
a
1

connection after
query
SELECT a, b FROM del_then_insert_t ORDER BY a;
----
a	b
1	fresh token banana
