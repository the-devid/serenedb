statement ok
INSERT INTO t VALUES (4, 'Moomintroll'), (5, 'Moominpappa'), (6, 'Moominmamma');


query
SELECT reltuples FROM pg_class WHERE relname = 't';
----
reltuples
6


statement ok
CREATE TEXT SEARCH DICTIONARY test_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


statement ok
CREATE INDEX t_idx ON t USING inverted(name test_english);


statement ok
VACUUM (SYNC_STATS) t;


statement ok
VACUUM (UPDATE_INDEXES) t;


