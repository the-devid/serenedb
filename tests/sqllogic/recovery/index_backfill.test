control substitution on

statement ok
CREATE TEXT SEARCH DICTIONARY test_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

# crash before tombstone removal, index should be gone

statement ok
CREATE TABLE idx_bf_t(a INTEGER PRIMARY KEY, b TEXT);

statement ok
INSERT INTO idx_bf_t VALUES (1, 'pudge goes mid'), (2, 'vedernikoff carries team'), (3, 'babsky afk again');

statement ok
SET sdb_faults = 'crash_before_remove_tombstone';

statement error connection closed
CREATE INDEX idx_bf_crash ON idx_bf_t USING inverted(a, b test_english);

connection bf_after_1
statement error retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT * FROM idx_bf_crash;

# crash before finish creation, index should be gone

connection bf_after_3
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;

connection bf_after_3
statement ok
SET sdb_faults = 'crash_before_finish_creation';

connection bf_after_3
statement error connection closed
CREATE INDEX idx_bf_crash4 ON idx_bf_t USING inverted(a, b test_english);

connection bf_after_4
statement error retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT * FROM idx_bf_crash4;


# completed CREATE INDEX should survive crash

connection bf_after_4
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;

connection bf_after_4
statement ok
CREATE INDEX idx_bf_ok ON idx_bf_t USING inverted(a, b test_english);

connection bf_after_4
statement ok
SET sdb_faults = 'crash_on_packet';

connection bf_after_4
query error connection closed
SELECT 1;

connection bf_after_5
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
VACUUM (UPDATE_INDEXES) idx_bf_t;

connection bf_after_5
query
SELECT a, b FROM idx_bf_ok WHERE b @@ ts_phrase('pudge');
----
a	b
1	pudge goes mid

connection bf_after_5
query
SELECT a, b FROM idx_bf_ok WHERE b @@ ts_phrase('vedernikoff carries');
----
a	b
2	vedernikoff carries team

connection bf_after_5
query
SELECT a, b FROM idx_bf_ok WHERE b @@ ts_phrase('babsky');
----
a	b
3	babsky afk again
