## Crash AFTER rocksdb commit but BEFORE iresearch TruncateCommit, on a
## table whose inverted index covers ONLY sdb_indexonly columns. The
## DeleteRange on the table's row range is in the WAL, but iresearch
## still holds the pre-truncate segments. wal_recovery's DeleteRangeCF
## must replay the truncate into every inverted shard on the table --
## same path as for non-IndexOnly tables.

control substitution on

statement ok
CREATE TEXT SEARCH DICTIONARY indexonly_trunc_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE TABLE indexonly_trunc (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  PRIMARY KEY (id)
) WITH (sdb_indexonly = [body]);

statement ok
CREATE INDEX indexonly_trunc_idx
  ON indexonly_trunc USING inverted(body indexonly_trunc_english);

statement ok
INSERT INTO indexonly_trunc VALUES
  (1, 'pre truncate alpha bravo'),
  (2, 'pre truncate charlie delta');

statement ok
VACUUM (UPDATE_INDEXES) indexonly_trunc;

# Sanity: rows are searchable before TRUNCATE.
query
SELECT id FROM indexonly_trunc_idx WHERE body @@ ts_phrase('pre truncate alpha bravo');
----
id
1

# Arm the failpoint: TRUNCATE writes the DeleteRange batch to rocksdb
# (WAL fsynced), then crashes BEFORE iresearch TruncateCommit runs.
statement ok
SET sdb_faults = 'TRUNCATE::CrashAfterRocksdbWrite';

statement error connection closed
TRUNCATE indexonly_trunc;

# --- restart ---

connection after_truncate
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;

# rocksdb has the truncate -- table is empty in main storage.
connection after_truncate
query
SELECT COUNT(*) FROM indexonly_trunc;
----
count
0

# wal_recovery's DeleteRangeCF must have called TruncateCommit on every
# inverted shard on the table, even though every indexed column is
# sdb_indexonly. Pre-truncate phrases must NOT be searchable.
connection after_truncate
query
SELECT id FROM indexonly_trunc_idx WHERE body @@ ts_phrase('pre truncate alpha bravo');
----
id

connection after_truncate
query
SELECT id FROM indexonly_trunc_idx WHERE body @@ ts_phrase('pre truncate charlie delta');
----
id

# Table is functional after recovery -- inserts land and index them.
connection after_truncate
statement ok
INSERT INTO indexonly_trunc VALUES
  (10, 'post truncate echo foxtrot'),
  (20, 'post truncate golf hotel');

connection after_truncate
statement ok
VACUUM (UPDATE_INDEXES) indexonly_trunc;

connection after_truncate
query
SELECT id FROM indexonly_trunc_idx WHERE body @@ ts_phrase('post truncate echo foxtrot') ORDER BY id;
----
id
10

connection after_truncate
query
SELECT id FROM indexonly_trunc_idx WHERE body @@ ts_phrase('post truncate golf hotel') ORDER BY id;
----
id
20

connection after_truncate
statement ok
DROP TABLE indexonly_trunc;
