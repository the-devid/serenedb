control substitution on
control max-async-connections 5

statement ok
CREATE TEXT SEARCH DICTIONARY test_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE TABLE t(r text);


statement ok
CREATE INDEX index_t ON t USING inverted(r test_english);


query
select c.relname as table_name, (select relname from pg_class where pg_class.oid = i.indexrelid) as index_name from pg_class as c join pg_index as i on c.oid = i.indrelid and c.relkind = 'r';
----
table_name	index_name
t	index_t


statement ok
SET sdb_faults = 'crash_on_packet';


query error connection closed
select 1;


connection new1
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT c.relname AS table_name, (SELECT relname FROM pg_class WHERE pg_class.oid = i.indexrelid) AS index_name FROM pg_class AS c JOIN pg_index AS i ON c.oid = i.indrelid AND c.relkind = 'r';
----
table_name	index_name
t	index_t


connection new1
statement ok
SET sdb_faults = 'crash_on_drop';


connection new1
statement error connection closed
DROP INDEX index_t;


connection new2
query ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
SELECT COUNT(*) from pg_class WHERE relname = 't';
----
count
1


connection new2
statement ok
CREATE INDEX index_t ON t USING inverted(r test_english);


connection new2
statement ok
RESET sdb_faults;


connection new2
statement ok
INSERT INTO t VALUES ('one'), ('two'), ('three');


connection new2
statement ok
SET sdb_faults = 'slow_search_task';


connection new2
statement ok
VACUUM (UPDATE_INDEXES) t;


statement async ok
INSERT INTO t VALUES ('one'), ('two'), ('three');


connection new2
query
SELECT r FROM index_t WHERE r @@ ts_phrase('one') LIMIT 1;
----
r
one


statement async ok
INSERT INTO t VALUES ('one'), ('two'), ('three');


connection new2
statement ok
DROP INDEX index_t;


wait


connection new2
statement ok
RESET sdb_faults;


connection new2
query
SELECT COUNT(*) FROM pg_class WHERE relname = 'index_t';
----
count
0


connection new2
query
SELECT COUNT(*) FROM pg_class WHERE relname = 't';
----
count
1

connection new2
statement ok
CREATE INDEX index_t ON t USING inverted(r test_english);


statement async ok
INSERT INTO t VALUES ('foo'), ('bar');


statement async ok
INSERT INTO t VALUES ('baz'), ('qux');


connection new2
statement ok
DROP INDEX index_t;


connection new2
statement ok
CREATE INDEX index_t ON t USING inverted(r test_english);


wait


connection new2
statement ok
VACUUM (UPDATE_INDEXES) t;


connection new2
query
SELECT COUNT(*) >= 1 FROM t WHERE r = 'foo';
----
?column?
t


connection new2
query
SELECT COUNT(*) >= 1 FROM t WHERE r = 'baz';
----
?column?
t


connection new2
statement ok
RESET sdb_faults;


connection new2
statement ok
INSERT INTO t VALUES ('one'), ('two'), ('three');


connection new2
statement ok
INSERT INTO t VALUES ('one'), ('two'), ('three');


# Force the inverted index to flush pending commits before the PHRASE lookup.
# Without this, the background commit thread's latency makes the lookup race
# with the INSERTs.
connection new2
statement ok
VACUUM (UPDATE_INDEXES) t;


connection new2
query
SELECT r FROM index_t WHERE r @@ ts_phrase('one') LIMIT 1;
----
r
one


connection new2
query
SELECT COUNT(*) >= 13 FROM t;
----
?column?
t


statement async ok
INSERT INTO t VALUES ('one'), ('two'), ('three');


statement async ok
INSERT INTO t VALUES ('one'), ('two'), ('three');


wait


connection new2
statement ok
DROP TABLE t;


# wait for drop
system ok
sleep 2


connection new2
query
SELECT * FROM sdb_search_tasks_status;
----
task_type	active_tasks	pending_tasks	threads
Commit	0	0	<slt:ignore>
Consolidation	0	0	<slt:ignore>
