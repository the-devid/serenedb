control substitution on

# DROP SCHEMA CASCADE inside the WAL recovery range.
#
# Two schemas, each with a table and an inverted index. Block search commits
# so iresearch lags rocksdb, then DROP SCHEMA CASCADE on one of them. On
# restart the catalog has only the surviving schema, and recovery must replay
# its WAL delta without tripping over the deleted schema's writes.

statement ok
CREATE SCHEMA ds_keep;

statement ok
CREATE SCHEMA ds_drop;

statement ok
CREATE TEXT SEARCH DICTIONARY ds_keep.ds_dict(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE TEXT SEARCH DICTIONARY ds_drop.ds_dict(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE TABLE ds_keep.t(id INTEGER PRIMARY KEY, body TEXT);

statement ok
CREATE TABLE ds_drop.t(id INTEGER PRIMARY KEY, body TEXT);

statement ok
INSERT INTO ds_keep.t VALUES (1, 'keep seed alpha'), (2, 'keep seed bravo');

statement ok
INSERT INTO ds_drop.t VALUES (1, 'drop seed one'), (2, 'drop seed two');

statement ok
CREATE INDEX ds_keep_idx ON ds_keep.t USING inverted(id, body ds_dict);

statement ok
CREATE INDEX ds_drop_idx ON ds_drop.t USING inverted(id, body ds_dict);

statement ok
VACUUM (UPDATE_INDEXES) ds_keep.t;

statement ok
VACUUM (UPDATE_INDEXES) ds_drop.t;

# Block search commits.
statement ok
SET sdb_faults = 'SearchCommitTask::commitUnsafe';

# Writes to both schemas that never reach iresearch.
statement ok
INSERT INTO ds_keep.t VALUES (3, 'keep after fault charlie');

statement ok
INSERT INTO ds_drop.t VALUES (3, 'drop after fault delta');

statement ok
UPDATE ds_keep.t SET body = 'keep CHANGED bravo' WHERE id = 2;

statement ok
UPDATE ds_drop.t SET body = 'drop CHANGED two' WHERE id = 2;

# Drop the entire schema cascading through table + index.
statement ok
DROP SCHEMA ds_drop CASCADE;

# More writes to the surviving schema after the drop.
statement ok
INSERT INTO ds_keep.t VALUES (4, 'keep post drop echo');

statement ok
DELETE FROM ds_keep.t WHERE id = 1;

statement ok
SET sdb_faults = 'crash_on_packet';

query error connection closed
SELECT 1;

# --- restart ---

connection ds_after
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
VACUUM (UPDATE_INDEXES) ds_keep.t;

# Dropped schema is gone.
connection ds_after
query
SELECT COUNT(*) FROM pg_namespace WHERE nspname = 'ds_drop';
----
count
0

connection ds_after
query
SELECT COUNT(*) FROM pg_namespace WHERE nspname = 'ds_keep';
----
count
1

# Surviving table: pks 2, 3, 4.
connection ds_after
query
SELECT COUNT(*) FROM ds_keep.t;
----
count
3

connection ds_after
query
SELECT COUNT(*) FROM ds_keep.ds_keep_idx;
----
count
3

connection ds_after
query
SELECT id FROM ds_keep.t WHERE body @@ ts_phrase('CHANGED');
----
id
2

connection ds_after
query
SELECT id FROM ds_keep.t WHERE body @@ ts_phrase('after fault charlie');
----
id
3

connection ds_after
query
SELECT id FROM ds_keep.t WHERE body @@ ts_phrase('post drop echo');
----
id
4

# Old pk=2 body and pk=1 are both gone.
connection ds_after
query
SELECT COUNT(*) FROM ds_keep.t WHERE body @@ ts_phrase('keep seed bravo');
----
count
0

connection ds_after
query
SELECT COUNT(*) FROM ds_keep.t WHERE id = 1;
----
count
0
