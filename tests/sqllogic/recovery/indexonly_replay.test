## Crash AFTER rocksdb commit but BEFORE iresearch commits.
##
## sdb_indexonly columns have no main-storage data; their values ride in the
## WAL as PutLogData [CP] / [RD] markers alongside the rocksdb writes. If the
## process dies in the gap between the rocksdb txn commit (WAL fsync done)
## and the iresearch segment commit, the inverted index has not absorbed
## the values yet -- but the WAL has them. wal_recovery must replay the
## markers into the inverted index on restart so the rows become searchable.

control substitution on

statement ok
CREATE TEXT SEARCH DICTIONARY indexonly_replay_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


# --- INSERT replay --------------------------------------------------------

statement ok
CREATE TABLE indexonly_replay (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  PRIMARY KEY (id)
) WITH (sdb_indexonly = [body]);

statement ok
CREATE INDEX indexonly_replay_idx
  ON indexonly_replay USING inverted(body indexonly_replay_english);

# Arm the failpoint: the next rocksdb commit succeeds (WAL fsynced) but the
# server aborts before iresearch's per-shard Commit can run.
statement ok
SET sdb_faults = 'crash_after_rocksdb_commit';

statement error connection closed
INSERT INTO indexonly_replay VALUES
  (1, 'pudge goes mid every game'),
  (2, 'anchin reads manga all day'),
  (3, 'pudge carries team again');

# Server restarted. wal_recovery should have replayed our [CP] markers.
connection after_replay
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;

connection after_replay
statement ok
VACUUM (UPDATE_INDEXES) indexonly_replay;

connection after_replay
query
SELECT id FROM indexonly_replay_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id
1
3

connection after_replay
query
SELECT id FROM indexonly_replay_idx WHERE body @@ ts_phrase('anchin') ORDER BY id;
----
id
2


# --- DELETE replay --------------------------------------------------------
#
# Insert a row, commit it normally, then DELETE under the same failpoint.
# wal_recovery must see the [RD] marker and propagate the delete to the
# inverted index even though the inverted index covers only the IndexOnly
# `body` column (no DeleteCF for an indexed column ever reaches replay).

connection after_replay
statement ok
INSERT INTO indexonly_replay VALUES (4, 'doomed phrase about to vanish');

connection after_replay
statement ok
VACUUM (UPDATE_INDEXES) indexonly_replay;

connection after_replay
query
SELECT id FROM indexonly_replay_idx WHERE body @@ ts_phrase('doomed phrase');
----
id
4

connection after_replay
statement ok
SET sdb_faults = 'crash_after_rocksdb_commit';

connection after_replay
statement error connection closed
DELETE FROM indexonly_replay WHERE id = 4;

connection after_delete
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;

connection after_delete
statement ok
VACUUM (UPDATE_INDEXES) indexonly_replay;

# Row 4 must be gone from the inverted index.
connection after_delete
query
SELECT id FROM indexonly_replay_idx WHERE body @@ ts_phrase('doomed phrase');
----
id

# Earlier rows are still there.
connection after_delete
query
SELECT id FROM indexonly_replay_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id
1
3

connection after_delete
statement ok
DROP TABLE indexonly_replay;


# --- UPDATE replay --------------------------------------------------------
#
# Update the IndexOnly column itself (so the scan doesn't need to read its
# old value -- Gap 1 blocks other UPDATE shapes). Crash after rocksdb
# commit but before iresearch commits the change. wal_recovery must
# replay the [CP] marker carrying the new value so the post-update term
# is searchable and the pre-update term is gone.

connection after_delete
statement ok
CREATE TABLE indexonly_update (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  PRIMARY KEY (id)
) WITH (sdb_indexonly = [body]);

connection after_delete
statement ok
CREATE INDEX indexonly_update_idx
  ON indexonly_update USING inverted(body indexonly_replay_english);

connection after_delete
statement ok
INSERT INTO indexonly_update VALUES
  (1, 'before update mango'),
  (2, 'before update nectarine');

# Seal the pre-update state into iresearch so the recovery range starts
# AFTER it -- the [CP] from the UPDATE batch is what must be replayed.
connection after_delete
statement ok
VACUUM (UPDATE_INDEXES) indexonly_update;

# Sanity: original phrase searchable.
connection after_delete
query
SELECT id FROM indexonly_update_idx WHERE body @@ ts_phrase('before update mango');
----
id
1

connection after_delete
statement ok
SET sdb_faults = 'crash_after_rocksdb_commit';

connection after_delete
statement error connection closed
UPDATE indexonly_update SET body = 'after update orange' WHERE id = 1;

connection after_update
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;

connection after_update
statement ok
VACUUM (UPDATE_INDEXES) indexonly_update;

# New phrase must be searchable -- wal_recovery replayed the [CP] for
# the post-update value.
connection after_update
query
SELECT id FROM indexonly_update_idx WHERE body @@ ts_phrase('after update orange');
----
id
1

# Old phrase must be gone -- FlushShard issues delete-by-PK before
# re-inserting cells, so id=1's pre-update body disappears.
connection after_update
query
SELECT id FROM indexonly_update_idx WHERE body @@ ts_phrase('before update mango');
----
id

# Untouched row is still indexed.
connection after_update
query
SELECT id FROM indexonly_update_idx WHERE body @@ ts_phrase('before update nectarine');
----
id
2

connection after_update
statement ok
DROP TABLE indexonly_update;
