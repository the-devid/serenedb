## Crash AFTER iresearch commit. wal_recovery must NOT re-apply WAL markers
## that are already absorbed by the durable iresearch segment. The
## existing per-batch sequence-number filter that wal_recovery uses to
## decide whether to replay a record must apply identically to the
## PutLogData [CP] / [RD] markers we ride in those same batches.

control substitution on

statement ok
CREATE TEXT SEARCH DICTIONARY indexonly_no_double_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE TABLE indexonly_no_double (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  PRIMARY KEY (id)
) WITH (sdb_indexonly = [body]);

statement ok
CREATE INDEX indexonly_no_double_idx
  ON indexonly_no_double USING inverted(body indexonly_no_double_english);

statement ok
INSERT INTO indexonly_no_double VALUES (1, 'pudge unique phrase one');

# Arm the post-commit crash. The next iresearch commit (driven by VACUUM
# below, or by the background commit thread -- both are fine) will
# complete successfully, then immediately abort the process. By that
# point the iresearch segment + committed_tick are durable on disk.
statement ok
SET sdb_faults = 'Search::CrashAfterCommit';

statement error connection closed
VACUUM (UPDATE_INDEXES) indexonly_no_double;

# After restart, the inverted index already contains the row -- recovery
# must NOT add it again. If the committed_tick filter is wrong, we'd see
# count == 2.
connection after_crash
statement ok retry $RETRY_ATTEMPTS backoff $BACKOFF_DURATION
RESET sdb_faults;

connection after_crash
query
SELECT COUNT(*) FROM indexonly_no_double_idx WHERE body @@ ts_phrase('pudge unique phrase one');
----
count
1

connection after_crash
statement ok
DROP TABLE indexonly_no_double;
