statement ok
DELETE FROM stress_t WHERE id = 100401;

statement ok
DELETE FROM stress_t WHERE id >= 100540 AND id < 100550;

statement ok
UPDATE stress_t SET body = 'upd1_R1_' || id WHERE id >= 100050 AND id < 100060;

statement ok
UPDATE stress_t SET body = 'upd2_R1_' || id WHERE id >= 100220 AND id < 100230;

statement ok
UPDATE stress_t SET body = 'upd_sgl_R1' WHERE id = 100400;

statement ok
UPDATE stress_t SET body = 'upd_block6_R1_' || id WHERE id >= 100500 AND id < 100520;

statement ok
UPDATE stress_t SET id = 109999 WHERE id = 100402;

statement ok
