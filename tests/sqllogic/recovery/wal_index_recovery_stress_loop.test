statement ok
DELETE FROM stress_t WHERE id = 100600;

statement ok
INSERT INTO stress_t VALUES (100700, 'late_R1');

statement ok
UPDATE stress_t SET body = 'late_R1_changed' WHERE id = 100700;

statement ok
DELETE FROM stress_t WHERE id >= 100820 AND id < 100830;

statement ok
SET sdb_faults = 'crash_on_packet';

query error connection closed
SELECT 1;

