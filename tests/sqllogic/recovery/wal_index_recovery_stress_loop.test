control substitution on

# Long crash-recovery chain: 10 rounds, each does ~20 mixed ops on its own
# id-sandbox (offset by R*100_000) before crashing. After every crash,
# recovery replays the round's WAL delta. After 10 cycles we verify:
#   - total row count matches expectation
#   - index count matches table count
#   - spot-check tokens from each round are searchable
#   - tokens that were updated/deleted away are gone
#
# Per-round sandbox layout (smaller than huge.test on purpose):
#   [R*100000+0   .. +20)    block A head — DELETED
#   [R*100000+20  .. +50)    block A leftover
#   [R*100000+50  .. +60)    block A updated body (upd1_)
#   [R*100000+60  .. +200)   block A leftover
#   [R*100000+200 .. +202)   block B head — DELETED (200, 201)
#   [R*100000+202 .. +220)   block B leftover
#   [R*100000+220 .. +230)   block B updated body (upd2_)
#   [R*100000+230 .. +300)   block B leftover
#   [R*100000+400)           sgl1 (updated body)
#   [R*100000+401)           sgl2 (deleted)
#   [R*100000+402 → +9999]   sgl3 (PK-updated to +9999)
#   [R*100000+500 .. +520)   block C updated body (upd_block6_)
#   [R*100000+520 .. +540)   block C leftover
#   [R*100000+540 .. +550)   block C tail — DELETED
#   [R*100000+600)           ephemeral (insert + delete)
#   [R*100000+700)           late singleton (updated body)
#   [R*100000+800 .. +820)   block D leftover
#   [R*100000+820 .. +830)   block D tail — DELETED
#
# Per-round surviving rows:
#   block A : 180 (200 - 20 deleted)
#   block B : 98  (100 - 2 deleted)
#   sgl1    : 1
#   sgl3 @ 9999 : 1
#   block C : 40  (50 - 10 deleted)
#   late    : 1
#   block D : 20  (30 - 10 deleted)
#   total   : 341 rows per sandbox
#
# Across 10 rounds: 3410 total rows.

statement ok
CREATE TEXT SEARCH DICTIONARY stress_dict(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE TABLE stress_t(id INTEGER PRIMARY KEY, body TEXT);

statement ok
CREATE INDEX stress_idx ON stress_t USING inverted(id, body stress_dict)
  WITH (commit_interval = 0);

statement ok
VACUUM (UPDATE_INDEXES) stress_t;

###############################################################################
# Round 1
###############################################################################

statement ok
SET sdb_faults = 'SearchCommitTask::commitUnsafe';

statement ok
INSERT INTO stress_t SELECT i, 'ins_R1_' || i FROM range(100000, 100200) AS t(i);

statement ok
INSERT INTO stress_t SELECT i, 'ins_R1_' || i FROM range(100200, 100300) AS t(i);

statement ok
INSERT INTO stress_t VALUES (100400, 'sgl1_R1');

statement ok
INSERT INTO stress_t VALUES (100401, 'sgl2_R1'), (100402, 'sgl3_R1');

statement ok
INSERT INTO stress_t SELECT i, 'block_C_R1_' || i FROM range(100500, 100550) AS t(i);

statement ok
INSERT INTO stress_t SELECT i, 'block_D_R1_' || i FROM range(100800, 100830) AS t(i);

statement ok
DELETE FROM stress_t WHERE id >= 100000 AND id < 100020;

statement ok
