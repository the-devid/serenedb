FROM
(
  VALUES
    ('babsky', 22, -5), ('babsky', 20, -3), ('babsky', 21, -4), ('babsky', 21, -4),
    ('vedernikoff', 14, 6), ('vedernikoff', 13, 4), ('vedernikoff', 14, 87)
) as clickclack(name, grade, iq)
