# Basic varchar literal
query
SELECT 'hello'::varchar;
----
varchar
hello


# Empty varchar
query
SELECT ''::varchar;
----
varchar
(empty)


# Varchar with spaces
query
SELECT '  spaces  '::varchar;
----
varchar
  spaces  


# Varchar with special characters
query
SELECT 'hello@world#2024'::varchar;
----
varchar
hello@world#2024


# Varchar with newline character (escape syntax)
query
SELECT E'line1\nline2\nline3'::varchar;
----
varchar
line1\nline2\nline3


query
SELECT E'line1\nline2'::varchar;
----
varchar
line1\nline2


query
SELECT E'line1'::varchar;
----
varchar
line1


# Varchar without newline character
query
SELECT 'line1\nline2'::varchar;
----
varchar
line1\\nline2



# Varchar with tab (escape syntax)
query
SELECT E'tab\there'::varchar;
----
varchar
tab\there


# Varchar with quotes
query
SELECT 'it''s working'::varchar;
----
varchar
it's working

# Varchar with backslash
query
SELECT '\it works'::varchar;
----
varchar
\\it works


# Varchar with unicode — Chinese
query
SELECT '你好世界'::varchar;
----
varchar
你好世界


# Varchar with unicode — emoji
query
SELECT '🌍🌎🌏'::varchar;
----
varchar
🌍🌎🌏


# Varchar with unicode — accented
query
SELECT 'café résumé naïve'::varchar;
----
varchar
café résumé naïve


# Varchar array — single element
query
SELECT ARRAY['hello'::varchar];
----
array
{hello}


# Varchar array — multiple elements
query
SELECT ARRAY['admin'::varchar, 'editor'::varchar, 'auditor'::varchar];
----
array
{admin,editor,auditor}


# Varchar array — spaces
query
SELECT ARRAY['hello world'::varchar, 'foo bar'::varchar];
----
array
{"hello world","foo bar"}


# Varchar array — with empty strings
query
SELECT ARRAY[''::varchar, ''::varchar, ''::varchar];
----
array
{"","",""}


# Varchar array — unicode strings
query
SELECT ARRAY['世界'::varchar, '🌍'::varchar, 'café'::varchar];
----
array
{世界,🌍,café}


# NULL varchar
query
SELECT NULL::varchar;
----
varchar
NULL


# Varchar array with NULL
query
SELECT ARRAY[NULL::varchar];
----
array
{NULL}


# Varchar array with NULL and values
query
SELECT ARRAY['value'::varchar, NULL::varchar, 'another'::varchar];
----
array
{value,NULL,another}


# Array with quotes
query
SELECT ARRAY['value'::varchar, NULL::varchar, '"quotes"'::varchar];
----
array
{value,NULL,"\\"quotes\\""}


# Array with item containing spaces
query
SELECT ARRAY['value'::varchar, NULL::varchar, '"quo tes"'::varchar];
----
array
{value,NULL,"\\"quo tes\\""}


# Array with item containing both unicode and spaces
query
SELECT ARRAY['世界'::varchar, '🌍'::varchar, 'ca   fé'::varchar];
----
array
{世界,🌍,"ca   fé"}

# From bytea
query
SELECT ('\x01 02 03 4d'::bytea)::varchar;
----
varchar
\\x0102034d

statement ok
SET BYTEA_OUTPUT = 'EsCaPe';

# From bytea
skipif pg-wire-extended
query
SELECT ('\x01 02 03 4d'::bytea)::varchar;
----
varchar
\\001\\002\\003M


query
SELECT 'str' = 'str'::varchar;
----
?column?
t
