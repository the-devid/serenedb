# quote_ident tests

# Simple lowercase identifier — no quoting needed
query
SELECT quote_ident('foo');
----
quote_ident
foo

# Uppercase letters — needs quoting (PG folds to lowercase)
query
SELECT quote_ident('Foo');
----
quote_ident
"Foo"

# Mixed case with space
query
SELECT quote_ident('Foo bar');
----
quote_ident
"Foo bar"

# Embedded double quote — gets doubled
query
SELECT quote_ident('foo"bar');
----
quote_ident
"foo""bar"

# Starts with digit — needs quoting
query
SELECT quote_ident('123abc');
----
quote_ident
"123abc"

# All lowercase with underscore — no quoting
query
SELECT quote_ident('my_table');
----
quote_ident
my_table

# Empty string — needs quoting
query
SELECT quote_ident('');
----
quote_ident
""

# Special characters
query
SELECT quote_ident('hello world!');
----
quote_ident
"hello world!"


# quote_literal tests

# Simple string
query
SELECT quote_literal('hello');
----
quote_literal
'hello'

# Embedded single quote — gets doubled
query
SELECT quote_literal('O''Reilly');
----
quote_literal
'O''Reilly'


# Embedded backslash — E-string with doubled backslash
query
SELECT quote_literal('C:\path');
----
quote_literal
 E'C:\\\\path'


# NULL input — returns NULL (STRICT)
query
SELECT quote_literal(NULL::text);
----
quote_literal
NULL


# Empty string
query
SELECT quote_literal('');
----
quote_literal
''


# quote_nullable tests

# Normal string
query
SELECT quote_nullable('hello');
----
quote_nullable
'hello'


# NULL input — returns the string NULL (not SQL NULL)
query
SELECT quote_nullable(NULL::text) IS NOT NULL;
----
?column?
t

query
SELECT quote_nullable(NULL::text);
----
quote_nullable
NULL


# Embedded single quote
query
SELECT quote_nullable('it''s');
----
quote_nullable
'it''s'


query
SELECT ARRAY(SELECT * FROM (VALUES (1), (2), (3)));
----
array
{1,2,3}


# SQL function with implicit type coercion of arguments ($1/$2 syntax)

statement ok
CREATE FUNCTION test_coerce_pos(bigint, bigint) RETURNS bigint LANGUAGE SQL AS 'SELECT $1 + $2'


query
SELECT test_coerce_pos(1, 2);
----
test_coerce_pos
3


query
SELECT pg_typeof(test_coerce_pos(1, 2));
----
pg_typeof
bigint


statement ok
DROP FUNCTION test_coerce_pos


# SQL function with named parameters and type coercion

statement ok
CREATE FUNCTION test_coerce_named(a bigint, b bigint) RETURNS bigint LANGUAGE SQL AS 'SELECT a + b'


query
SELECT test_coerce_named(1, 2);
----
test_coerce_named
3


query
SELECT pg_typeof(test_coerce_named(1, 2));
----
pg_typeof
bigint


statement ok
DROP FUNCTION test_coerce_named


