query
EXPLAIN
WITH m(name, total) AS (
  VALUES
    ('pudge', 150),
    ('pudge', 0),
    ('deadinside', 200),
    ('deadinside', 250),
    ('makak', 175),
    ('makak', 65)
)
SELECT * FROM m
WHERE total = (
  SELECT SUM(total)
  FROM m m2
  WHERE m2.name = m.name
);
----
