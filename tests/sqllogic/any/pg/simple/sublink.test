WITH networth AS (
  SELECT
    guy AS name,
    SUM(coins) AS total_money
  FROM (
    VALUES
      ('pudge', 100), ('pudge', 50), ('deadinside', 200), ('makak', 150), ('makak', 25)
  ) AS lmao(guy, coins)
  GROUP BY guy
),
guys AS (
  SELECT column1 as name
  FROM
  (
    VALUES ('vedernikoff'), ('makak'), ('deadinside')
  )
