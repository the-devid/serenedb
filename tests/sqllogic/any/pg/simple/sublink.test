query
EXPLAIN SELECT CASE WHEN c>(SELECT avg(c) FROM t1) THEN a*2 ELSE b*10 END
  FROM t1
 ORDER BY 1, a
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│          case ASC         │
│           #1 ASC          │
│                           │
│          ~3 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│         PROJECTION        │
│    ────────────────────   │
│   CASE  WHEN ((CAST(c AS  │
│  DOUBLE) > SUBQUERY)) THEN│
│   ((a * 2)) ELSE (b * 10) │
│             END           │
│             a             │
│                           │
│          ~3 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       CROSS_PRODUCT       ├──────────────┐
└─────────────┬─────────────┘              │
┌─────────────┴─────────────┐┌─────────────┴─────────────┐
│   ROCKSDB_TABLE_FULLSCAN  ││         PROJECTION        │
│    ────────────────────   ││    ────────────────────   │
│         Table: t1         ││ CASE  WHEN ((#1 > 1)) THEN│
│                           ││   ("error"('More than one │
│        Projections:       ││      row returned by a    │
│             c             ││     subquery used as an   │
│             a             ││     expression - scalar   │
│             b             ││     subqueries can only   │
│                           ││    return a single row.   │
│                           ││          Use "SET         │
│                           ││ scalar_subquery_error_on_m│
│                           ││   ultiple_rows=false" to  │
│                           ││     revert to previous    │
│                           ││   behavior of returning a │
│                           ││ random row.')) ELSE #0 END│
│                           ││                           │
│          ~3 rows          ││           ~1 row          │
└───────────────────────────┘└─────────────┬─────────────┘
                             ┌─────────────┴─────────────┐
                             │    UNGROUPED_AGGREGATE    │
                             │    ────────────────────   │
                             │        Aggregates:        │
                             │        "first"(#0)        │
                             │        count_star()       │
                             │                           │
                             │           ~1 row          │
                             └─────────────┬─────────────┘
                             ┌─────────────┴─────────────┐
                             │         PROJECTION        │
                             │    ────────────────────   │
                             │             #0            │
                             │                           │
                             │           ~1 row          │
                             └─────────────┬─────────────┘
                             ┌─────────────┴─────────────┐
                             │         PROJECTION        │
                             │    ────────────────────   │
                             │  "/"(CAST(#0 AS DOUBLE),  │
                             │     CAST(#1 AS DOUBLE))   │
                             │                           │
                             │           ~1 row          │
                             └─────────────┬─────────────┘
                             ┌─────────────┴─────────────┐
                             │    UNGROUPED_AGGREGATE    │
                             │    ────────────────────   │
                             │        Aggregates:        │
                             │          sum(#0)          │
                             │         count(#1)         │
                             │                           │
                             │           ~1 row          │
                             └─────────────┬─────────────┘
                             ┌─────────────┴─────────────┐
                             │         PROJECTION        │
