                             │  CAST(total AS HUGEINT) = ├──────────────┐
                             │          SUBQUERY         │              │
                             │ name IS NOT DISTINCT FROM │              │
                             │            name           │              │
                             │                           │              │
                             │          ~3 rows          │              │
                             └─────────────┬─────────────┘              │
                             ┌─────────────┴─────────────┐┌─────────────┴─────────────┐
                             │          CTE_SCAN         ││       HASH_GROUP_BY       │
                             │    ────────────────────   ││    ────────────────────   │
