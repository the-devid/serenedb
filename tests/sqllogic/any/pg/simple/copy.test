# JSON Lines: structured round-trip via DuckDB's native json copy function.
# COPY TO (FORMAT json) serializes rows as JSON objects (one per line).
# COPY FROM (FORMAT json) parses JSON keys into table columns.

onlyif serenedb
statement ok
CREATE TABLE json_source (kostya BIGINT, vedernikoff TEXT);

onlyif serenedb
statement ok
INSERT INTO json_source VALUES (666, 'clickclack'), (993, 'deadinside'), (228, 'babsky');

onlyif serenedb
statement count 3
COPY json_source TO '/tmp/${__DATABASE__}_kostya.jsonl' (FORMAT json);


# .jsonl extension auto-detected as JSON format
onlyif serenedb
statement ok
CREATE TABLE json_target (kostya BIGINT, vedernikoff TEXT);

onlyif serenedb
statement count 3
COPY json_target FROM '/tmp/${__DATABASE__}_kostya.jsonl';

onlyif serenedb
query
SELECT * FROM json_target ORDER BY 1;
----
