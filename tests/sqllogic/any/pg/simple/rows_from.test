CREATE TABLE clickclack(id BIGINT, name TEXT, score BIGINT);


statement count 1
INSERT INTO clickclack VALUES (1, 'vedernikoff', 100);


statement count 1
INSERT INTO clickclack VALUES (2, 'petrov', 200);


statement count 1
INSERT INTO clickclack VALUES (3, 'sidorov', 300);


