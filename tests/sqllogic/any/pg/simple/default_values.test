CREATE TABLE clickclack(
  id INTEGER PRIMARY KEY DEFAULT 1000,
  weight INTEGER DEFAULT 100,
  age INTEGER DEFAULT 228,
  grade INTEGER GENERATED ALWAYS AS ( (2 * weight + age) / 10 + length('vedro')::integer - 5) STORED
);


