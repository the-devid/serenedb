onlyif serenedb
query
EXPLAIN (LOGICAL) CREATE TABLE vedernikoff AS SELECT x FROM generate_series(1, 10) AS t(x);
----
QUERY PLAN
LOGICAL PLAN:
- TableWrite INSERT: -> ROW<rows:BIGINT>
    x := x
  - Project: -> ROW<"x":BIGINT>
      x := generate_series
    - Project: -> ROW<"generate_series":BIGINT>
        generate_series := generate_series
      - Unnest: -> ROW<"generate_series":BIGINT>
          [generate_series] := pg_generate_series(CAST(1 AS BIGINT), CAST(10 AS BIGINT))
        - Values: 1 rows -> ROW<>


