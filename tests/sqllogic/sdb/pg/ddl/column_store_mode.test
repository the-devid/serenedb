## sdb_indexonly column-store-mode option in CREATE TABLE WITH-clause.
## NOTE: SELECT on an index-only column will be made an error once the feature
## is finished. Tests below avoid querying the marked columns directly.

# Happy path: single column marked. Only non-indexonly columns are queried.
statement ok
CREATE TABLE indexonly_t1 (
  a INTEGER NOT NULL,
  b VARCHAR NOT NULL,
  c BIGINT NOT NULL,
  PRIMARY KEY (a)
) WITH (sdb_indexonly = [b]);

statement ok
INSERT INTO indexonly_t1 VALUES (1, 'one', 100), (2, 'two', 200);

query
SELECT a, c FROM indexonly_t1 ORDER BY a;
----
a	c
1	100
2	200

statement ok
DROP TABLE indexonly_t1;


# Multiple columns marked.
statement ok
CREATE TABLE indexonly_t2 (
  a INTEGER NOT NULL,
  b VARCHAR NOT NULL,
  c BIGINT NOT NULL,
  PRIMARY KEY (a)
) WITH (sdb_indexonly = [b, c]);

statement ok
INSERT INTO indexonly_t2 VALUES (1, 'x', 10);

query
SELECT a FROM indexonly_t2;
----
a
1


# Error: list references unknown column.
statement error
CREATE TABLE indexonly_err1 (
  a INTEGER NOT NULL,
  PRIMARY KEY (a)
) WITH (sdb_indexonly = [missing]);
----
db error: ERROR: WITH option "sdb_indexonly" references unknown column "missing"


# Error: scalar value instead of list.
statement error
CREATE TABLE indexonly_err2 (
  a INTEGER NOT NULL,
  PRIMARY KEY (a)
) WITH (sdb_indexonly = 1);
----
db error: ERROR: WITH option "sdb_indexonly" expects a list literal, e.g. [col1, col2]


# Error: list element is not an identifier.
statement error
CREATE TABLE indexonly_err3 (
  a INTEGER NOT NULL,
  PRIMARY KEY (a)
) WITH (sdb_indexonly = [1, 2]);
----
db error: ERROR: WITH option "sdb_indexonly" list element is not a column name


# Secondary index over an IndexOnly column must be rejected -- the column's
# values exist only inside inverted indexes, so a btree/secondary key over
# them would have nothing to read. Reuses indexonly_t2 (b, c are IndexOnly).

# Single-column secondary index on an IndexOnly column.
statement error
CREATE INDEX indexonly_t2_b ON indexonly_t2 (b);
----
db error: ERROR: Failed to create index: cannot include column "b" in a secondary index: column has sdb_indexonly storage and is only readable through an inverted index


# Composite secondary index mixing a normal and an IndexOnly column.
statement error
CREATE INDEX indexonly_t2_ab ON indexonly_t2 (a, b);
----
db error: ERROR: Failed to create index: cannot include column "b" in a secondary index: column has sdb_indexonly storage and is only readable through an inverted index


# UNIQUE secondary index over an IndexOnly column.
statement error
CREATE UNIQUE INDEX indexonly_t2_uniq_c ON indexonly_t2 (c);
----
db error: ERROR: Failed to create index: cannot include column "c" in a secondary index: column has sdb_indexonly storage and is only readable through an inverted index


# Sanity: secondary index over the normal column is fine.
statement ok
CREATE INDEX indexonly_t2_a ON indexonly_t2 (a);


# Reading an sdb_indexonly column directly is rejected -- the column has
# no main-storage data, so SELECT / ORDER BY / unindexed WHERE cannot
# materialise it. Only inverted-index search predicates that the optimizer
# claims into an IRESEARCH_* scan are allowed.

# Direct projection.
statement error
SELECT b FROM indexonly_t2;
----
db error: ERROR: column "b" has sdb_indexonly storage and cannot be read directly; it is only accessible through an inverted-index search predicate


# SELECT * also expands to include the IndexOnly column and is rejected.
statement error
SELECT * FROM indexonly_t2;
----
db error: ERROR: column "b" has sdb_indexonly storage and cannot be read directly; it is only accessible through an inverted-index search predicate


# WHERE filter that the inverted index cannot claim.
statement error
SELECT a FROM indexonly_t2 WHERE b = 'x';
----
db error: ERROR: column "b" has sdb_indexonly storage and cannot be read directly; it is only accessible through an inverted-index search predicate


# ORDER BY on an IndexOnly column.
statement error
SELECT a FROM indexonly_t2 ORDER BY c;
----
db error: ERROR: column "c" has sdb_indexonly storage and cannot be read directly; it is only accessible through an inverted-index search predicate


# Sanity: a query that doesn't reference the IndexOnly column still works.
query
SELECT a FROM indexonly_t2 WHERE a = 1;
----
a
1

statement ok
DROP TABLE indexonly_t2;


# Inverted index over an IndexOnly column: data is searchable through the
# index's search predicates even though direct reads of the column are
# rejected. Order matters -- the inverted index must exist before INSERT,
# otherwise the IndexOnly value has no destination (main storage is skipped
# for IndexOnly, and CREATE INDEX backfill cannot recover values that were
# never persisted).

statement ok
CREATE TABLE indexonly_search (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  PRIMARY KEY (id)
) WITH (sdb_indexonly = [body]);

statement ok
CREATE TEXT SEARCH DICTIONARY indexonly_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE INDEX indexonly_search_idx
  ON indexonly_search USING inverted(body indexonly_english);

statement ok
INSERT INTO indexonly_search VALUES
  (1, 'pudge goes mid every game'),
  (2, 'anchin reads manga all day'),
  (3, 'pudge carries team again');

statement ok
VACUUM (UPDATE_INDEXES) indexonly_search;

# Search predicate against the IndexOnly column passes through the inverted
# index. Only `id` is projected; `body` is consumed by the predicate and
# removed from the scan's column list by the optimizer.
query
SELECT id FROM indexonly_search_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id
1
3

# Direct projection of the IndexOnly column from the base table is still
# rejected (the IRESEARCH_* claim only happens for @@-style predicates).
statement error
SELECT body FROM indexonly_search;
----
db error: ERROR: column "body" has sdb_indexonly storage and cannot be read directly; it is only accessible through an inverted-index search predicate


statement ok
DROP TABLE indexonly_search;


# Inverted index created AFTER inserts. Pre-existing rows lose their
# IndexOnly values (main storage is skipped, no inverted index existed at
# INSERT time), so the backfill produces an empty index for that column.
# The CREATE INDEX statement itself must still succeed -- the read-side
# check on IndexOnly columns is relaxed during CREATE INDEX backfill.
# Inserts AFTER the index is in place are searchable normally.

statement ok
CREATE TABLE indexonly_late (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  PRIMARY KEY (id)
) WITH (sdb_indexonly = [body]);

statement ok
INSERT INTO indexonly_late VALUES
  (1, 'lost forever one'),
  (2, 'lost forever two');

# CREATE INDEX after INSERT does not error; backfill silently produces an
# empty index for the IndexOnly column.
statement ok
CREATE INDEX indexonly_late_idx
  ON indexonly_late USING inverted(body indexonly_english);

statement ok
VACUUM (UPDATE_INDEXES) indexonly_late;

# The two pre-index rows are not searchable -- their `body` was never
# persisted anywhere.
query
SELECT id FROM indexonly_late_idx WHERE body @@ ts_phrase('lost') ORDER BY id;
----
id

# Inserts after the index is in place flow through the inverted writer and
# become searchable normally.
statement ok
INSERT INTO indexonly_late VALUES
  (3, 'pudge after index'),
  (4, 'anchin after index');

statement ok
VACUUM (UPDATE_INDEXES) indexonly_late;

query
SELECT id FROM indexonly_late_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id
3

statement ok
DROP TABLE indexonly_late;


# Composite inverted index where the IndexOnly column is NOT the leading
# index column. Pre-fix, the backfill scan had a non-empty leading iterator
# (id) and an empty IndexOnly iterator (body), hitting an internal assertion
# (col_count == count). Post-fix, presence of any IndexOnly column in the
# scan projection during CREATE INDEX backfill marks the scan as already
# finished -- backfill is a no-op, statement succeeds.

statement ok
CREATE TABLE indexonly_composite (
  id INTEGER NOT NULL,
  body TEXT NOT NULL,
  PRIMARY KEY (id)
) WITH (sdb_indexonly = [body]);

statement ok
INSERT INTO indexonly_composite VALUES
  (1, 'preexisting one'),
  (2, 'preexisting two');

# Composite inverted index: id (regular, has data) + body (IndexOnly, no
# main-storage data). Order puts the data-bearing column first; pre-fix this
# would assert.
statement ok
CREATE INDEX indexonly_composite_idx
  ON indexonly_composite USING inverted(id, body indexonly_english);

statement ok
VACUUM (UPDATE_INDEXES) indexonly_composite;

# Pre-existing rows are not in the index (backfill was a no-op).
query
SELECT id FROM indexonly_composite_idx WHERE body @@ ts_phrase('preexisting') ORDER BY id;
----
id

# New inserts populate the index normally and are searchable.
statement ok
INSERT INTO indexonly_composite VALUES (3, 'fresh row');

statement ok
VACUUM (UPDATE_INDEXES) indexonly_composite;

query
SELECT id FROM indexonly_composite_idx WHERE body @@ ts_phrase('fresh') ORDER BY id;
----
id
3

statement ok
DROP TABLE indexonly_composite;
