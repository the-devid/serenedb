# Basic TRUNCATE
statement ok
CREATE TABLE pudge (id INTEGER PRIMARY KEY, kostya TEXT);

statement count 3
INSERT INTO pudge VALUES (1, 'clickclack'), (2, 'deadinside'), (3, 'gul');

query
SELECT * FROM pudge ORDER BY id;
----
id	kostya
1	clickclack
2	deadinside
3	gul

statement ok
TRUNCATE pudge;

query
SELECT * FROM pudge ORDER BY id;
----
id	kostya

# Table still exists and accepts inserts after truncate
statement count 2
INSERT INTO pudge VALUES (10, 'makak'), (20, 'noscope');

query
SELECT * FROM pudge ORDER BY id;
----
id	kostya
10	makak
20	noscope

statement ok
DROP TABLE pudge;


