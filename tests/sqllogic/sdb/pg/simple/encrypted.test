connection ssl-tls sslmode=prefer port=plain
skipif pg-wire-extended
query
select 1234567890123456::numeric;
----
numeric
1234567890123456.0000000000000000000


connection ssl-tls2 sslmode=prefer port=ssl
skipif pg-wire-extended
query
select 1234567890123456::numeric;
----
numeric
1234567890123456.0000000000000000000


connection ssl-tls3 sslmode=require port=ssl
skipif pg-wire-extended
query
select 1234567890123456::numeric;
----
numeric
1234567890123456.0000000000000000000


connection ssl-tls4 sslmode=require port=plain
skipif pg-wire-extended
query error
select 1234567890123456::numeric;
----
error performing TLS handshake: server does not support TLS


connection ssl-tls5 sslmode=disable port=ssl
skipif pg-wire-extended
query error
select 1234567890123456::numeric;
----
connection closed
