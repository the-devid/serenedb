    delimiters = '"a"'
)


query
SELECT ts_lexize('multi_delim_single', 'baccaad');
----
ts_lexize
{b,cc,d}


# --- Empty result when input is only delimiters (test_delimiter_empty_match) ---

statement ok
CREATE TEXT SEARCH DICTIONARY multi_delim_dot(
    template = 'multi_delimiter',
    delimiters = '"."'
)


query
SELECT ts_lexize('multi_delim_dot', '..');
----
ts_lexize
{}


# --- Three single-character delimiters (test_delimiter_3) ---

