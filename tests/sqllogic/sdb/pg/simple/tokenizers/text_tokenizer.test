# --- ts_lexize: wildcard tokens contain 0xFF boundary sentinels.
# ts_lexize is typed VARCHAR[], but DuckDB's `Value::Value(string)`
# validates UTF-8 -- so element-wise materialisation through `unnest`
# would reject the raw bytes. Casting `ts_lexize(...)::BLOB[]` before
# the unnest routes each token through the BLOB Value path (no
# validation), and `encode(t, 'escape')` then renders the bytes with
# `\\377` for the 0xFF sentinel and printable ASCII passed through as-is.

query
SELECT encode(t, 'escape')
FROM unnest(ts_lexize('wildcard_default', 'hello')::BLOB[]) AS t
ORDER BY 1;
----
encode
\\377he
ell
hel
llo
lo\\377
o\\377


query
SELECT encode(t, 'escape')
FROM unnest(ts_lexize('wildcard_ngram2', 'hello')::BLOB[]) AS t
ORDER BY 1;
----
encode
\\377h
el
he
ll
lo
o\\377


query
SELECT encode(t, 'escape')
FROM unnest(ts_lexize('wildcard_default', 'hello world')::BLOB[]) AS t
ORDER BY 1;
----
encode
\\377he
\\377wo
d\\377
ell
hel
ld\\377
llo
lo\\377
o\\377
orl
rld
wor


query
SELECT encode(t, 'escape')
FROM unnest(ts_lexize('wildcard_ngram5_seg', 'quick')::BLOB[]) AS t
ORDER BY 1;
----
encode
\\377quic
ck\\377
ick\\377
k\\377
quick
uick\\377


query
SELECT encode(t, 'escape')
FROM unnest(ts_lexize('wildcard_text_base', 'Fox juMps')::BLOB[]) AS t
ORDER BY 1;
----
encode
\\377fo
\\377ju
fox
jum
mps
ox\\377
ps\\377
s\\377
ump
x\\377


