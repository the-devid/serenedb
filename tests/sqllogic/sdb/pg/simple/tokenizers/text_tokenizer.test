# HELP

statement error
CREATE TEXT SEARCH DICTIONARY a(help);
----
db error: ERROR: 
Text Search Dictionary:
  template[required] (string) [default: none] - Tokenizer template type
  features:
    norm (boolean) [default: false] - Enables norm feature in index
    offset (boolean) [default: false] - Enables offset feature in index
    position (boolean) [default: false] - Enables position feature in index
    frequency (boolean) [default: false] - Enables frequency feature in index
  text:
    locale (string) - ICU locale string (e.g. en_US.UTF-8)
    accent (boolean) [default: true] - Preserve accent marks
    stemming (boolean) [default: true] - Apply stemming to tokens
    stopwords (string) - Comma-separated list of inline stop words
    stopwordspath (string) - Path to file containing stop words
    case (string) [default: none] - Text case conversion: none, lower, upper
    edgengram:
      mingram (integer) [default: 2] - Minimum n-gram length
      maxgram (integer) [default: 3] - Maximum n-gram length
      preserveoriginal (boolean) [default: false] - Emit the original token alongside n-grams
  ngram:
    mingram (integer) [default: 2] - Minimum n-gram length
    maxgram (integer) [default: 3] - Maximum n-gram length
    preserveoriginal (boolean) [default: false] - Emit the original token alongside n-grams
    inputtype (string) [default: utf8] - Input stream encoding: binary, utf8
    startmarker (string) - Prefix marker appended at n-gram boundary
    endmarker (string) - Suffix marker appended at n-gram boundary
  nearest_neighbors:
    modellocation (string) - Path to the ML model file
    topk (integer) [default: 1] - Number of top results to return
  stem:
    locale (string) - ICU locale string (e.g. en_US.UTF-8)
  stopwords:
    stopwords (string) - Comma-separated list of inline stop words
    hex (boolean) [default: false] - Treat stop words as hex-encoded strings
  classification:
    modellocation (string) - Path to the ML model file
    topk (integer) [default: 1] - Number of top results to return
    threshold (double) [default: 0] - Minimum confidence score [0.0..1.0]
  collation:
    locale (string) - ICU locale string (e.g. en_US.UTF-8)
  delimiter:
    delimiter[required] (string) [default: none] - Token delimiter character or string
  multi_delimiter:
    delimiters[required] (string) [default: none] - The list of delimiters(e.g., '",", "|", "!"'
  minhash:
    numhashes (integer) [default: 1] - Number of hash functions to use
  wildcard:
    ngramsize (integer) [default: 3] - N-gram size for wildcard prefix indexing (minimum 2)
  norm:
    locale (string) - ICU locale string (e.g. en_US.UTF-8)
    case (string) [default: none] - Text case conversion: none, lower, upper
    accent (boolean) [default: true] - Preserve accent marks
  segmentation:
    case (string) [default: none] - Text case conversion: none, lower, upper
    break (string) [default: alpha] - Token boundary detection mode: all, graphic, alpha
  pipeline:
    (no additional options)
  pattern:
    pattern[required] (string) [default: none] - RE2 regular expression pattern for matching or splitting
    group (integer) [default: -1] - Capture group to extract: -1=split, 0=whole match, N>0=Nth group
  path_hierarchy:
    delimiter (string) [default: /] - Path separator character or string (UTF-8)
    replacement (string) - Replacement for delimiter in tokens
    reverse (boolean) [default: false] - Use reverse tokenization for domain-like hierarchies
    skip (integer) [default: 0] - Number of initial tokens to skip
    buffersize (integer) [default: 1024] - Term buffer size hint (characters per pass)
  union:
    (no additional options)
  copy_from:
    from[required] (string) [default: none] - the source tokenizer name
  geopoint:
    latitude (string) - Slash-separated path to latitude field (e.g., 'lat' or 'loc/lat'); empty (the default) treats the indexed JSON value as a [lat, lng] array directly. latitude and longitude must both be set or both left empty.
    longitude (string) - Slash-separated path to longitude field (e.g., 'lng' or 'loc/lng'); see latitude for empty-default semantics.
    options:
      maxcells (integer) [default: 20] - Maximum number of S2 cells
      minlevel (integer) [default: 4] - Minimum S2 cell level (0-30)
      maxlevel (integer) [default: 23] - Maximum S2 cell level (0-30), ~1m precision at level 23
      levelmod (integer) [default: 1] - S2 level modifier (1, 2, or 3)
      optimizeforspace (boolean) [default: false] - Optimize S2 index for space rather than speed
  geojson:
    type (string) [default: shape] - GeoJson shape type: shape, centroid, point
    coding (string) [default: s2point] - Encoding format: s2point, s2latlngf64, s2latlngu32
    options:
      maxcells (integer) [default: 20] - Maximum number of S2 cells
      minlevel (integer) [default: 4] - Minimum S2 cell level (0-30)
      maxlevel (integer) [default: 23] - Maximum S2 cell level (0-30), ~1m precision at level 23
      levelmod (integer) [default: 1] - S2 level modifier (1, 2, or 3)
      optimizeforspace (boolean) [default: false] - Optimize S2 index for space rather than speed
  keyword:
    (no additional options)
