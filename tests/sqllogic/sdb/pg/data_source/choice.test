# ── 2-D: different a, same b constraint → b is trailing, full scan on a ───────
# (a<2 AND b=1) OR (a>2 AND b=1) → b=1 is 2nd col, can't be in prefix when a
# is a range; falls back to full scan with post-filter
query
SELECT COUNT(*) FROM t_sweep3 WHERE (a < 2 AND b = 1) OR (a > 2 AND b = 1);
----
count
6

