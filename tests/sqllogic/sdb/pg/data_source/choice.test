statement ok
INSERT INTO t_choice_cpk VALUES (1, 4, 11), (1, 6, 12), (2, 2, 21), (3, 2, 30), (3, 6, 32);


query
SELECT * FROM t_choice_cpk ORDER BY a, b;
----
a	b	val
1	2	10
1	4	11
1	6	12
2	2	21
3	2	30
3	4	20
3	6	32
5	6	30

# OrFilter of two complete PK conjunctions -> 2 specific points -> MultiGet.
query
SELECT * FROM t_choice_cpk WHERE (a=1 AND b=2) OR (a=3 AND b=4) ORDER BY a, b;
----
a	b	val
1	2	10
3	4	20

onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice_cpk WHERE (a=1 AND b=2) OR (a=3 AND b=4) ORDER BY a, b;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│     t_choice_cpk.a ASC    │
│     t_choice_cpk.b ASC    │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│  ROCKSDB_PK_POINTS_LOOKUP │
│    ────────────────────   │
│    Table: t_choice_cpk    │
│                           │
│          Filter:          │
│         (a=1, b=2)        │
│         (a=3, b=4)        │
│                           │
│        Projections:       │
│             a             │
│             b             │
│            val            │
│                           │
│          ~8 rows          │
└───────────────────────────┘

query
SELECT * FROM t_choice_cpk WHERE a=1 AND (b=2 OR b=4) ORDER BY a, b;
----
a	b	val
1	2	10
1	4	11

onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice_cpk WHERE a=1 AND (b=2 OR b=4) ORDER BY a, b;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│     t_choice_cpk.a ASC    │
│     t_choice_cpk.b ASC    │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│  ROCKSDB_PK_POINTS_LOOKUP │
│    ────────────────────   │
│    Table: t_choice_cpk    │
│                           │
│          Filter:          │
│         (a=1, b=2)        │
│         (a=1, b=4)        │
│                           │
│        Projections:       │
│             a             │
│             b             │
│            val            │
│                           │
│          ~8 rows          │
└───────────────────────────┘


# Cartesian product of {a:1},{b:2} x {a:2},{b:4}:
#   {a:1} and {a:2} = contradiction
#   {a:1} and {b:4} = (1,4) <- specific point
#   {b:2} and {a:2} = (2,2) <- specific point
#   {b:2} and {b:4} = contradiction
# -> 2 specific points -> point lookup.
query
SELECT * FROM t_choice_cpk WHERE (a=1 OR b=2) AND (a=2 OR b=4) ORDER BY a, b;
----
a	b	val
1	4	11
2	2	21

onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice_cpk WHERE (a=1 OR b=2) AND (a=2 OR b=4) ORDER BY a, b;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│     t_choice_cpk.a ASC    │
│     t_choice_cpk.b ASC    │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│  ROCKSDB_PK_POINTS_LOOKUP │
│    ────────────────────   │
│    Table: t_choice_cpk    │
│                           │
│          Filter:          │
│         (a=1, b=4)        │
│         (a=2, b=2)        │
│                           │
│        Projections:       │
│             a             │
│             b             │
│            val            │
│                           │
│          ~8 rows          │
└───────────────────────────┘


# 1=1 is not a call expression -> AnyFilterNode (no constraints).
# Cartesian of {a:1},{b:2} x {IsNoFilters} stays partial -> not specific -> full scan.
# Reads all 8 rows from the table.
onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice_cpk WHERE (a=1 OR b=2) AND 1=1 ORDER BY a, b;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│     t_choice_cpk.a ASC    │
│     t_choice_cpk.b ASC    │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│           FILTER          │
│    ────────────────────   │
│    ((a = 1) OR (b = 2))   │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│   ROCKSDB_TABLE_FULLSCAN  │
│    ────────────────────   │
│    Table: t_choice_cpk    │
│                           │
│        Projections:       │
│             a             │
│             b             │
│            val            │
│                           │
│          ~8 rows          │
└───────────────────────────┘


# 1=2 -> AnyFilterNode; first point emitted by OrFilter is {a:1} (partial) -> full scan.
