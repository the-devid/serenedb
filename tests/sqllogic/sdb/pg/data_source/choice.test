# Contradictory/void range tests — predicate can never be satisfied → 0 rows, range scan.
statement ok
CREATE TABLE t_void (a INT PRIMARY KEY, val INT);

statement ok
INSERT INTO t_void VALUES (1, 10), (3, 30), (5, 50);

# a < 1 AND a > 1 → contradictory, 0 ranges → empty result.
query
SELECT * FROM t_void WHERE a < 1 AND a > 1;
----
a	val

onlyif serenedb
query
EXPLAIN SELECT * FROM t_void WHERE a < 1 AND a > 1;
----
QUERY PLAN
┌───────────────────────────┐
│   ROCKSDB_PK_RANGES_SCAN  │
│    ────────────────────   │
│       Table: t_void       │
│     Filter: {a=empty}     │
│                           │
│        Projections:       │
│             a             │
│            val            │
│                           │
│          ~3 rows          │
