statement ok
CREATE TABLE t_neq (id INTEGER PRIMARY KEY, val INTEGER);

statement ok
INSERT INTO t_neq VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50);

# id != 4  ->  two ranges: (-inf, 4) and (4, +inf)  ->  4 rows
query
SELECT * FROM t_neq WHERE id != 4 ORDER BY id;
----
id	val
1	10
2	20
3	30
5	50

onlyif serenedb
query
