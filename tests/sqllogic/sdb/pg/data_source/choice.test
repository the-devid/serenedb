statement ok
CREATE TABLE choices_array (a INTEGER PRIMARY KEY, nums INTEGER[], labels VARCHAR[]);

statement ok
INSERT INTO choices_array VALUES
  (1, ARRAY[1, 2, 3], ARRAY['alpha', 'beta']),
  (2, ARRAY[4, 5], ARRAY['gamma']),
  (3, ARRAY[1, 3], ARRAY['alpha', 'delta', 'epsilon']),
  (4, ARRAY[]::INTEGER[], ARRAY[]::VARCHAR[]);

# workaround for https://github.com/serenedb/serenedb/issues/530
statement ok
INSERT INTO choices_array VALUES (5, NULL, NULL);


onlyif serenedb
query
