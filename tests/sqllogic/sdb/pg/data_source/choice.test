# Tests that point lookups are chosen when the point filter fully covers
# the primary key, and that the full scan variants are chosen otherwise.
# Uses EXPLAIN to verify the number of rows read by the TableScan.

# ATTENTION: if some constant folding optimization will be made, some tests
# may fail, especially ones that check that point lookup data source cannot be used.

statement ok
CREATE TABLE t_choice (id INTEGER PRIMARY KEY, val INTEGER);

statement ok
INSERT INTO t_choice VALUES (1, 10), (2, 20), (3, 30);

# Point lookup: WHERE id = 2 -> 1 specific point -> reads 1 row.
query
SELECT * FROM t_choice WHERE id = 2;
----
id	val
2	20

onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice WHERE id = 2;
----
QUERY PLAN
┌───────────────────────────┐
│  ROCKSDB_PK_POINTS_LOOKUP │
│    ────────────────────   │
│      Table: t_choice      │
│       Filter: (id=2)      │
│                           │
│        Projections:       │
│             id            │
│            val            │
│                           │
│          ~3 rows          │
└───────────────────────────┘

# No filter -> full scan
onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice ORDER BY id;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│      t_choice.id ASC      │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│   ROCKSDB_TABLE_FULLSCAN  │
│    ────────────────────   │
│      Table: t_choice      │
│                           │
│        Projections:       │
│             id            │
│            val            │
│                           │
│          ~3 rows          │
└───────────────────────────┘


query
SELECT * FROM t_choice ORDER BY id;
----
id	val
1	10
2	20
3	30


onlyif serenedb
statement ok
SET sdb_read_your_own_writes = 1;

statement ok
BEGIN;

statement count 1
INSERT INTO t_choice VALUES (4, 40);

# Point lookup within transaction (RYOW): reads 1 row.
query
SELECT * FROM t_choice WHERE id = 4;
----
id	val
4	40

onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice WHERE id = 4;
----
QUERY PLAN
┌───────────────────────────┐
│  ROCKSDB_PK_POINTS_LOOKUP │
│    ────────────────────   │
│      Table: t_choice      │
│       Filter: (id=4)      │
│                           │
│        Projections:       │
│             id            │
│            val            │
│                           │
│          ~3 rows          │
└───────────────────────────┘

statement ok
ROLLBACK;

onlyif serenedb
statement ok
SET sdb_read_your_own_writes = 0;

statement ok
INSERT INTO t_choice VALUES (10, 10), (20, 20), (30, 30);

onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice WHERE (id < 8 and val >= 20) or (id >= 10 and val < 20);
----
QUERY PLAN
┌───────────────────────────┐
│           FILTER          │
│    ────────────────────   │
│ (((val >= 20) OR (val < 20│
│ )) AND (((id < 8) AND (val│
│   >= 20)) OR ((id >= 10)  │
│      AND (val < 20))))    │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│   ROCKSDB_PK_RANGES_SCAN  │
│    ────────────────────   │
│      Table: t_choice      │
│                           │
│          Filter:          │
│       {id=(-inf, 8)}      │
│      {id=[10, +inf)}      │
│                           │
│        Projections:       │
│             id            │
│            val            │
│                           │
│          ~6 rows          │
└───────────────────────────┘

# --- Compound PK ---

statement ok
CREATE TABLE t_choice_cpk (a INTEGER, b INTEGER, val INTEGER, PRIMARY KEY (a, b));

statement ok
INSERT INTO t_choice_cpk VALUES (1, 2, 10), (3, 4, 20), (5, 6, 30);

# Full PK filter -> 1 specific point -> reads 1 row.
query
SELECT * FROM t_choice_cpk WHERE a = 3 AND b = 4;
----
a	b	val
3	4	20

onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice_cpk WHERE a = 3 AND b = 4;
----
QUERY PLAN
┌───────────────────────────┐
│  ROCKSDB_PK_POINTS_LOOKUP │
│    ────────────────────   │
│    Table: t_choice_cpk    │
│     Filter: (a=3, b=4)    │
│                           │
│        Projections:       │
│             a             │
│             b             │
│            val            │
│                           │
│          ~3 rows          │
└───────────────────────────┘


# Partial PK filter (not a point) -> range scan
onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice_cpk WHERE a = 3 ORDER BY b;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│     t_choice_cpk.b ASC    │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│   ROCKSDB_PK_RANGES_SCAN  │
│    ────────────────────   │
│    Table: t_choice_cpk    │
│       Filter: {a=3}       │
│                           │
│        Projections:       │
│             a             │
│             b             │
│            val            │
│                           │
│          ~3 rows          │
└───────────────────────────┘


# No filter -> full scan
onlyif serenedb
query
EXPLAIN SELECT * FROM t_choice_cpk ORDER BY a;
