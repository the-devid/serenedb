statement ok
DROP TABLE t_between;

# BETWEEN on compound PK: prefix equality + range on next column
statement ok
CREATE TABLE t_between_cpk (a INTEGER, b INTEGER, val INTEGER, PRIMARY KEY (a, b));

statement ok
INSERT INTO t_between_cpk VALUES
  (1, 1, 11), (1, 3, 13), (1, 5, 15), (1, 7, 17),
  (2, 2, 22), (2, 4, 24), (2, 6, 26);

# a = 1 AND b BETWEEN 3 AND 6  ->  range lookup {a=1, b=[3, 6]}  ->  2 rows
query
SELECT * FROM t_between_cpk WHERE a = 1 AND b BETWEEN 3 AND 6 ORDER BY b;
----
a	b	val
1	3	13
1	5	15

onlyif serenedb
query
EXPLAIN SELECT * FROM t_between_cpk WHERE a = 1 AND b BETWEEN 3 AND 6;
