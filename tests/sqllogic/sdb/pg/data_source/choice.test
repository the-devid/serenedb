statement ok
DROP TABLE t_void;

# ── Sweep-line tests: 3-column PK, overlapping/intersecting OR ranges ─────────
# PK = (a, b, c). All columns INTEGER, values 1..3 → 27 rows.
# val = a*100 + b*10 + c for easy identification.
# Goal: verify the sweep produces disjoint ranges so no row is returned twice.

statement ok
CREATE TABLE t_sweep3
  (a INTEGER, b INTEGER, c INTEGER, val INTEGER,
   PRIMARY KEY (a, b, c));

statement ok
INSERT INTO t_sweep3 VALUES
  (1,1,1,111),(1,1,2,112),(1,1,3,113),
  (1,2,1,121),(1,2,2,122),(1,2,3,123),
  (1,3,1,131),(1,3,2,132),(1,3,3,133),
  (2,1,1,211),(2,1,2,212),(2,1,3,213),
  (2,2,1,221),(2,2,2,222),(2,2,3,223),
  (2,3,1,231),(2,3,2,232),(2,3,3,233),
  (3,1,1,311),(3,1,2,312),(3,1,3,313),
  (3,2,1,321),(3,2,2,322),(3,2,3,323),
  (3,3,1,331),(3,3,2,332),(3,3,3,333);


# ── 1-D disjoint ranges (gap between them) ───────────────────────────────────
# a < 2 OR a > 2  →  a=1 (9 rows) + a=3 (9 rows) = 18 rows; a=2 excluded
query
SELECT COUNT(*) FROM t_sweep3 WHERE a < 2 OR a > 2;
----
count
18

