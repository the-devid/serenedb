# =============================================================================
# DML within a transaction (RYOW): point and range lookup see own writes
# =============================================================================

statement ok
CREATE TABLE t_dml_ryow (id INTEGER PRIMARY KEY, val INTEGER);

statement ok
INSERT INTO t_dml_ryow VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50);

onlyif serenedb
statement ok
SET sdb_read_your_own_writes = 1;

statement ok
BEGIN;

# Insert a new row; read it back to verify it is visible within the tx.
statement count 1
INSERT INTO t_dml_ryow VALUES (6, 60);

query
SELECT * FROM t_dml_ryow WHERE id = 6;
----
id	val
6	60

# Update inside tx; verify the new value is visible.
onlyif serenedb
query
EXPLAIN UPDATE t_dml_ryow SET val = 99 WHERE id = 3;
----
QUERY PLAN
┌───────────────────────────┐
│         EXTENSION         │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│         PROJECTION        │
│    ────────────────────   │
│             #0            │
│             #1            │
│             #2            │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│         PROJECTION        │
│    ────────────────────   │
│             99            │
│             id            │
│           rowid           │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│  ROCKSDB_PK_POINTS_LOOKUP │
│    ────────────────────   │
│     Table: t_dml_ryow     │
│       Filter: (id=3)      │
│                           │
│          ~5 rows          │
└───────────────────────────┘


statement count 1
UPDATE t_dml_ryow SET val = 99 WHERE id = 3;

query
SELECT * FROM t_dml_ryow WHERE id = 3;
----
id	val
3	99

# Delete inside tx; verify the row is gone.
onlyif serenedb
query
EXPLAIN DELETE FROM t_dml_ryow WHERE id = 2;
----
QUERY PLAN
┌───────────────────────────┐
│         EXTENSION         │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│  ROCKSDB_PK_POINTS_LOOKUP │
│    ────────────────────   │
│     Table: t_dml_ryow     │
│       Filter: (id=2)      │
│      Projections: id      │
│                           │
│          ~5 rows          │
└───────────────────────────┘


statement count 1
DELETE FROM t_dml_ryow WHERE id = 2;

query
SELECT count(*) FROM t_dml_ryow WHERE id = 2;
----
count
0

# Range scan inside tx sees pre-existing, inserted, and updated rows.
query
SELECT * FROM t_dml_ryow WHERE id >= 4 ORDER BY id;
----
id	val
4	40
5	50
6	60

statement ok
ROLLBACK;

# After rollback all changes are gone.
query
SELECT * FROM t_dml_ryow ORDER BY id;
----
id	val
1	10
2	20
3	30
4	40
5	50

onlyif serenedb
statement ok
SET sdb_read_your_own_writes = 0;

statement ok
DROP TABLE t_dml_ryow;


