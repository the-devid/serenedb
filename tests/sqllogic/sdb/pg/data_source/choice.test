# Complex tests — composite PK: BIGINT, INT, VARCHAR columns.
statement ok
CREATE TABLE t_complex (
  region BIGINT,
  priority INT,
  name VARCHAR,
  score INT,
  PRIMARY KEY (region, priority, name)
);

statement ok
INSERT INTO t_complex VALUES
  (1, 10, 'alice', 100),
  (1, 10, 'bob',   200),
  (1, 20, 'alice', 300),
  (1, 20, 'carol', 400),
  (2, 10, 'alice', 500),
  (2, 30, 'bob',   600),
  (3,  5, 'dave',  700),
  (3, 40, 'eve',   800);

# Equality on all PK columns → point lookup.
query
SELECT * FROM t_complex WHERE region = 1 AND priority = 10 AND name = 'alice';
----
region	priority	name	score
1	10	alice	100

