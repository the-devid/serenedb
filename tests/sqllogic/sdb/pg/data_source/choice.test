# NOT (a != 1 OR b != 2)  ->  De Morgan: a = 1 AND b = 2  ->  point lookup
statement ok
CREATE TABLE t_neq_cpk (a INTEGER, b INTEGER, val INTEGER, PRIMARY KEY (a, b));

statement ok
INSERT INTO t_neq_cpk VALUES (1, 2, 10), (1, 3, 11), (2, 2, 20), (3, 4, 30);

query
SELECT * FROM t_neq_cpk WHERE NOT (a != 1 OR b != 2);
----
a	b	val
1	2	10

