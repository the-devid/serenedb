# =============================================================================
# BETWEEN tests  (a BETWEEN x AND y  ≡  x <= a AND a <= y)
# =============================================================================

statement ok
CREATE TABLE t_between (id INTEGER PRIMARY KEY, val INTEGER);

statement ok
INSERT INTO t_between VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50);

# Basic BETWEEN: id BETWEEN 2 AND 4  ->  range [2, 4]  ->  3 rows
query
SELECT * FROM t_between WHERE id BETWEEN 2 AND 4 ORDER BY id;
----
id	val
2	20
3	30
4	40

onlyif serenedb
query
