debug_checkpoint_abort	NONE	DEBUG SETTING: trigger an abort while checkpointing for testing purposes
debug_checkpoint_sleep_ms	0	DEBUG SETTING: time to sleep before a checkpoint
debug_eviction_queue_sleep_micro_seconds	0	DEBUG SETTING: time for the eviction queue to sleep before acquiring shared ownership of block memory
debug_force_external	off	DEBUG SETTING: force out-of-core computation for operators that support it, used for testing
debug_force_no_cross_product	off	DEBUG SETTING: Force disable cross product generation when hyper graph isn't connected, used for testing
debug_physical_table_scan_execution_strategy	DEFAULT	DEBUG SETTING: force use of given strategy for executing physical table scans
debug_skip_checkpoint_on_commit	off	DEBUG SETTING: skip checkpointing on commit
debug_verify_blocks	off	DEBUG SETTING: verify block metadata during checkpointing
debug_verify_vector	NONE	DEBUG SETTING: enable vector verification
debug_window_mode	WINDOW	DEBUG SETTING: switch window mode to use
default_block_size	262144	The default block size for new duckdb database files (new as-in, they do not yet exist).
default_collation	(empty)	The collation setting used when none is specified
default_null_order	NULLS_LAST	NULL ordering used when none is specified (NULLS_FIRST or NULLS_LAST)
default_order	ASCENDING	The order type used when none is specified (ASC or DESC)
default_secret_storage	local_file	Allows switching the default storage for secrets
default_transaction_isolation	repeatable read	Sets the transaction isolation level of each new transaction.
default_transaction_read_only	off	Sets the default read-only status of new transactions.
deprecated_using_key_syntax	DEFAULT	Configures the use of the deprecated union syntax for USING KEY CTEs.
disable_database_invalidation	on	Disables invalidating the database instance when encountering a fatal error. Should be used with great care, as DuckDB cannot guarantee correct behavior after a fatal error.
disable_parquet_prefetching	off	Disable the prefetching mechanism in Parquet
disable_timestamptz_casts	off	Disable casting from timestamp to timestamptz 
disabled_compression_methods	(empty)	Disable a specific set of compression methods (comma separated)
disabled_filesystems	(empty)	Disable specific file systems preventing access (e.g. LocalFileSystem)
disabled_log_types	(empty)	Sets the list of disabled loggers
disabled_optimizers	(empty)	DEBUG SETTING: disable a specific set of optimizers (comma separated)
duckdb_api	cpp	DuckDB API surface
dynamic_or_filter_threshold	50	The maximum amount of OR filters we generate dynamically from a hash join
enable_curl_server_cert_verification	on	Enable server side certificate verification for CURL backend.
enable_external_access	on	Allow the database to access external state (through e.g. loading/installing modules, COPY TO/FROM, CSV readers, pandas replacement scans, etc)
enable_external_file_cache	on	Allow the database to cache external files (e.g., Parquet) in memory.
enable_fsst_vectors	off	Allow scans on FSST compressed segments to emit compressed vectors to utilize late decompression
enable_geoparquet_conversion	on	Attempt to decode/encode geometry data in/as GeoParquet files if the spatial extension is present.
enable_global_s3_configuration	on	Automatically fetch AWS credentials from environment variables.
enable_http_logging	on	(deprecated) Enables HTTP logging
enable_http_metadata_cache	off	Whether or not the global http metadata is used to cache HTTP metadata
enable_logging	<slt:ignore>	Enables the logger
enable_macro_dependencies	off	Enable created MACROs to create dependencies on the referenced objects (such as tables)
enable_object_cache	off	[PLACEHOLDER] Legacy setting - does nothing
enable_profiling	NULL	Enables profiling, and sets the output format (JSON, QUERY_TREE, QUERY_TREE_OPTIMIZER)
enable_progress_bar	off	Enables the progress bar, printing progress to the terminal for long queries
enable_progress_bar_print	on	Controls the printing of the progress bar, when 'enable_progress_bar' is true
enable_server_cert_verification	off	Enable server side certificate verification.
enable_view_dependencies	off	Enable created VIEWs to create dependencies on the referenced objects (such as tables)
enabled_log_types	<slt:ignore>	Sets the list of enabled loggers
errors_as_json	off	Output error messages as structured JSON instead of as a raw string
experimental_metadata_reuse	on	EXPERIMENTAL: Re-use row group and table metadata when checkpointing.
explain_output	PHYSICAL_ONLY	Output of EXPLAIN statements (ALL, OPTIMIZED_ONLY, PHYSICAL_ONLY)
