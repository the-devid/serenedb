# Non-fast-path body: UNION ALL is rejected at classification. count /
# PHRASE work via iresearch; real-column reads surface the "not yet
# supported" error.
statement ok
CREATE VIEW union_glob AS
  SELECT id, who, what
  FROM read_parquet('s3://${MINIO_BUCKET}/${__DATABASE__}_glob_*.parquet')
  UNION ALL
  SELECT id, who, what
  FROM read_csv('s3://${MINIO_BUCKET}/${__DATABASE__}_glob_*.csv');


statement ok
CREATE INDEX union_glob_idx ON union_glob
  USING inverted(id, who view_s3_en, what view_s3_en) WITH (pk = 'id');


query
SELECT count(*) FROM union_glob_idx WHERE what @@ ts_phrase('deadinside');
----
count
16


statement error
SELECT id, who FROM union_glob_idx WHERE what @@ ts_phrase('deadinside') ORDER BY id;
----
db error: ERROR: materialising real columns from this view-backed inverted index is not yet supported -- view body must be a simple `SELECT * FROM <reader>(literal_args)` over a recognised fast-path source (read_parquet/csv/json/...)


