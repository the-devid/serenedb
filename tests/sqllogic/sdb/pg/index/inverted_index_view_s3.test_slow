# ============================================================================
# JOIN: combine an iresearch-index hit set with the rocksdb seed table by id.
# Verifies the index-entry returns proper row schemas for downstream joins.
# ============================================================================


query
SELECT s.id, s.who, idx.what
FROM   company_src s
JOIN   pq_glob_idx idx ON s.id = idx.id
WHERE  idx.what @@ ts_phrase('sql')
ORDER BY s.id;
----
id	who	what
4	anchin-chan	reads manga all day instead of writing sql deadinside
7	krivda	writes sql at night and closes tickets at dawn deadinside


query
SELECT s.id, s.who, idx.what
FROM   company_src s
JOIN   csv_glob_idx idx ON s.id = idx.id
WHERE  idx.what @@ ts_phrase('mass effect')
ORDER BY s.id;
----
id	who	what
6	gayazov	plays mass effect and skips every stand up deadinside


# ============================================================================
# Larger-row glob: 1000 rows distributed across 3 files via id ranges.
# Exercises per-file dispatch with substantially more groups + row positions.
# ============================================================================


statement ok
CREATE TABLE big_src (id INTEGER PRIMARY KEY, body TEXT);


statement count 1000
INSERT INTO big_src
SELECT i,
       'row '::text || i::text || CASE
         WHEN i % 7 = 0 THEN ' lucky_seven blob'
         WHEN i % 5 = 0 THEN ' midfile fast'
         WHEN i % 3 = 0 THEN ' triplet'
         ELSE ' filler text deadinside'
       END
FROM   generate_series(1, 1000) AS g(i);


statement count 333
COPY (SELECT id, body FROM big_src WHERE id <= 333)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_big_a.parquet' (FORMAT parquet);

statement count 333
COPY (SELECT id, body FROM big_src WHERE id BETWEEN 334 AND 666)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_big_b.parquet' (FORMAT parquet);

statement count 334
COPY (SELECT id, body FROM big_src WHERE id >= 667)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_big_c.parquet' (FORMAT parquet);


statement ok
CREATE VIEW pq_big AS
  SELECT * FROM read_parquet('s3://${MINIO_BUCKET}/${__DATABASE__}_big_*.parquet');


statement ok
CREATE INDEX pq_big_idx ON pq_big USING inverted(id, body view_s3_en);


