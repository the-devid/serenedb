control substitution on

# View-backed inverted index over S3, single-file + glob (parquet, csv,
# json). Set ops / joins / aggregates fall through to the unwired
# generic materialisation path; an example sits at the bottom of the
# JSON-glob block.


statement ok
CREATE OR REPLACE SECRET minio_${__DATABASE__} (
  TYPE s3,
  KEY_ID '${MINIO_ACCESS_KEY}',
  SECRET '${MINIO_SECRET_KEY}',
  ENDPOINT '${MINIO_HOST}:${MINIO_PORT}',
  URL_STYLE 'path',
  USE_SSL false,
  SCOPE 's3://${MINIO_BUCKET}/${__DATABASE__}_'
);


statement ok
SET s3_use_ssl=false;


statement ok
CREATE TEXT SEARCH DICTIONARY view_s3_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


# --- seed: a rocksdb table we'll dump to S3 in multiple files/formats ---


statement ok
CREATE TABLE company_src (id INTEGER PRIMARY KEY, who TEXT, what TEXT);


statement ok
INSERT INTO company_src VALUES
  (1, 'vedernikoff', 'want a lot of money but not want to work deadinside'),
  (2, 'babsky',      'parses csv files in sleep and dreams of parquet deadinside'),
  (3, 'pudge',       'goes mid every game and blames the jungler deadinside'),
  (4, 'anchin-chan', 'reads manga all day instead of writing sql deadinside'),
  (5, 'kostya',      'types on a clickclack keyboard all night long deadinside'),
  (6, 'gayazov',     'plays mass effect and skips every stand up deadinside'),
  (7, 'krivda',      'writes sql at night and closes tickets at dawn deadinside'),
  (8, 'pavelvi',     'pushes to main at 3am and calls it a feature deadinside');


# Three glob shards so per-file dispatch has multiple groups.
statement count 3
COPY (SELECT id, who, what FROM company_src WHERE id <= 3)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_a.parquet' (FORMAT parquet);

statement count 3
COPY (SELECT id, who, what FROM company_src WHERE id BETWEEN 4 AND 6)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_b.parquet' (FORMAT parquet);

statement count 2
COPY (SELECT id, who, what FROM company_src WHERE id >= 7)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_c.parquet' (FORMAT parquet);


# Same content as csv -- byte-offset PK.
statement count 3
COPY (SELECT id, who, what FROM company_src WHERE id <= 3)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_a.csv' (FORMAT csv, HEADER true);

statement count 3
COPY (SELECT id, who, what FROM company_src WHERE id BETWEEN 4 AND 6)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_b.csv' (FORMAT csv, HEADER true);

statement count 2
COPY (SELECT id, who, what FROM company_src WHERE id >= 7)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_c.csv' (FORMAT csv, HEADER true);


# JSON glob (newline-delimited).
statement count 3
COPY (SELECT id, who, what FROM company_src WHERE id <= 3)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_a.jsonl' (FORMAT json);

statement count 3
COPY (SELECT id, who, what FROM company_src WHERE id BETWEEN 4 AND 6)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_b.jsonl' (FORMAT json);

statement count 2
COPY (SELECT id, who, what FROM company_src WHERE id >= 7)
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_glob_c.jsonl' (FORMAT json);


# ============================================================================
# Single-file PARQUET fast path (FileRowNumber)
# ============================================================================


statement count 8
COPY company_src
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_single.parquet' (FORMAT parquet);


statement ok
CREATE VIEW pq_single AS
  SELECT * FROM read_parquet('s3://${MINIO_BUCKET}/${__DATABASE__}_single.parquet');


statement ok
CREATE INDEX pq_single_idx ON pq_single
  USING inverted(id, who view_s3_en, what view_s3_en);


# All 8 source rows present in the index (row count via count(*)).
query
SELECT count(*) FROM pq_single_idx;
----
count
8


# Index-side full scan via the fast-path streams the underlying parquet 1:1.
query
SELECT id, who FROM pq_single_idx ORDER BY id;
----
id	who
1	vedernikoff
2	babsky
3	pudge
4	anchin-chan
5	kostya
6	gayazov
7	krivda
8	pavelvi


# Single-row PHRASE match.
query
SELECT id, who FROM pq_single_idx
WHERE what @@ ts_phrase('mass effect')
ORDER BY id;
----
id	who
6	gayazov


# Phrase common to all rows.
query
SELECT count(*) FROM pq_single_idx WHERE what @@ ts_phrase('deadinside');
----
count
8


# OR across two phrases.
query
SELECT id, who FROM pq_single_idx
WHERE what @@ ts_phrase('at night') OR what @@ ts_phrase('at 3am')
ORDER BY id;
----
id	who
7	krivda
8	pavelvi


# AND across two columns.
query
SELECT id, who FROM pq_single_idx
WHERE who @@ ts_phrase('babsky') AND what @@ ts_phrase('parquet')
ORDER BY id;
----
id	who
2	babsky


# BM25 returns positive scores for matching rows.
query
SELECT id, BM25(pq_single_idx.tableoid) > 0 AS has_score
FROM pq_single_idx
WHERE what @@ ts_phrase('deadinside')
ORDER BY id;
----
id	has_score
1	t
2	t
3	t
4	t
5	t
6	t
7	t
8	t


# top-K via BM25 -- iresearch-side scoring, no source materialisation needed.
query
SELECT id FROM pq_single_idx
WHERE what @@ ts_phrase('sql') OR what @@ ts_phrase('parquet') OR what @@ ts_phrase('mass')
ORDER BY BM25(pq_single_idx.tableoid) DESC, id ASC
LIMIT 3;
----
id
6
2
4


# Cross-check against direct view: same rowset for an equivalent LIKE.
query
SELECT id, who FROM pq_single
WHERE what LIKE '%mass effect%'
ORDER BY id;
----
id	who
6	gayazov


