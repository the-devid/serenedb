id	what
3	goes mid every game and blames the jungler deadinside


# CSV byte-offset PK behaves correctly when the row contains a long string
# (verifies the offset-based lookup, not just leading-row positions).
query
SELECT id, who FROM csv_single_idx
WHERE what @@ ts_phrase('main') AND what @@ ts_phrase('3am')
ORDER BY id;
----
id	who
8	pavelvi


# ============================================================================
# Glob PARQUET fast path (FileIndexPlusRowNumber)
# Three files: a (3 rows, ids 1-3), b (3 rows, ids 4-6), c (2 rows, ids 7-8).
# Per-file dispatch must:
#   1. Decode 16-byte (file_index, file_row_number) PK pairs.
#   2. Group entries by file_index.
#   3. Re-bind read_parquet on each file's single-file path.
#   4. Drive parquet's lookup TF with row_number positions per file.
# ============================================================================


statement ok
CREATE VIEW pq_glob AS
  SELECT * FROM read_parquet('s3://${MINIO_BUCKET}/${__DATABASE__}_glob_*.parquet');


statement ok
CREATE INDEX pq_glob_idx ON pq_glob
  USING inverted(id, who view_s3_en, what view_s3_en);


# Total row count matches the source.
query
SELECT count(*) FROM pq_glob_idx;
----
count
8


# Bare scan via fast-path streams the union 1:1.
query
SELECT id, who FROM pq_glob_idx ORDER BY id;
----
id	who
1	vedernikoff
2	babsky
3	pudge
4	anchin-chan
5	kostya
6	gayazov
7	krivda
8	pavelvi


# Phrase that hits exactly one row in file 'a' (file_index 0).
query
SELECT id, who FROM pq_glob_idx
WHERE what @@ ts_phrase('parquet')
ORDER BY id;
----
id	who
2	babsky


# Phrase that hits exactly one row in file 'b' (file_index 1).
query
SELECT id, who FROM pq_glob_idx
WHERE what @@ ts_phrase('mass effect')
ORDER BY id;
----
id	who
6	gayazov


# Phrase that hits exactly one row in file 'c' (file_index 2).
query
SELECT id, who FROM pq_glob_idx
WHERE what @@ ts_phrase('3am')
ORDER BY id;
----
id	who
8	pavelvi


# Phrase that spans MULTIPLE files (file_index 1 + 2): file 'b' has krivda?
# no -- 'sql' appears in id=4 (file b, anchin-chan) and id=7 (file c, krivda).
# Dispatch must produce two file groups and combine their results in order.
query
SELECT id, who FROM pq_glob_idx
WHERE what @@ ts_phrase('sql')
ORDER BY id;
----
id	who
4	anchin-chan
7	krivda


# Phrase that hits ALL rows -- exercises the full per-file fan-out.
query
SELECT id, who FROM pq_glob_idx
WHERE what @@ ts_phrase('deadinside')
ORDER BY id;
----
id	who
1	vedernikoff
2	babsky
3	pudge
4	anchin-chan
5	kostya
6	gayazov
7	krivda
8	pavelvi


# AND across columns (different files): who in file b, what in file b.
query
SELECT id, who, what FROM pq_glob_idx
WHERE who @@ ts_phrase('kostya') AND what @@ ts_phrase('clickclack')
ORDER BY id;
----
id	who	what
5	kostya	types on a clickclack keyboard all night long deadinside


# OR across files (krivda in file c, anchin-chan in file b).
query
SELECT id, who FROM pq_glob_idx
WHERE who @@ ts_phrase('krivda') OR who @@ ts_phrase('anchin-chan')
ORDER BY id;
----
id	who
4	anchin-chan
7	krivda


# IN-style OR over many ids spanning all three files.
query
SELECT id, who FROM pq_glob_idx
WHERE who @@ ts_phrase('vedernikoff')
   OR who @@ ts_phrase('gayazov')
   OR who @@ ts_phrase('pavelvi')
ORDER BY id;
----
id	who
1	vedernikoff
6	gayazov
8	pavelvi


# BM25 across file boundaries.
query
SELECT id, BM25(pq_glob_idx.tableoid) > 0 AS has_score
FROM pq_glob_idx
WHERE what @@ ts_phrase('deadinside')
ORDER BY id;
----
id	has_score
1	t
2	t
3	t
4	t
5	t
6	t
7	t
8	t


# Phrase with no matches -- empty result, no per-file dispatch should fail.
query
SELECT id FROM pq_glob_idx
WHERE what @@ ts_phrase('nothingmatcheshere');
----
id


# Cross-check against direct view scan.
query
SELECT count(*) FROM pq_glob_idx
WHERE what @@ ts_phrase('sql');
----
count
2


query
SELECT count(*) FROM pq_glob WHERE what LIKE '%sql%';
----
count
2


