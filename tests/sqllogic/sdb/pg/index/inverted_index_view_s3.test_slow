# PHRASE + range filter: the secondary filter (id >= 5) gets pushed into
# get.table_filters by DuckDB's filter pushdown; iresearch_plan reclaims
# it back into the search-scan filter_summary so the materialised hits
# are filtered both ways.
query
SELECT id, who FROM csv_glob_idx
WHERE what @@ ts_phrase('deadinside') AND id >= 5
ORDER BY id;
----
id	who
5	kostya
6	gayazov
7	krivda
8	pavelvi


# PHRASE + IN list: same reclaim path on a different filter shape.
query
SELECT id, who FROM csv_glob_idx
WHERE what @@ ts_phrase('deadinside') AND id IN (1, 4, 7)
ORDER BY id;
----
id	who
1	vedernikoff
4	anchin-chan
7	krivda


