statement count 8
COPY company_src
TO 's3://${MINIO_BUCKET}/${__DATABASE__}_single.csv' (FORMAT csv, HEADER true);


statement ok
CREATE VIEW csv_single AS
  SELECT * FROM read_csv('s3://${MINIO_BUCKET}/${__DATABASE__}_single.csv');


statement ok
CREATE INDEX csv_single_idx ON csv_single
  USING inverted(id, who view_s3_en, what view_s3_en);


query
SELECT count(*) FROM csv_single_idx;
----
count
8


query
SELECT id, who FROM csv_single_idx
WHERE what @@ ts_phrase('mass effect')
ORDER BY id;
----
id	who
6	gayazov


query
SELECT count(*) FROM csv_single_idx WHERE what @@ ts_phrase('deadinside');
