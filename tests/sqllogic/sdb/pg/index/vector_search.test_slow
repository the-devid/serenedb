statement ok
CREATE TABLE vecs (id INT, emb FLOAT[8]);


statement ok
INSERT INTO vecs
SELECT
  s AS id,
  [
    sin(s * 0.001)::FLOAT,
    cos(s * 0.001)::FLOAT,
    sin(s * 0.003)::FLOAT,
    cos(s * 0.003)::FLOAT,
    sin(s * 0.007)::FLOAT,
    cos(s * 0.007)::FLOAT,
    sin(s * 0.013)::FLOAT,
    cos(s * 0.013)::FLOAT
  ]::FLOAT[8] AS emb
FROM generate_series(1, 50000) AS s;


statement ok
CREATE TABLE correct(id INT);


statement ok
INSERT INTO correct SELECT id FROM vecs ORDER BY emb <-> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 512;


statement ok
CREATE TABLE correct_filtered(id INT);


statement ok
INSERT INTO correct_filtered SELECT id FROM vecs WHERE id > 25000 ORDER BY emb <-> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 512;



statement ok
CREATE INDEX vecs_hnsw ON vecs USING inverted(emb hnsw (metric = 'l2', m = 64, ef_construction = 256));


statement ok
VACUUM (UPDATE_INDEXES) vecs;


query
EXPLAIN SELECT id FROM vecs_hnsw ORDER BY emb <-> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 10;
----
QUERY PLAN
┌───────────────────────────┐
│     IRESEARCH_ANN_SCAN    │
│    ────────────────────   │
│      Index: vecs_hnsw     │
│      Lookup: rocksdb      │
│          TopK: 10         │
│          Dims: 8          │
│      Projections: id      │
│                           │
│        ~50,000 rows       │
└───────────────────────────┘


statement ok
SET sdb_ef_search TO 512;

query
WITH
  result AS (SELECT id FROM vecs_hnsw ORDER BY emb <-> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 512)
SELECT COUNT(*)::FLOAT / 512 > 0.9 FROM correct WHERE id IN (SELECT id FROM result);
----
?column?
t



query
EXPLAIN SELECT id FROM vecs_hnsw WHERE id > 25000 ORDER BY emb <-> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 10;
----
QUERY PLAN
┌───────────────────────────┐
│     IRESEARCH_ANN_SCAN    │
│    ────────────────────   │
│      Index: vecs_hnsw     │
│      Lookup: rocksdb      │
│          TopK: 10         │
│          Dims: 8          │
│    Filter: (#0 > 25000)   │
│      Projections: id      │
│                           │
│        ~50,000 rows       │
└───────────────────────────┘


# Since filter demands larger efSearch
statement ok
SET sdb_ef_search TO 2048;

query
WITH
  result AS (SELECT id FROM vecs_hnsw WHERE id > 25000 ORDER BY emb <-> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 512)
SELECT COUNT(*)::FLOAT / 512 > 0.9 FROM correct_filtered WHERE id IN (SELECT id FROM result);
----
?column?
t


statement ok
SET sdb_ef_search TO 512;

# L1 recall

statement ok
CREATE TABLE correct_l1(id INT);


statement ok
INSERT INTO correct_l1 SELECT id FROM vecs ORDER BY emb <+> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 512;


statement ok
CREATE INDEX vecs_hnsw_l1 ON vecs USING inverted(id, emb hnsw (metric = 'l1', m = 64, ef_construction = 256));


statement ok
VACUUM (UPDATE_INDEXES) vecs;


query
WITH
  result AS (SELECT id FROM vecs_hnsw_l1 ORDER BY emb <+> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 512)
SELECT COUNT(*)::FLOAT / 512 > 0.9 FROM correct_l1 WHERE id IN (SELECT id FROM result);
----
?column?
t


# Cosine recall

statement ok
CREATE TABLE correct_cos(id INT);


statement ok
CREATE TABLE correct_cos2(id INT);


statement ok
INSERT INTO correct_cos SELECT id FROM vecs ORDER BY emb <=> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 512;


statement ok
INSERT INTO correct_cos2 SELECT id FROM vecs ORDER BY cosine_similarity(emb, [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8]) DESC LIMIT 512;


statement ok
CREATE INDEX vecs_hnsw_cos ON vecs USING inverted(id, emb hnsw (metric = 'cosine', m = 64, ef_construction = 256));


statement ok
VACUUM (UPDATE_INDEXES) vecs;


query
WITH
  result AS (SELECT id FROM vecs_hnsw_cos ORDER BY emb <=> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 512)
SELECT COUNT(*)::FLOAT / 512 > 0.9 FROM correct_cos WHERE id IN (SELECT id FROM result);
----
?column?
t


