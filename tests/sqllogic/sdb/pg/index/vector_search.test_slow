statement ok
VACUUM (UPDATE_INDEXES) vecs;


query
WITH
  result AS (SELECT id FROM vecs_hnsw_ip ORDER BY emb <#> [0.0, 1.0, 0.0, 1.0, 0.0, 1.0, 0.0, 1.0]::FLOAT[8] LIMIT 512)
SELECT COUNT(*)::FLOAT / 512 > 0.9 FROM correct_ip WHERE id IN (SELECT id FROM result);
