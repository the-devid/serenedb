  pk INTEGER PRIMARY KEY,
  t VARCHAR,
  v STRUCT(
    header STRUCT(name VARCHAR, version INTEGER),
    payload STRUCT(key VARCHAR, items INTEGER[2])[]
  )
)


skipif pg-wire-extended
statement ok
CREATE INDEX n5_idx ON n5 USING inverted(pk, t en) INCLUDE (v)


skipif pg-wire-extended
statement ok
