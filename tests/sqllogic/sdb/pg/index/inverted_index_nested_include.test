pk	v
1	("(hdr1,1)","{""(k1,\\\\""{10,20}\\\\"")"",""(k2,\\\\""{30,40}\\\\"")""}")
2	NULL
3	("(,3)",{})
4	(,"{""(only,\\\\""{99,100}\\\\"")""}")
5	("(h5,)","{""(,\\\\""{7,8}\\\\"")"",""(z,)""}")


# --- 6. LIST<ARRAY<STRUCT<f FLOAT,
#                          a INTEGER[2],
#                          l LIST<STRUCT<x INTEGER, y INTEGER>>>, 2>> -----

skipif pg-wire-extended
statement ok
CREATE TABLE n6 (
  pk INTEGER PRIMARY KEY,
  t VARCHAR,
  v STRUCT(
    f FLOAT,
    a INTEGER[2],
    l STRUCT(x INTEGER, y INTEGER)[]
  )[2][]
)


skipif pg-wire-extended
statement ok
CREATE INDEX n6_idx ON n6 USING inverted(pk, t en) INCLUDE (v)


skipif pg-wire-extended
statement ok
INSERT INTO n6 VALUES (1, 'one', [
  [ROW(1.5, [10,20], [ROW(100,200), ROW(300,400)]), ROW(2.5, [30,40], [])],
  [ROW(NULL, [50,60], [ROW(NULL, 700)]),            ROW(4.5, NULL, NULL)]
])


skipif pg-wire-extended
statement ok
INSERT INTO n6 VALUES (2, 'two',   NULL)


skipif pg-wire-extended
statement ok
INSERT INTO n6 VALUES (3, 'three', [])


skipif pg-wire-extended
statement ok
INSERT INTO n6 VALUES (4, 'four',  [
  [NULL, ROW(9.0, [1,2], [])]
])


skipif pg-wire-extended
statement ok
VACUUM (UPDATE_INDEXES) n6


