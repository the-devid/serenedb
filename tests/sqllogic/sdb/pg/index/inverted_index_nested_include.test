skipif pg-wire-extended
query
SELECT pk, v FROM n4_idx
WHERE t @@ ts_phrase('one') OR t @@ ts_phrase('two')
   OR t @@ ts_phrase('three') OR t @@ ts_phrase('four')
ORDER BY pk;
----
pk	v
1	{"(k,\\"(7,\\"\\"{a,b}\\"\\")\\")","(m,\\"(,)\\")"}
2	NULL
3	{}
4	{"(p,)"}


# --- 5. STRUCT<STRUCT<...>, LIST<STRUCT<VARCHAR, INTEGER[2]>>> ----------

skipif pg-wire-extended
statement ok
