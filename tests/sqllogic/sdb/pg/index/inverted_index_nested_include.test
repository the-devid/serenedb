1	{{"(1.5,\\"{10,20}\\",\\"{\\"\\"(100,200)\\"\\",\\"\\"(300,400)\\"\\"}\\")","(2.5,\\"{30,40}\\",{})"},{"(,\\"{50,60}\\",\\"{\\"\\"(,700)\\"\\"}\\")","(4.5,,)"}}
