skipif pg-wire-extended
statement ok
INSERT INTO n5 VALUES (2, 'two',   NULL)


skipif pg-wire-extended
statement ok
INSERT INTO n5 VALUES (3, 'three', ROW(ROW(NULL, 3), []))


skipif pg-wire-extended
statement ok
INSERT INTO n5 VALUES (4, 'four',  ROW(NULL, [ROW('only', [99,100])]))


skipif pg-wire-extended
statement ok
INSERT INTO n5 VALUES (5, 'five',  ROW(ROW('h5', NULL), [ROW(NULL, [7,8]), ROW('z', NULL)]))


skipif pg-wire-extended
statement ok
VACUUM (UPDATE_INDEXES) n5


