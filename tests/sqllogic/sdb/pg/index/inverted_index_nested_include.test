  t VARCHAR,
  v STRUCT(a INTEGER, b DOUBLE[], c FLOAT[3])
)


skipif pg-wire-extended
statement ok
CREATE INDEX n3_idx ON n3 USING inverted(pk, t en) INCLUDE (v)


skipif pg-wire-extended
statement ok
