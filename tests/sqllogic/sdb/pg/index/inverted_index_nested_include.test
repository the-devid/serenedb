hash-threshold 100

# End-to-end: deeply-nested INCLUDE'd columns round-trip through the new cs.
# Each section exercises a different composition shape:
#   1. LIST<ARRAY<INTEGER,2>>
#   2. ARRAY<LIST<VARCHAR>,2>
#   3. STRUCT<INTEGER, LIST<DOUBLE>, ARRAY<FLOAT,3>>
#   4. MAP<VARCHAR, STRUCT<INTEGER, LIST<VARCHAR>>>
#   5. STRUCT<STRUCT<...>, LIST<STRUCT<VARCHAR, ARRAY<INTEGER,2>>>>
#   6. LIST<ARRAY<STRUCT<FLOAT, ARRAY<INTEGER,2>,
#                       LIST<STRUCT<INTEGER, INTEGER>>>, 2>>
# Every read goes through the iresearch index path -- the leading EXPLAIN
# per section asserts the nested column is served by the columnstore
# (annotated `(i)`), pk falls through to the rocksdb lookup `(l)`.

statement ok
CREATE TEXT SEARCH DICTIONARY en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
)


# --- 1. LIST<ARRAY<INTEGER,2>> ------------------------------------------

statement ok
CREATE TABLE n1 (pk INTEGER PRIMARY KEY, t VARCHAR, v INTEGER[2][])


statement ok
CREATE INDEX n1_idx ON n1 USING inverted(pk, t en) INCLUDE (v)


statement ok
INSERT INTO n1 VALUES (1, 'one',   [[1,2],[3,4]])


statement ok
INSERT INTO n1 VALUES (2, 'two',   NULL)


statement ok
INSERT INTO n1 VALUES (3, 'three', [[7,8],[9,10],[11,12]])


statement ok
INSERT INTO n1 VALUES (4, 'four',  [])


statement ok
VACUUM (UPDATE_INDEXES) n1


query
EXPLAIN SELECT pk, v FROM n1_idx WHERE t @@ ts_phrase('one');
----
QUERY PLAN
┌───────────────────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│       Index: n1_idx       │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│  AND[PHRASE[t(string) =   │
│    <Term:one(0, 0); >]]   │
│                           │
│        Projections:       │
│           pk (l)          │
│           v (i)           │
│                           │
│          ~4 rows          │
└───────────────────────────┘


query
SELECT pk, v FROM n1_idx
WHERE t @@ ts_phrase('one') OR t @@ ts_phrase('two')
   OR t @@ ts_phrase('three') OR t @@ ts_phrase('four')
ORDER BY pk;
----
pk	v
1	{{1,2},{3,4}}
2	NULL
3	{{7,8},{9,10},{11,12}}
4	{}


# --- 2. ARRAY<LIST<VARCHAR>,2> ------------------------------------------

skipif pg-wire-extended
statement ok
