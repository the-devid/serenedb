CREATE TABLE t (id INT, emb FLOAT[3]);


statement ok
CREATE INDEX l2_index ON t USING inverted(id, emb hnsw);


statement ok
INSERT INTO t VALUES (1, [100, 0, 0]::FLOAT[3]), (2, [50, 50, 50]::FLOAT[3]), (3, [50, 25, 50]::FLOAT[3]), (4, [50, 50, 100]::FLOAT[3]);


query
EXPLAIN SELECT id FROM l2_index ORDER BY emb <-> [0.0, 0.0, 0.0]::FLOAT[3] LIMIT 2;
----
QUERY PLAN
┌───────────────────────────┐
│     IRESEARCH_ANN_SCAN    │
│    ────────────────────   │
│      Index: l2_index      │
│      Lookup: rocksdb      │
│          TopK: 2          │
│          Dims: 3          │
│      Projections: id      │
│                           │
│          ~4 rows          │
└───────────────────────────┘


