# ---- EXPLAIN with LIMIT: strategy should flip to iresearch_score_topk_scan ----
# When the query has ORDER BY BM25() DESC + LIMIT k, the optimizer rule
# TryAttachScoreTopK pulls the limit into SearchScan.score_top_k. This changes
# the scan function name and adds a "TopK: k" line to the EXPLAIN box.

query
EXPLAIN SELECT id FROM docs_topk_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_topk_idx.tableoid) DESC LIMIT 3;
----
QUERY PLAN
┌───────────────────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│        Table: docs        │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│ AND[PHRASE[body(string) = │
│    <Term:fox(0, 0); >]]   │
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│          TopK: 3          │
│      Projections: id      │
│                           │
│          ~5 rows          │
└───────────────────────────┘


# ---- EXPLAIN: UNION ALL of two topk branches ----
# Each branch independently qualifies for TryAttachScoreTopK; both scans
# should show Strategy=iresearch_score_topk_scan with TopK=3.

query
EXPLAIN (SELECT id, BM25(docs_topk_idx.tableoid) > 0 AS has_score FROM docs_topk_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_topk_idx.tableoid) DESC LIMIT 3)
UNION ALL
(SELECT id, BM25(docs_topk_idx.tableoid) > 0 AS has_score FROM docs_topk_idx WHERE body @@ ts_phrase('lazy') ORDER BY BM25(docs_topk_idx.tableoid) DESC LIMIT 3)
ORDER BY id;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│           id ASC          │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│           UNION           ├──────────────┐
└─────────────┬─────────────┘              │
┌─────────────┴─────────────┐┌─────────────┴─────────────┐
│         PROJECTION        ││         PROJECTION        │
│    ────────────────────   ││    ────────────────────   │
│             id            ││             id            │
│         has_score         ││         has_score         │
│                           ││                           │
│           ~1 row          ││           ~1 row          │
└─────────────┬─────────────┘└─────────────┬─────────────┘
┌─────────────┴─────────────┐┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      ││       IRESEARCH_SCAN      │
│    ────────────────────   ││    ────────────────────   │
│        Table: docs        ││        Table: docs        │
│      Lookup: rocksdb      ││      Lookup: rocksdb      │
│                           ││                           │
│          Filter:          ││          Filter:          │
│ AND[PHRASE[body(string) = ││ AND[PHRASE[body(string) = │
│    <Term:fox(0, 0); >]]   ││   <Term:lazy(0, 0); >]]   │
│                           ││                           │
│           Score:          ││           Score:          │
│    bm25(k1=1.2, b=0.75)   ││    bm25(k1=1.2, b=0.75)   │
│                           ││                           │
│          TopK: 3          ││          TopK: 3          │
│                           ││                           │
│        Projections:       ││        Projections:       │
│             id            ││             id            │
│  sdb_inverted_index_score ││  sdb_inverted_index_score │
│                           ││                           │
│          ~5 rows          ││          ~5 rows          │
└───────────────────────────┘└───────────────────────────┘


# ---- EXPLAIN: topk inside a subquery, outer query has a different ORDER BY ----
# The inner TopN matches the drop shape (its ORDER BY resolves to the score
# column); the outer ORDER BY id is unaffected. Only one topk_scan.

query
EXPLAIN SELECT id, score FROM (
  SELECT id, BM25(docs_topk_idx.tableoid) AS score FROM docs_topk_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_topk_idx.tableoid) DESC LIMIT 3
) sub ORDER BY id;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│         sub.id ASC        │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│        Table: docs        │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│ AND[PHRASE[body(string) = │
│    <Term:fox(0, 0); >]]   │
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│          TopK: 3          │
│                           │
│        Projections:       │
│             id            │
│  sdb_inverted_index_score │
│                           │
│          ~5 rows          │
└───────────────────────────┘


# ---- Correctness tests: topk results match full scan + sort + limit ----

# First get the expected results without topk (full scan path).
# Length-normalized BM25 ranks shorter docs higher: id=2 (3t) > 4 (4t) > 5 (7t) > 1 (9t).
query
SELECT id FROM docs_topk_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_topk_idx.tableoid) DESC, id LIMIT 3;
----
