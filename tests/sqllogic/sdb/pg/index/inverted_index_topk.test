hash-threshold 100

statement ok
CREATE TABLE docs (id INTEGER PRIMARY KEY, body VARCHAR);


statement ok
INSERT INTO docs VALUES (1, 'the quick brown fox jumps over the lazy dog');


statement count 1
INSERT INTO docs VALUES (2, 'the quick fox');


statement count 1
INSERT INTO docs VALUES (3, 'the lazy dog');


statement count 1
INSERT INTO docs VALUES (4, 'the fox runs fast');


statement count 1
INSERT INTO docs VALUES (5, 'a quick brown rabbit and a fox');


statement ok
CREATE TEXT SEARCH DICTIONARY en_topk(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


statement ok
CREATE INDEX docs_topk_idx ON docs USING inverted(id, body en_topk);


statement ok
VACUUM (UPDATE_INDEXES) docs;


query
EXPLAIN SELECT id FROM docs_topk_idx WHERE body @@ ts_phrase('fox') ORDER BY BM25(docs_topk_idx.tableoid) ASC LIMIT 5;
----
QUERY PLAN
┌───────────────────────────┐
│         PROJECTION        │
│    ────────────────────   │
│             #0            │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│           TOP_N           │
│    ────────────────────   │
│           Top: 5          │
│      Order By: #1 ASC     │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│        Table: docs        │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│ AND[PHRASE[body(string) = │
│    <Term:fox(0, 0); >]]   │
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│        Projections:       │
│             id            │
│  sdb_inverted_index_score │
│                           │
│          ~5 rows          │
└───────────────────────────┘


