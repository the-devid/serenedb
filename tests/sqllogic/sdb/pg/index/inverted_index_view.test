hash-threshold 100

# View-backed inverted index queries that don't require materialisation:
# count(*), count(1), BM25/TFIDF score, offsets, tableoid all flow from the
# iresearch index without touching the source.
#
# Materialisation (selecting real source columns through the index entry) is
# wired in a follow-up; today such queries surface a "not yet supported"
# error.

statement count 3
COPY (SELECT 1 AS id, 'pudge goes mid' AS body
      UNION ALL SELECT 2, 'anchin reads manga'
      UNION ALL SELECT 3, 'pudge plays again')
TO '/tmp/${__DATABASE__}_view_idx.parquet' (FORMAT PARQUET);

statement ok
CREATE TEXT SEARCH DICTIONARY view_idx_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE VIEW pq_v AS SELECT * FROM read_parquet('/tmp/${__DATABASE__}_view_idx.parquet');

# CREATE INDEX on a view over read_parquet auto-detects file_row_number as
# PK (fast-path); no WITH (pk = ...) needed.
statement ok
CREATE INDEX pq_idx ON pq_v USING inverted(id, body view_idx_en);

# count(*) over a view-backed inverted index goes through IRESEARCH_COUNT --
# no materialisation, just iresearch doc-id counting.
query
SELECT count(*) FROM pq_idx WHERE body @@ ts_phrase('pudge');
----
count
2

query
SELECT count(1) FROM pq_idx WHERE body @@ ts_phrase('pudge');
----
count
2

# BM25 score is emitted by iresearch directly (virtual column).
query
SELECT BM25(pq_idx.tableoid) > 0 AS has_score FROM pq_idx WHERE body @@ ts_phrase('pudge') ORDER BY BM25(pq_idx.tableoid) DESC LIMIT 1;
----
has_score
t

# Selecting a real view column flows through ViewFileIndexSource: the
# scan op gets PK bytes from iresearch, sorts/decodes them to int64
# file_row_number, and pushes the lookup down through MakeFastPathLookupFunction.
query
SELECT id, body FROM pq_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id	body
1	pudge goes mid
3	pudge plays again


# Generic-view case: view body is a UNION ALL of inline VALUES -- no leaf
# relation to fast-path. The view body has no auto-detectable PK and no
# specialised lookup TF; only the generic full-scan + hash-join path can
# materialise. Today no-materialisation queries still work.

statement ok
CREATE VIEW union_v AS
  SELECT 1 AS id, 'pudge goes mid' AS body
  UNION ALL SELECT 2, 'anchin reads manga'
  UNION ALL SELECT 3, 'pudge plays again';

statement ok
CREATE INDEX union_idx ON union_v USING inverted(id, body view_idx_en) WITH (pk = 'id');

query
SELECT count(*) FROM union_idx WHERE body @@ ts_phrase('pudge');
----
count
2

query
SELECT count(1) FROM union_idx WHERE body @@ ts_phrase('pudge');
----
count
2

query
SELECT BM25(union_idx.tableoid) > 0 AS has_score FROM union_idx WHERE body @@ ts_phrase('pudge') ORDER BY BM25(union_idx.tableoid) DESC LIMIT 1;
----
has_score
t

# UNION ALL view body has no fast-path source, so real-column reads fall
# back to the generic materialisation path -- not yet wired.
statement error
SELECT id FROM union_idx WHERE body @@ ts_phrase('pudge');
----
db error: ERROR: materialising real columns from this view-backed inverted index is not yet supported -- view body must be a simple `SELECT * FROM <reader>(literal_args)` over a recognised fast-path source (read_parquet/csv/json/...)


# View over a serenedb rocksdb table -- static, no DML refresh.

statement ok
CREATE TABLE base_t (id INTEGER PRIMARY KEY, body TEXT, extra TEXT);

statement ok
INSERT INTO base_t VALUES
  (1, 'pudge goes mid', 'a'),
  (2, 'anchin reads manga', 'b'),
  (3, 'pudge plays again', 'c');

statement ok
CREATE VIEW v_star AS SELECT * FROM base_t;

statement ok
CREATE INDEX i_star ON v_star USING inverted(body view_idx_en);

query
SELECT count(*) FROM i_star WHERE body @@ ts_phrase('pudge');
----
count
2

query
SELECT id, body, extra FROM i_star WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id	body	extra
1	pudge goes mid	a
3	pudge plays again	c

# Reordered projection.
statement ok
CREATE VIEW v_proj AS SELECT body, id FROM base_t;

statement ok
CREATE INDEX i_proj ON v_proj USING inverted(body view_idx_en);

query
SELECT count(*) FROM i_proj WHERE body @@ ts_phrase('pudge');
----
count
2

query
SELECT id, body FROM i_proj WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id	body
1	pudge goes mid
3	pudge plays again

query
SELECT body FROM i_proj WHERE body @@ ts_phrase('pudge') ORDER BY body;
----
body
pudge goes mid
pudge plays again


# Cast (id INTEGER -> id_b BIGINT). Search-filter builder peels cast so
# PHRASE binds through it.
statement ok
CREATE VIEW v_cast AS SELECT id::BIGINT AS id_b, body FROM base_t;

statement ok
CREATE INDEX i_cast ON v_cast USING inverted(body view_idx_en);

query
SELECT count(*) FROM i_cast WHERE body @@ ts_phrase('pudge');
----
count
2

query
SELECT id_b, body FROM i_cast WHERE body @@ ts_phrase('pudge') ORDER BY id_b;
----
id_b	body
1	pudge goes mid
3	pudge plays again


# No-PK base table -- PK source is the hidden rowid.
statement ok
CREATE TABLE base_nopk (body TEXT, extra TEXT);

statement ok
INSERT INTO base_nopk VALUES
  ('pudge goes mid', 'a'),
  ('anchin reads manga', 'b'),
  ('pudge plays again', 'c');

statement ok
CREATE VIEW v_nopk AS SELECT * FROM base_nopk;

statement ok
CREATE INDEX i_nopk ON v_nopk USING inverted(body view_idx_en);

query
SELECT count(*) FROM i_nopk WHERE body @@ ts_phrase('pudge');
----
count
2

query
SELECT body, extra FROM i_nopk WHERE body @@ ts_phrase('pudge') ORDER BY body;
----
body	extra
pudge goes mid	a
pudge plays again	c


# Parquet glob.
statement count 2
COPY (SELECT 1 AS id, 'pudge goes mid' AS body
      UNION ALL SELECT 2, 'anchin reads manga')
TO '/tmp/${__DATABASE__}_glob_a.parquet' (FORMAT PARQUET);

statement count 2
COPY (SELECT 3 AS id, 'pudge plays again' AS body
      UNION ALL SELECT 4, 'krivda writes sql')
TO '/tmp/${__DATABASE__}_glob_b.parquet' (FORMAT PARQUET);

statement ok
CREATE VIEW pq_glob AS
  SELECT * FROM read_parquet('/tmp/${__DATABASE__}_glob_*.parquet');

statement ok
CREATE INDEX pq_glob_idx ON pq_glob USING inverted(id, body view_idx_en);

query
SELECT count(*) FROM pq_glob_idx WHERE body @@ ts_phrase('pudge');
----
count
2

query
SELECT BM25(pq_glob_idx.tableoid) > 0 AS has_score FROM pq_glob_idx WHERE body @@ ts_phrase('pudge') ORDER BY BM25(pq_glob_idx.tableoid) DESC LIMIT 1;
----
has_score
t

query
SELECT id, body FROM pq_glob_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id	body
1	pudge goes mid
3	pudge plays again


