# Multi-row-group parquet -- the lookup TF prunes row groups by sorted
# pk_lookups; this exercises hits landing in a non-leading group.
statement count 6
COPY (SELECT 100 AS id, 'one alpha' AS body
      UNION ALL SELECT 101, 'two beta'
      UNION ALL SELECT 102, 'three gamma'
      UNION ALL SELECT 103, 'four delta'
      UNION ALL SELECT 104, 'pudge appears late'
      UNION ALL SELECT 105, 'six epsilon')
TO '/tmp/${__DATABASE__}_multi_rg.parquet' (FORMAT PARQUET, ROW_GROUP_SIZE 2);

statement ok
CREATE VIEW pq_multi_rg AS SELECT * FROM read_parquet('/tmp/${__DATABASE__}_multi_rg.parquet');

statement ok
CREATE INDEX pq_multi_rg_idx ON pq_multi_rg USING inverted(id, body view_idx_en);

# With ROW_GROUP_SIZE=2 the file has 3 groups; hit is in group 2.
query
SELECT id, body FROM pq_multi_rg_idx WHERE body @@ ts_phrase('pudge');
----
id	body
104	pudge appears late


# TopK by BM25 + real-column projection. Designed so iresearch returns
# pks in score-DESC order that DOES NOT match pk-ascending order (doc
# with pk=2 has TF=4, ranks above pk=0 with TF=1). The materializer
# sorts internally for parquet row-group skipping but must permute the
# result back to the caller-positional score/rowid arrays' order.
statement count 3
COPY (SELECT 1 AS id, 'foo' AS body
      UNION ALL SELECT 2, 'bar baz'
      UNION ALL SELECT 3, 'foo foo foo foo')
TO '/tmp/${__DATABASE__}_topk.parquet' (FORMAT PARQUET);

statement ok
CREATE VIEW topk_v AS SELECT * FROM read_parquet('/tmp/${__DATABASE__}_topk.parquet');

statement ok
CREATE INDEX topk_idx ON topk_v USING inverted(id, body view_idx_en);

query
SELECT id, body
FROM topk_idx
WHERE body @@ ts_phrase('foo')
ORDER BY BM25(topk_idx.tableoid) DESC
LIMIT 2;
----
id	body
3	foo foo foo foo
1	foo


# Bare `SELECT * FROM idx;` -- must walk the iresearch index and
# materialize, NOT fall back to a PK rocksdb scan. Covers all view-backed
# pk_specs to confirm the bare-scan path uses the index everywhere.

statement ok
CREATE VIEW bare_pq_v AS SELECT * FROM read_parquet('/tmp/${__DATABASE__}_view_idx.parquet');

statement ok
CREATE INDEX bare_pq_idx ON bare_pq_v USING inverted(id, body view_idx_en);

query
SELECT id, body FROM bare_pq_idx ORDER BY id;
----
id	body
1	pudge goes mid
2	anchin reads manga
3	pudge plays again

statement count 4
COPY (SELECT 10 AS id, 'one' AS body
      UNION ALL SELECT 11, 'two'
      UNION ALL SELECT 12, 'three'
      UNION ALL SELECT 13, 'four')
TO '/tmp/${__DATABASE__}_bare.csv';

statement ok
CREATE VIEW bare_csv_v AS SELECT * FROM read_csv('/tmp/${__DATABASE__}_bare.csv');

statement ok
CREATE INDEX bare_csv_idx ON bare_csv_v USING inverted(id, body view_idx_en);

query
SELECT id, body FROM bare_csv_idx ORDER BY id;
----
id	body
10	one
11	two
12	three
13	four


