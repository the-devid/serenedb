hash-threshold 100

statement ok
CREATE TEXT SEARCH DICTIONARY en_norm(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


statement ok
CREATE TABLE sparse_norm (id INTEGER PRIMARY KEY, content JSON);


statement ok
CREATE INDEX sparse_norm_idx ON sparse_norm
    USING inverted(id, (content->>'body') en_norm);


statement count 1
INSERT INTO sparse_norm VALUES (1, '{"body":"t"}'::json);


