statement ok
VACUUM (UPDATE_INDEXES) sparse_norm;


query
SELECT id FROM sparse_norm_idx
WHERE content->>'body' @@ ts_phrase('t') ORDER BY id;
----
id
1
3
4


query
SELECT id, BM25(sparse_norm_idx.tableoid) > 0 AS has_score
FROM sparse_norm_idx
WHERE content->>'body' @@ ts_phrase('t')
ORDER BY id;
----
id	has_score
1	t
3	t
4	t


query
SELECT id FROM sparse_norm_idx
WHERE content->>'body' @@ ts_phrase('t')
ORDER BY BM25(sparse_norm_idx.tableoid) DESC, id;
----
id
1
3
4


query
SELECT id FROM sparse_norm_idx
WHERE content->>'body' @@ ts_phrase('t')
ORDER BY TFIDF(sparse_norm_idx.tableoid, true) DESC, id;
----
id
1
3
4


