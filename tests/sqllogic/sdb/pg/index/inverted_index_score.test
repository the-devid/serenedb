# Union tree: each branch is itself a UNION (((fox UNION lazy) UNION ALL (fox UNION lazy)))
query
(
  (SELECT id, BM25() AS score FROM docs_idx WHERE PHRASE(body, 'fox') LIMIT 2)
  UNION ALL
  (SELECT id, BM25() AS score FROM docs_idx WHERE PHRASE(body, 'lazy') LIMIT 2)
)
UNION ALL
(
  (SELECT id, BM25() AS score FROM docs_idx WHERE PHRASE(body, 'fox') LIMIT 2)
  UNION ALL
  (SELECT id, BM25() AS score FROM docs_idx WHERE PHRASE(body, 'lazy') LIMIT 2)
)
ORDER BY id LIMIT 6;
