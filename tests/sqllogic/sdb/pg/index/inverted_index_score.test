# EXPLAIN for join two inverted indexes with scorer scoped inside subquery
query
EXPLAIN (EXECUTION) SELECT a.id, a.score > 0 AS has_score FROM
  (SELECT id, BM25() AS score FROM docs_idx WHERE PHRASE(body, 'fox')) a
  JOIN
  (SELECT id FROM docs2_idx WHERE PHRASE(body, 'fox')) b
  ON a.id = b.id
ORDER BY a.id;
