# ORDER BY BM25() with >32 results exercises the full-block ScoreBlock path
query
SELECT id, BM25() > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id LIMIT 3;
----
id	has_score
1	t
2	t
4	t


# BM25() can appear multiple times in the same query (SELECT + ORDER BY)
query
SELECT id, BM25() > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25() DESC LIMIT 3;
----
id	has_score
4	t
2	t
1	t


# BM25() in SELECT, WHERE, and ORDER BY simultaneously
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') AND BM25() > 0 ORDER BY BM25() DESC LIMIT 3;
----
id
4
2
1


# BM25() with same explicit params used twice is allowed
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') AND BM25(1.2, 0.75) > 0 ORDER BY BM25(1.2, 0.75) DESC LIMIT 3;
----
id
4
2
1


# Error: BM25() and BM25() with different params conflict
query error
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25(1.2, 0.75) DESC, BM25(1.0, 0.5) DESC LIMIT 3;
----
db error: ERROR: Only one scorer function is allowed per inverted index
HINT: Use UNION to combine different score functions for same inverted index


# Error: BM25 and TFIDF in the same query conflict
query error
SELECT id, BM25() FROM docs_idx WHERE PHRASE(body, 'fox') AND TFIDF() > 0 LIMIT 3;
----
db error: ERROR: Only one scorer function is allowed per inverted index
HINT: Use UNION to combine different score functions for same inverted index


# UNION ALL: same scorer in each branch — each branch is an independent scoring scope
query
(SELECT id, BM25() AS score FROM docs_idx WHERE PHRASE(body, 'fox') LIMIT 3)
UNION ALL
(SELECT id, BM25() AS score FROM docs_idx WHERE PHRASE(body, 'lazy') LIMIT 3)
ORDER BY id;
----
id	score
1	0.05305543
1	3.1416833
2	0.05305543
3	3.1416833
4	0.05305543
35	3.1416833


# UNION ALL: different scorer types per branch (BM25 vs TFIDF) — each branch is independent
query
(SELECT id, BM25() AS score FROM docs_idx WHERE PHRASE(body, 'fox') LIMIT 2)
UNION ALL
(SELECT id, TFIDF() AS score FROM docs_idx WHERE PHRASE(body, 'lazy') LIMIT 2)
ORDER BY id;
----
id	score
1	0.7065702
1	2.3513753
2	0.7065702
3	2.3513753


# Subquery: BM25() inside subquery, outer references the alias
query
SELECT id, score FROM (
  SELECT id, BM25() AS score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25() DESC LIMIT 3
) sub ORDER BY id;
----
id	score
1	0.05305543
2	0.05305543
4	0.05305543

