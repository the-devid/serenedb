hash-threshold 100

statement ok
CREATE TABLE docs (id INTEGER PRIMARY KEY, body VARCHAR);


statement ok
INSERT INTO docs VALUES (1, 'the quick brown fox jumps over the lazy dog');


statement count 1
INSERT INTO docs VALUES (2, 'the quick fox');


statement count 1
INSERT INTO docs VALUES (3, 'the lazy dog');


statement ok
CREATE TEXT SEARCH DICTIONARY en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


statement ok
CREATE INDEX docs_idx ON docs USING inverted(id, body en);


statement ok
VACUUM (UPDATE_INDEXES) docs;


# BM25 scores are non-negative; verify they are returned and > 0
query
SELECT id, BM25() > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id;
----
id	has_score
1	t
2	t


# TFIDF scores are also > 0
query
SELECT id, TFIDF() > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id;
----
id	has_score
1	t
2	t


# BM25 with explicit parameters produces non-zero scores
query
SELECT id, BM25(1.2, 0.75) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id;
----
id	has_score
1	t
2	t


# BM25 ordering
query
SELECT id FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY BM25() DESC, id;
----
id
1
2


query
SELECT id FROM docs_idx WHERE PHRASE(body, 'lazy') ORDER BY BM25() DESC, id;
----
id
1
3


