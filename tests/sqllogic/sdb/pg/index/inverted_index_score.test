# OR filter: match either 'fox' or 'lazy', score comes from the matched docs
query
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') OR PHRASE(body, 'lazy') ORDER BY id LIMIT 5;
----
id	has_score
1	t
2	t
3	t
4	t
5	t


# AND filter: only docs containing both 'fox' and 'lazy' get scored
query
SELECT id, BM25(docs_idx.tableoid) > 0 AS has_score FROM docs_idx WHERE PHRASE(body, 'fox') AND PHRASE(body, 'lazy') ORDER BY id;
----
id	has_score
1	t
35	t


# Subquery: wrap scored result, filter by score threshold
query
SELECT id FROM (SELECT id, BM25(docs_idx.tableoid) AS score FROM docs_idx WHERE PHRASE(body, 'fox') ORDER BY id) sub WHERE score > 0 ORDER BY id LIMIT 3;
----
id
1
2
4


