statement ok
INSERT INTO test_term_ops values (5, 'foo', 'e');

statement ok
INSERT INTO test_term_ops values (6, 'foo', 'F');

statement ok
VACUUM (UPDATE_INDEXES) test_term_ops;

query
SELECT a FROM test_term_ops_idx WHERE b @@ (ts_like('percent_not_contain')) ORDER BY a;
----
a
1
2

query
SELECT a FROM test_term_ops_idx WHERE b @@ (ts_like('percent_not_contain')) AND a < 2;
----
a
1

query
SELECT a FROM test_term_ops_idx WHERE b @@ (ts_like('percent\_not\_contain')) ORDER BY a;
----
a
2

query
SELECT a FROM test_term_ops_idx WHERE c @@ 'd';
----
a
4


query
SELECT a FROM test_term_ops_idx WHERE c = 'd';
----
a


query
SELECT a FROM test_term_ops_idx WHERE c @@ ts_gt('d') ORDER BY a DESC;
----
a
6
5

query
SELECT a FROM test_term_ops_idx WHERE c @@ ts_le('d') ORDER BY a DESC;
----
a
4
3
2
1

query
SELECT a FROM test_term_ops_idx WHERE NOT (c @@ ts_lt('d')) ORDER BY a DESC;
----
a
6
5
4

query
SELECT a FROM test_term_ops_idx WHERE c @@ ts_any(['d', 'a']) ORDER BY a DESC;
----
a
4
1

