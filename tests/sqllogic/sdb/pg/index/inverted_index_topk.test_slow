query
SELECT COUNT(*) FROM (
  SELECT id FROM wiki_topk_idx WHERE body @@ ts_phrase('griffith observatory') ORDER BY BM25(wiki_topk_idx.tableoid) DESC
) t;
----
count
250


# Clean up
statement ok
DROP INDEX wiki_topk_idx;

statement ok
DROP TABLE wiki_docs;

statement ok
DROP TEXT SEARCH DICTIONARY en_topk_slow;
