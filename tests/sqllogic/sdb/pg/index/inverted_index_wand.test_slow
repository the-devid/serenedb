# `.*_.*` only `rare_token` carries an underscore.

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ ts_regexp('.*_.*')
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 100),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ ts_regexp('.*_.*')
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 100)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
----
count
0


# === ts_levenshtein (ByLevenshtein -- automaton w/ bounded edit distance) ===
# Distance-1: only 'alpha' is within 1 edit of 'aplha' (single swap).

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ ts_levenshtein('aplha', 1)
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 100),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ ts_levenshtein('aplha', 1)
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 100)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
----
count
0


# Distance-2: 'alpha' (insert h,a) and 'apple' (insert p,e) both within 2.

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ ts_levenshtein('apl', 2)
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 1),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ ts_levenshtein('apl', 2)
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 1)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
