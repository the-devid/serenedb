count
0


# === ts_regexp (ByRegexp -- automaton expansion over the term dictionary) ===

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ ts_regexp('^a.+')
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 1),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ ts_regexp('^a.+')
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 1)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
----
count
0


