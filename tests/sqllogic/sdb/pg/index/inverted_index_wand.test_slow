# === ts_starts_with (ByPrefix -- expands to all matching terms) ===
# Prefix 'a' hits {alpha, apple}; a doc can match both branches, so
# scores fall into a small number of tiers (alpha-only, apple-only, both).

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ ts_starts_with('a')
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 1),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ ts_starts_with('a')
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 1)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
----
count
0


