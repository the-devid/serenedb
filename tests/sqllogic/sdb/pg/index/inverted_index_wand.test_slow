# Prefix 'rare' hits exactly one term -- prefix-as-ByTerm corner case.

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ ts_starts_with('rare')
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 100),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ ts_starts_with('rare')
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 100)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
