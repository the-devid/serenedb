# Skewed disjunction: one huge posting (alpha, ~14k) plus one tiny
# (rare_token, 1k). WAND must reconcile per-term max-impact correctly when
# branch sizes differ by an order of magnitude.

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ ts_any(['alpha', 'rare_token'])
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 1),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ ts_any(['alpha', 'rare_token'])
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 1)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
----
count
0


