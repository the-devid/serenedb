# `>= 'lemon'` flips the direction. Range matches {lemon, mango, purple,
# rare_token, red, yellow, zeta} -- a mix of very common (red), medium
# (yellow/purple/mango/lemon/zeta) and very rare (rare_token) terms.

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ ts_ge('lemon')
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 100),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ ts_ge('lemon')
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 100)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
----
