# Rare term: K can exceed posting-list length (1000 hits, LIMIT 1000 is
# the full set). WAND still has to walk every posting; nothing to prune.

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ 'rare_token'
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 1),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ 'rare_token'
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 1)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
