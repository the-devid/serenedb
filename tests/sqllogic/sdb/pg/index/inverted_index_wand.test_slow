# === Range -- ts_lt / ts_ge (ByRange -- half-open term range) ===
# `< 'cat'` matches {alpha, apple, banana, beta, blue} -- a doc qualifies
# when any one of its 4-5 tokens falls in that range, score is the sum
# of BM25 contributions over the matching tokens.

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ ts_lt('cat')
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 1),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ ts_lt('cat')
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 1)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
----
count
0


