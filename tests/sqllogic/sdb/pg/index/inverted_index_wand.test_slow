hash-threshold 100

# ---------------------------------------------------------------------------
# 100k-row WAND-vs-non-WAND top-K equivalence across every filter that
# compiles to a multi-term iterator with per-block max-impact. The cheap
# (50k-row) coverage lives in sibling inverted_index_wand.test; this file
# extends it to every WAND-eligible filter shape beyond term + ts_any:
# ts_starts_with (ByPrefix), ts_regexp (ByRegexp), ts_levenshtein
# (ByLevenshtein), and ts_lt / ts_ge (ByRange).
#
# Vocabulary is layered so different filter shapes land on different
# posting fan-outs:
#   animal (3 values, ~33k docs each) -- cat / dog / fox
#   color  (5 values, ~20k docs each) -- red / blue / green / yellow / purple
#   greek  (7 values, ~14k docs each) -- alpha .. eta
#   fruit  (11 values, ~9k docs each) -- apple .. mango
#   rare_token (1 value, 1k docs)
#
# Each row is 4 or 5 tokens (the rare_token slot adds one), so BM25 length
# normalisation gives two slightly different score tiers within a posting
# list -- enough variation that WAND actually has docs to prune rather
# than skating through a single uniform score plateau.
#
# Comparison template per filter, at LIMIT k in {1, 10, 100, 1000}:
#   wand_top_k EXCEPT plain_top_k  UNION ALL  plain_top_k EXCEPT wand_top_k
# Must be 0 for the WAND path to agree with the brute-force path on the
# (score DESC, id ASC) tie-broken ordering.
# ---------------------------------------------------------------------------

statement ok
CREATE TEXT SEARCH DICTIONARY en_wand(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);



statement ok
CREATE TABLE wand_huge (id INTEGER PRIMARY KEY, body VARCHAR);


statement ok
CREATE TABLE plain_huge (id INTEGER PRIMARY KEY, body VARCHAR);


statement ok
INSERT INTO wand_huge SELECT i, concat_ws(' ',
    CASE i % 3
      WHEN 0 THEN 'cat'
      WHEN 1 THEN 'dog'
      ELSE        'fox'
    END,
    CASE i % 5
      WHEN 0 THEN 'red'
      WHEN 1 THEN 'blue'
      WHEN 2 THEN 'green'
      WHEN 3 THEN 'yellow'
      ELSE        'purple'
    END,
    CASE i % 7
      WHEN 0 THEN 'alpha'
      WHEN 1 THEN 'beta'
      WHEN 2 THEN 'gamma'
      WHEN 3 THEN 'delta'
      WHEN 4 THEN 'epsilon'
      WHEN 5 THEN 'zeta'
      ELSE        'eta'
    END,
    CASE i % 11
      WHEN 0 THEN 'apple'
      WHEN 1 THEN 'banana'
      WHEN 2 THEN 'cherry'
      WHEN 3 THEN 'date'
      WHEN 4 THEN 'elderberry'
      WHEN 5 THEN 'fig'
      WHEN 6 THEN 'grape'
      WHEN 7 THEN 'huckleberry'
      WHEN 8 THEN 'kiwi'
      WHEN 9 THEN 'lemon'
      ELSE        'mango'
    END,
    CASE i % 100 WHEN 0 THEN 'rare_token' ELSE NULL END
  )
  FROM generate_series(1, 100000) AS s(i);


statement ok
INSERT INTO plain_huge SELECT * FROM wand_huge;


statement ok
CREATE INDEX wand_huge_idx ON wand_huge USING inverted(id, body en_wand)
  WITH (optimize_top_k = 'bm25(1.2, 0.75)');


statement ok
CREATE INDEX plain_huge_idx ON plain_huge USING inverted(id, body en_wand);


statement ok
VACUUM (UPDATE_INDEXES) wand_huge;


statement ok
VACUUM (UPDATE_INDEXES) plain_huge;


# Sanity: both indexes saw the same vocabulary distribution.

query I
SELECT COUNT(*) FROM wand_huge_idx WHERE body @@ 'fox';
----
count
33333


query I
SELECT COUNT(*) FROM plain_huge_idx WHERE body @@ 'fox';
----
count
33333


query I
SELECT COUNT(*) FROM wand_huge_idx WHERE body @@ 'rare_token';
----
count
1000


# === Literal term (ByTerm -> SingleWandIterator) ===
# Common term: pruning has lots of room (heap fills fast, then skips).

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ 'fox'
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 1),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ 'fox'
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 1)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
----
count
0


