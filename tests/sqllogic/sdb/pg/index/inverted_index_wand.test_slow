# === ts_any (ByTerms -> MaxScoreIterator) ===
# Three-term disjunction over the animal slot -- every row matches one
# branch, so this is the densest possible posting union.

query I
WITH w AS (SELECT id FROM wand_huge_idx WHERE body @@ ts_any(['fox', 'cat', 'dog'])
           ORDER BY BM25(wand_huge_idx.tableoid) DESC, id LIMIT 1),
     p AS (SELECT id FROM plain_huge_idx WHERE body @@ ts_any(['fox', 'cat', 'dog'])
           ORDER BY BM25(plain_huge_idx.tableoid) DESC, id LIMIT 1)
SELECT COUNT(*) FROM (
  (SELECT * FROM w EXCEPT SELECT * FROM p)
  UNION ALL
  (SELECT * FROM p EXCEPT SELECT * FROM w)
) d;
----
count
0


