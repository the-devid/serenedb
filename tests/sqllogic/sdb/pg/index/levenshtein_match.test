statement ok
DROP TEXT SEARCH DICTIONARY IF EXISTS test_english;

statement ok
DROP TABLE IF EXISTS test_levenshtein;

statement ok
CREATE TABLE test_levenshtein (a INTEGER PRIMARY KEY, b VARCHAR);

statement ok
CREATE TEXT SEARCH DICTIONARY test_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'lower',
    stemming = false,
    accent = false
);

statement ok
CREATE INDEX test_levenshtein_idx ON test_levenshtein USING inverted(a, b test_english);

statement ok
INSERT INTO test_levenshtein values (1, 'cat');

statement ok
INSERT INTO test_levenshtein values (2, 'bat');

statement ok
INSERT INTO test_levenshtein values (3, 'car');

statement ok
INSERT INTO test_levenshtein values (4, 'dog');

statement ok
INSERT INTO test_levenshtein values (5, 'cats');

statement ok
INSERT INTO test_levenshtein values (6, 'act');

statement ok
VACUUM (UPDATE_INDEXES) test_levenshtein;

# Exact match (distance 0)
query
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('cat', 0) ORDER BY a;
----
a
1

# Distance 1: cat, bat (substitution), car (substitution), cats (insertion), act (transposition with default transpositions=true)
query
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('cat', 1) ORDER BY a;
----
a
1
2
3
5
6

# Distance 1 without transpositions: act is distance 2 (not a single transposition)
query
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('cat', 1, false) ORDER BY a;
----
a
1
2
3
5

# Distance 2 matches more
query
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('cat', 2) ORDER BY a;
----
a
1
2
3
5
6

# !! LEVENSHTEIN -- TSQUERY-surface negation.
query
SELECT a FROM test_levenshtein_idx WHERE b @@ !!ts_levenshtein('cat', 0) ORDER BY a;
----
a
2
3
4
5
6

# Distance too high (> 4)
statement error
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('cat', 5);

# Distance too high for transpositions (> 3)
statement error
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('cat', 4, true);

# Combined with AND on a non-FTS predicate.
query
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('cat', 1) AND a < 4 ORDER BY a;
----
a
1
2
3

# 1-arg form -- distance is picked from term length: 0 for <=2 chars,
# 1 for 3-5 chars, 2 for >=6 chars. 
# Keeps short queries from drifting into unrelated
# tokens in stemmed indexes (e.g. `rocks` reaching `lock` via 2 edits).

# 3 chars -> distance 1. Same hits as ts_levenshtein('cat', 1).
query
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('cat') ORDER BY a;
----
a
1
2
3
5
6

# 4 chars -> distance 1. Same hits as ts_levenshtein('cats', 1).
query
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('cats') ORDER BY a;
----
a
1
5

# 2 chars -> distance 0. No row exactly matches 'ab', so empty.
query
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('ab') ORDER BY a;
----
a

# 1 char -> distance 0. No row exactly matches.
query
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('z') ORDER BY a;
----
a

# 6+ chars -> distance 2. No row is within 2 edits of 'caterpillar'.
query
SELECT a FROM test_levenshtein_idx WHERE b @@ ts_levenshtein('caterpillar') ORDER BY a;
----
a

# Auto distance composes with negation, AND, and the boost operator.
query
SELECT a FROM test_levenshtein_idx WHERE b @@ !!ts_levenshtein('cat') ORDER BY a;
----
a
4

statement ok
DROP TABLE test_levenshtein;


# Optional `prefix` 4th argument: a literal leading substring that must
# match exactly. Only the suffix beyond `prefix` participates in
# edit-distance computation.
statement ok
DROP TABLE IF EXISTS test_levenshtein_prefix;

statement ok
CREATE TABLE test_levenshtein_prefix (a INTEGER PRIMARY KEY, b VARCHAR);

statement ok
CREATE INDEX test_levenshtein_prefix_idx ON test_levenshtein_prefix USING inverted(a, b test_english);

statement ok
INSERT INTO test_levenshtein_prefix VALUES
    (1, 'apple'),
    (2, 'apply'),
    (3, 'application'),
    (4, 'apricot'),
    (5, 'banana');

statement ok
VACUUM (UPDATE_INDEXES) test_levenshtein_prefix;


# Prefix `app` + suffix `le` distance 0 -> only `apple` matches.
query
SELECT a FROM test_levenshtein_prefix_idx WHERE b @@ ts_levenshtein('le', 0, true, 'app') ORDER BY a;
----
a
1


# Prefix `app` + suffix `le` distance 1 -> `apple` (dist 0) and `apply` (dist 1).
# `application` has suffix `lication` which is way beyond distance 1 from `le`.
# `apricot` doesn't share the literal `app` prefix (only `ap`) so it's excluded.
# `banana` doesn't share the prefix at all.
query
SELECT a FROM test_levenshtein_prefix_idx WHERE b @@ ts_levenshtein('le', 1, true, 'app') ORDER BY a;
----
a
1
2


# Empty prefix is equivalent to the 3-arg form: full term participates in
# edit-distance computation.
query
SELECT a FROM test_levenshtein_prefix_idx WHERE b @@ ts_levenshtein('apple', 1, true, '') ORDER BY a;
----
a
1
2


# `!! ts_levenshtein(... prefix)` -- negation composes with the prefix path.
query
SELECT a FROM test_levenshtein_prefix_idx WHERE b @@ !!ts_levenshtein('le', 1, true, 'app') ORDER BY a;
----
a
3
4
5


# Distance bounds (>4 / >3-with-transpositions) are still enforced when
# a prefix is supplied.
statement error
SELECT a FROM test_levenshtein_prefix_idx WHERE b @@ ts_levenshtein('le', 5, true, 'app');

statement error
SELECT a FROM test_levenshtein_prefix_idx WHERE b @@ ts_levenshtein('le', 4, true, 'app');


statement ok
DROP TABLE test_levenshtein_prefix;
