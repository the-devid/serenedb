statement ok
CREATE TABLE no_pk_table AS
SELECT
  CASE
    WHEN ids.value % 2 = 0 THEN
      'word is good: ' || (ids.value)::text
    ELSE
      'word is bad: ' || (ids.value)::text
  END AS word
FROM
  generate_series(1, 1000) as ids(value)


statement ok
CREATE INDEX no_pk_index ON no_pk_table USING INVERTED(word test_english);


query
SELECT * FROM no_pk_index WHERE word @@ ts_phrase('bad') LIMIT 1;
----
word
word is bad: 1
