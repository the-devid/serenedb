statement ok
CREATE TEXT SEARCH DICTIONARY score_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);

statement ok
CREATE INDEX score_parquet_idx ON score_parquet_ext USING inverted(a, b score_en);

onlyif serenedb
query
EXPLAIN SELECT a, BM25(score_parquet_idx.tableoid) > 0 AS has_score FROM score_parquet_idx WHERE b @@ ts_phrase('fox') ORDER BY a;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│  score_parquet_idx.a ASC  │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│         PROJECTION        │
│    ────────────────────   │
│             a             │
│         has_score         │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│           Index:          │
│     score_parquet_idx     │
│                           │
│      Lookup: parquet      │
│                           │
│          Filter:          │
│  AND[PHRASE[b(string) =   │
│    <Term:fox(0, 0); >]]   │
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│        Projections:       │
│             a             │
│  sdb_inverted_index_score │
│                           │
│          ~3 rows          │
└───────────────────────────┘


