query
SELECT COUNT(1) FROM vedernikoff_idx WHERE b @@ ts_phrase('pudge') AND b @@ ts_phrase('game');
----
count
2


query
EXPLAIN SELECT COUNT(*) FROM vedernikoff_idx WHERE b @@ ts_phrase('pudge') AND b @@ ts_phrase('game');
----
QUERY PLAN
┌───────────────────────────┐
│    UNGROUPED_AGGREGATE    │
│    ────────────────────   │
│        Aggregates:        │
│        count_star()       │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│      IRESEARCH_COUNT      │
│    ────────────────────   │
│           Index:          │
│      vedernikoff_idx      │
│                           │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│  AND[PHRASE[b(string) =   │
│  <Term:pudge(0, 0); >] && │
│  PHRASE[b(string) = <Term │
│      :game(0, 0); >]]     │
│                           │
│          Output:          │
│       row-count only      │
│                           │
│          ~4 rows          │
└───────────────────────────┘


