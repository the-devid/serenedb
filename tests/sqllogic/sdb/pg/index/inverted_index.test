# BM25 scoring on external (parquet) table

statement ok
CREATE TABLE score_parquet_src (a INTEGER PRIMARY KEY, b TEXT);

statement ok
INSERT INTO score_parquet_src VALUES
  (1, 'the quick brown fox jumps over the lazy dog'),
  (2, 'the quick fox'),
  (3, 'the lazy dog');

statement count 3
COPY score_parquet_src TO '/tmp/${__DATABASE__}_score_parquet.parquet' (FORMAT PARQUET);

statement ok
CREATE TABLE score_parquet_ext(
  a INT8,
  b TEXT
) USING EXTERNAL
WITH (
  PATH = '/tmp/${__DATABASE__}_score_parquet.parquet'
);

statement ok
CREATE TEXT SEARCH DICTIONARY score_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);

statement ok
CREATE INDEX score_parquet_idx ON score_parquet_ext USING inverted(a, b score_en);

query
SELECT a, BM25() > 0 AS has_score FROM score_parquet_idx WHERE PHRASE(b, 'fox') ORDER BY a;
----
a	has_score
1	t
2	t

query
SELECT a FROM score_parquet_idx WHERE PHRASE(b, 'fox') ORDER BY BM25() DESC, a;
----
a
1
2

statement ok
DROP TABLE score_parquet_ext;

statement ok
DROP TABLE score_parquet_src;


