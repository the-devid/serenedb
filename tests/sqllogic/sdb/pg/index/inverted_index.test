hash-threshold 100

statement ok
CREATE TABLE foo (a INTEGER PRIMARY KEY, b VARCHAR, c VARCHAR);

statement ok
INSERT INTO foo values (1, 'quick brown fox jumps over lazy dog', 'value a');

statement ok
CREATE TEXT SEARCH DICTIONARY test_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement ok
CREATE INDEX foo_idx ON foo USING inverted(a, b test_english, c test_english);

query
SELECT a, b, c FROM foo_idx WHERE b @@ ts_phrase('over lazy dog');
----
a	b	c
1	quick brown fox jumps over lazy dog	value a

statement ok
INSERT INTO foo values (2, 'quick red fox jumps over lazy dog', 'value a');

statement ok
VACUUM (UPDATE_INDEXES) foo;

query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('over lazy dog') ORDER BY a;
----
a	b
1	quick brown fox jumps over lazy dog
2	quick red fox jumps over lazy dog

statement ok
UPDATE foo SET c = 'value abc' WHERE a = 1;

statement ok
VACUUM (UPDATE_INDEXES) foo;

query
SELECT a, b, c FROM foo_idx WHERE c @@ ts_phrase('value abc') AND b @@ ts_phrase('over lazy dog');
----
a	b	c
1	quick brown fox jumps over lazy dog	value abc

statement ok
INSERT INTO foo values (3, 'quick red fox jumps over big dog', 'value a');

statement ok
INSERT INTO foo values (4, 'quick brown fox jumps over big dog', 'value b');

statement ok
VACUUM (UPDATE_INDEXES) foo;

query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('over big dog') OR b @@ ts_phrase('red fox') ORDER BY a;
----
a	b
2	quick red fox jumps over lazy dog
3	quick red fox jumps over big dog
4	quick brown fox jumps over big dog

query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('over big dog') OR a = 1 ORDER BY a;
----
a	b
1	quick brown fox jumps over lazy dog
3	quick red fox jumps over big dog
4	quick brown fox jumps over big dog

query
SELECT a, b, c FROM foo_idx WHERE c @@ ts_phrase('value b') AND b @@ ts_phrase('over big dog');
----
a	b	c
4	quick brown fox jumps over big dog	value b

statement ok
INSERT INTO foo values (5, 'quick brown lazy fox runs over big dog', 'value c');

statement ok
INSERT INTO foo values (6, 'quick fox over big dog', 'value c');

statement ok
VACUUM (UPDATE_INDEXES) foo;

# Exact gap: 1 word between 'quick' and 'fox' -- matches rows with 'quick brown fox' and 'quick red fox'
query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('quick', 1, 'fox') ORDER BY a;
----
a	b
1	quick brown fox jumps over lazy dog
2	quick red fox jumps over lazy dog
3	quick red fox jumps over big dog
4	quick brown fox jumps over big dog

# Exact gap: 2 words between 'quick' and 'fox' -- matches only row 5 ('quick brown lazy fox')
query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('quick', 2, 'fox') ORDER BY a;
----
a	b
5	quick brown lazy fox runs over big dog

# Exact gap: 0 words between (adjacent) -- matches only row 6 ('quick fox')
query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('quick', 0, 'fox') ORDER BY a;
----
a	b
6	quick fox over big dog

# Range gap [0,1]: 0 or 1 words between 'quick' and 'fox'
query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('quick', ARRAY[0,1], 'fox') ORDER BY a;
----
a	b
1	quick brown fox jumps over lazy dog
2	quick red fox jumps over lazy dog
3	quick red fox jumps over big dog
4	quick brown fox jumps over big dog
6	quick fox over big dog

# Range gap [1,2]: 1 or 2 words between 'quick' and 'fox'
query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('quick', ARRAY[1,2], 'fox') ORDER BY a;
----
a	b
1	quick brown fox jumps over lazy dog
2	quick red fox jumps over lazy dog
3	quick red fox jumps over big dog
4	quick brown fox jumps over big dog
5	quick brown lazy fox runs over big dog

# Range gap with bracket-literal syntax [1,2] -- also binds to LIST,
# same as ARRAY[1,2] above.
query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('quick', [1,2], 'fox') ORDER BY a;
----
a	b
1	quick brown fox jumps over lazy dog
2	quick red fox jumps over lazy dog
3	quick red fox jumps over big dog
4	quick brown fox jumps over big dog
5	quick brown lazy fox runs over big dog

# Range gap with explicit fixed-size ARRAY cast -- exercises the ARRAY
# branch of FromPhrase (unadorned ARRAY[..] / [..] bind to LIST, only an
# explicit INTEGER[n] cast produces a fixed-size ARRAY value).
query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('quick', [1,2]::INTEGER[2], 'fox') ORDER BY a;
----
a	b
1	quick brown fox jumps over lazy dog
2	quick red fox jumps over lazy dog
3	quick red fox jumps over big dog
4	quick brown fox jumps over big dog
5	quick brown lazy fox runs over big dog

# Multi-token pattern with gap: 'quick brown' then 1 word then 'fox' -- only row 5 has 'brown lazy fox'
query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('quick brown', 1, 'fox') ORDER BY a;
----
a	b
5	quick brown lazy fox runs over big dog

# Multiple gaps: 'quick' +1 word+ 'fox' +3 words+ 'dog'
query
SELECT a, b FROM foo_idx WHERE b @@ ts_phrase('quick', 1, 'fox', 3, 'dog') ORDER BY a;
----
a	b
1	quick brown fox jumps over lazy dog
2	quick red fox jumps over lazy dog
3	quick red fox jumps over big dog
4	quick brown fox jumps over big dog

# Error: leading text pattern tokenizes to nothing (empty string) so the
# following integer gap has no preceding text -- covers the opts->empty()
# check in the integer gap branch of FromPhrase.
query error ts_phrase gap at argument 1 must be preceded by a text pattern
SELECT a FROM foo_idx WHERE b @@ ts_phrase('', 1, 'fox');


# Same as above but via a range gap -- covers the opts->empty() check
# in the LIST/ARRAY gap branch of FromPhrase.
query error ts_phrase gap at argument 1 must be preceded by a text pattern
SELECT a FROM foo_idx WHERE b @@ ts_phrase('', ARRAY[1,2], 'fox');


# Error: gap at end with no following text pattern
query error ts_phrase ends with a gap; a text pattern must follow each gap
SELECT a FROM foo_idx WHERE b @@ ts_phrase('quick', 1);


# Error: two consecutive gaps
query error ts_phrase has consecutive gaps at argument 2
SELECT a FROM foo_idx WHERE b @@ ts_phrase('quick', 1, 2, 'fox');


# Error: range gap with min > max
query error ts_phrase interval gap must satisfy 0 <= min <= max, got \[3, 1\] \(argument 1\)
SELECT a FROM foo_idx WHERE b @@ ts_phrase('quick', ARRAY[3,1], 'fox');


statement ok
DROP TABLE foo;

