# Multi-segment scoring: insert+vacuum then insert again (unsorted keys across segments)

statement ok
CREATE TABLE multi_seg (a INTEGER PRIMARY KEY, b TEXT);

statement ok
INSERT INTO multi_seg VALUES (1, 'alpha fox'), (2, 'beta fox');

statement ok
CREATE INDEX multi_seg_idx ON multi_seg USING inverted(a, b score_en);

statement ok
VACUUM (UPDATE_INDEXES) multi_seg;

statement ok
INSERT INTO multi_seg VALUES (3, 'gamma fox'), (4, 'delta fox');

statement ok
VACUUM (UPDATE_INDEXES) multi_seg;

query
SELECT a, BM25() > 0 AS has_score FROM multi_seg_idx WHERE PHRASE(b, 'fox') ORDER BY a;
----
a	has_score
1	t
2	t
3	t
4	t

query
SELECT a FROM multi_seg_idx WHERE PHRASE(b, 'fox') ORDER BY BM25() DESC, a;
----
a
1
2
3
4

statement ok
DROP TABLE multi_seg;
