hash-threshold 100

# Per-format reader variant coverage (read_parquet vs parquet_scan,
# csv/json _auto aliases) -- each must classify into the same fast-path.

statement ok
CREATE TEXT SEARCH DICTIONARY variants_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);

statement count 2
COPY (SELECT 1 AS a, 'shared term alpha info' AS b
      UNION ALL SELECT 2, 'shared term beta info')
TO '/tmp/${__DATABASE__}_variants.jsonl' (FORMAT json);

statement count 2
COPY (SELECT 1 AS a, 'shared term alpha info' AS b
      UNION ALL SELECT 2, 'shared term beta info')
TO '/tmp/${__DATABASE__}_variants.parquet' (FORMAT parquet);

statement count 2
COPY (SELECT 1 AS a, 'shared term alpha info' AS b
      UNION ALL SELECT 2, 'shared term beta info')
TO '/tmp/${__DATABASE__}_variants.csv' (FORMAT csv, HEADER);


# ---- parquet variants ----

statement ok
CREATE VIEW v_read_parquet AS SELECT * FROM read_parquet('/tmp/${__DATABASE__}_variants.parquet');

statement ok
CREATE INDEX v_read_parquet_idx ON v_read_parquet USING inverted(a, b variants_en);

query
SELECT a, b FROM v_read_parquet_idx WHERE b @@ ts_phrase('shared term') ORDER BY a;
----
a	b
1	shared term alpha info
2	shared term beta info

statement ok
CREATE VIEW v_parquet_scan AS SELECT * FROM parquet_scan('/tmp/${__DATABASE__}_variants.parquet');

statement ok
CREATE INDEX v_parquet_scan_idx ON v_parquet_scan USING inverted(a, b variants_en);

query
SELECT a, b FROM v_parquet_scan_idx WHERE b @@ ts_phrase('shared term') ORDER BY a;
----
a	b
1	shared term alpha info
2	shared term beta info


