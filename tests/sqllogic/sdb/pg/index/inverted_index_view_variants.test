# ---- json variants (objects mode) ----
# objects mode emits a single 'json' VARCHAR column; PHRASE works via
# the search-filter-builder cast-peel.

statement ok
CREATE VIEW v_read_json_objects AS SELECT * FROM read_json_objects('/tmp/${__DATABASE__}_variants.jsonl');

statement ok
CREATE INDEX v_read_json_objects_idx ON v_read_json_objects USING inverted(json variants_en);

query
SELECT json FROM v_read_json_objects_idx WHERE json @@ ts_phrase('shared term') ORDER BY json;
----
json
{"a":1,"b":"shared term alpha info"}
{"a":2,"b":"shared term beta info"}

statement ok
