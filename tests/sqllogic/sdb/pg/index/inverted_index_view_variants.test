# ---- projection shapes (subset / reorder / rename / cast) ----

statement ok
CREATE VIEW v_subset AS SELECT b FROM read_parquet('/tmp/${__DATABASE__}_variants.parquet');

statement ok
CREATE INDEX v_subset_idx ON v_subset USING inverted(b variants_en);

query
SELECT b FROM v_subset_idx WHERE b @@ ts_phrase('shared term') ORDER BY b;
----
b
shared term alpha info
shared term beta info

statement ok
CREATE VIEW v_reorder AS SELECT b, a FROM read_parquet('/tmp/${__DATABASE__}_variants.parquet');

statement ok
CREATE INDEX v_reorder_idx ON v_reorder USING inverted(b variants_en, a);

query
SELECT a, b FROM v_reorder_idx WHERE b @@ ts_phrase('shared term') ORDER BY a;
----
a	b
1	shared term alpha info
2	shared term beta info

statement ok
