# View body modifiers: backfill applies WHERE/ORDER/LIMIT, so the index
# only captures rows the view emits; non-matching rows are never added.

# WHERE only
statement ok
CREATE VIEW v_where AS
  SELECT a, b FROM read_parquet('/tmp/${__DATABASE__}_variants.parquet')
  WHERE a <= 2;

statement ok
CREATE INDEX v_where_idx ON v_where USING inverted(b variants_en, a);

query
SELECT count(*) FROM v_where_idx;
----
count
2

query
SELECT a, b FROM v_where_idx WHERE b @@ ts_phrase('shared term') ORDER BY a;
----
a	b
1	shared term alpha info
2	shared term beta info

# ORDER BY only -- order doesn't change index contents; just verify
# the body still classifies as fast-path.
statement ok
CREATE VIEW v_order AS
  SELECT a, b FROM read_parquet('/tmp/${__DATABASE__}_variants.parquet')
  ORDER BY a;

statement ok
CREATE INDEX v_order_idx ON v_order USING inverted(b variants_en, a);

query
SELECT count(*) FROM v_order_idx WHERE b @@ ts_phrase('shared term');
----
count
2

# LIMIT only -- index captures only the first row of v_limit.
statement ok
CREATE VIEW v_limit AS
  SELECT a, b FROM read_parquet('/tmp/${__DATABASE__}_variants.parquet')
  ORDER BY a LIMIT 1;

statement ok
CREATE INDEX v_limit_idx ON v_limit USING inverted(b variants_en, a);

query
SELECT count(*) FROM v_limit_idx;
----
count
1

query
SELECT a FROM v_limit_idx WHERE b @@ ts_phrase('shared term');
----
a
1

# WHERE + ORDER BY + LIMIT combined
statement ok
CREATE VIEW v_filter_order_limit AS
  SELECT b AS y, a::BIGINT AS x
  FROM read_parquet('/tmp/${__DATABASE__}_variants.parquet')
  WHERE a >= 1
  ORDER BY a
  LIMIT 2;

statement ok
CREATE INDEX v_filter_order_limit_idx ON v_filter_order_limit USING inverted(y variants_en, x);

query
SELECT count(*) FROM v_filter_order_limit_idx;
----
count
2

query
SELECT x, y FROM v_filter_order_limit_idx WHERE y @@ ts_phrase('shared term') ORDER BY x;
----
x	y
1	shared term alpha info
2	shared term beta info


