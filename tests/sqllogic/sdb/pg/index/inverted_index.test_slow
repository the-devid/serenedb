statement ok
DROP TABLE json_idx_ext;

statement ok
DROP TABLE json_idx_src;


statement ok
CREATE TABLE dense_pk_slow (a INTEGER PRIMARY KEY, b TEXT);

statement count 5000
INSERT INTO dense_pk_slow
SELECT n, 'every row shares universal phrase number ' || n::text
FROM generate_series(1, 5000) AS s(n);

statement ok
CREATE INDEX dense_pk_slow_idx ON dense_pk_slow USING inverted(a, b test_english);

statement ok
VACUUM (UPDATE_INDEXES) dense_pk_slow;

statement count 5000
INSERT INTO dense_pk_slow
SELECT n, 'every row shares universal phrase number ' || n::text
FROM generate_series(5001, 10000) AS s(n);

statement ok
VACUUM (UPDATE_INDEXES) dense_pk_slow;

