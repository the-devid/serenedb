show-column-names false
hash-threshold 100

statement count 100000
CREATE TABLE clickclack AS
SELECT
  CASE
    WHEN vedernikoff_team.crook % 2 = 0 THEN
      'team member vedernikoff has ' || (crook / 10)::text || ' stocks'
    ELSE
      'team member cutelooked has ' || (boss * 1000)::text || ' stocks'
  END AS fact
FROM
  generate_series(1, 1000) as vedernikoff_team(crook),
  generate_series(1, 100) as cutelooked_team(boss);

statement ok
CREATE TEXT SEARCH DICTIONARY test_english(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);

statement ok
CREATE INDEX clickclack_facts ON clickclack USING inverted(fact test_english);

query
SELECT * FROM clickclack_facts WHERE fact @@ ts_phrase('team member');
----
100000 values hashing to bb6ff2754819408ef9bd04dec00816a6

query
SELECT * FROM clickclack_facts WHERE fact @@ ts_phrase('vedernikoff has');
----
50000 values hashing to 094f52e717c8cf7ff4991704ce7b48e5

query
SELECT * FROM clickclack_facts WHERE fact @@ ts_phrase('cutelooked has');
----
50000 values hashing to 9fd1ddfa1c80ec0842fd691aa0c87e10

query
SELECT * FROM clickclack_facts WHERE fact @@ ts_phrase('has 0 stocks');
----
400 values hashing to 281bddebb99a13518781132c8d56e194


statement ok
DROP TABLE clickclack;

statement ok
CREATE TABLE clickclack_pk (fact TEXT PRIMARY KEY, detail TEXT);

statement count 10000
INSERT INTO clickclack_pk
SELECT
  CASE
    WHEN rn % 2 = 0 THEN
      'team member vedernikoff has ' || rn::text || ' stocks'
    ELSE
      'team member cutelooked has ' || rn::text || ' stocks'
  END AS fact,
  CASE
    WHEN rn % 2 = 0 THEN
      'vedernikoff row ' || rn::text
    ELSE
      'cutelooked row ' || rn::text
  END AS detail
FROM
  generate_series(1, 10000) AS s(rn);

statement ok
CREATE INDEX clickclack_pk_facts ON clickclack_pk USING inverted(fact test_english, detail test_english);

query
SELECT * FROM clickclack_pk_facts WHERE fact @@ ts_phrase('team member') ORDER BY fact;
----
20000 values hashing to c5e18a8a07f65b8031c775e242239353

query
SELECT * FROM clickclack_pk_facts WHERE fact @@ ts_phrase('vedernikoff has') ORDER BY fact;
----
10000 values hashing to b74729795b45633d271483956071de12

query
SELECT * FROM clickclack_pk_facts WHERE fact @@ ts_phrase('cutelooked has') ORDER BY fact;
----
10000 values hashing to 1d8c44c6f3d932d3b08d276682b5124e

query
SELECT * FROM clickclack_pk_facts WHERE fact @@ ts_phrase('has 0 stocks') ORDER BY fact;
----

query
SELECT * FROM clickclack_pk_facts WHERE detail @@ ts_phrase('vedernikoff row') ORDER BY fact;
----
10000 values hashing to b74729795b45633d271483956071de12

query
SELECT * FROM clickclack_pk_facts WHERE detail @@ ts_phrase('cutelooked row') ORDER BY fact;
----
10000 values hashing to 1d8c44c6f3d932d3b08d276682b5124e

statement ok
DROP TABLE clickclack_pk;

control substitution on

# index on external text/csv table with large dataset

statement count 100000
CREATE TABLE csv_idx_src AS
SELECT
  CASE
    WHEN vedernikoff_team.crook % 2 = 0 THEN
      'team member vedernikoff has ' || (crook / 10)::text || ' stocks'
    ELSE
      'team member cutelooked has ' || (boss * 1000)::text || ' stocks'
  END AS fact,
  CASE
    WHEN vedernikoff_team.crook % 3 = 0 THEN
      'department alpha'
    ELSE
      'department beta'
  END AS dept
FROM
  generate_series(1, 1000) as vedernikoff_team(crook),
  generate_series(1, 100) as cutelooked_team(boss);

statement count 100000
COPY csv_idx_src TO '/tmp/${__DATABASE__}_csv_idx_slow.csv';

statement ok
CREATE TABLE csv_idx_ext(
  fact TEXT,
  dept TEXT
) WITH (
  PATH = '/tmp/${__DATABASE__}_csv_idx_slow.csv'
);

statement ok
CREATE INDEX csv_idx_ext_facts ON csv_idx_ext USING inverted(fact test_english, dept test_english);

query
SELECT * FROM csv_idx_ext_facts WHERE fact @@ ts_phrase('team member');
----
200000 values hashing to dffa5050b3b273e066f091861f35419f

query
SELECT * FROM csv_idx_ext_facts WHERE fact @@ ts_phrase('vedernikoff has');
----
100000 values hashing to 68ea068f3dc556204bf660fa9bf9f37d

query
SELECT * FROM csv_idx_ext_facts WHERE fact @@ ts_phrase('cutelooked has');
----
100000 values hashing to cb3f9840fcd2ef13ff17e654eac7c758

query
SELECT * FROM csv_idx_ext_facts WHERE dept @@ ts_phrase('department alpha');
----
66600 values hashing to e75efbadfaf23e06fddbfa32ed427ef9

statement ok
DROP TABLE csv_idx_ext;

statement ok
DROP TABLE csv_idx_src;


statement count 10000
CREATE TABLE dense_pq_slow_src AS
SELECT
  'every row shares this phrase plus detail number ' || s.n::text AS fact,
  CASE
    WHEN s.n % 3 = 0 THEN 'division alpha sector'
    WHEN s.n % 3 = 1 THEN 'division beta sector'
    ELSE 'division gamma sector'
  END AS division
FROM generate_series(1, 10000) AS s(n);

statement count 10000
COPY dense_pq_slow_src TO '/tmp/${__DATABASE__}_dense_pq_slow.parquet' (FORMAT PARQUET);

statement ok
CREATE TABLE dense_pq_slow_ext(
  fact TEXT,
  division TEXT
) WITH (
  PATH = '/tmp/${__DATABASE__}_dense_pq_slow.parquet'
);

statement ok
CREATE INDEX dense_pq_slow_idx ON dense_pq_slow_ext USING inverted(fact test_english, division test_english);

query
SELECT * FROM dense_pq_slow_idx WHERE fact @@ ts_phrase('every row shares');
----
