6666 values hashing to d02fe07290c471e6b19d6ae6bfeea5b3

query
SELECT * FROM dense_pq_slow_idx WHERE PHRASE(fact, 'every') OR PHRASE(division, 'division alpha sector');
----
20000 values hashing to 6d447bce6f45bd07ae971f1e22396944

statement ok
DROP TABLE dense_pq_slow_ext;

statement ok
DROP TABLE dense_pq_slow_src;


statement count 10000
CREATE TABLE dense_csv_slow_src AS
SELECT
  'universal text entry number ' || s.n::text || ' in dataset' AS content,
  CASE
    WHEN s.n % 2 = 0 THEN 'region north area'
    ELSE 'region south area'
  END AS region
FROM generate_series(1, 10000) AS s(n);

statement count 10000
COPY dense_csv_slow_src TO '/tmp/${__DATABASE__}_dense_csv_slow.csv';

statement ok
CREATE TABLE dense_csv_slow_ext(
  content TEXT,
  region TEXT
) USING EXTERNAL
WITH (
  PATH = '/tmp/${__DATABASE__}_dense_csv_slow.csv'
);

statement ok
CREATE INDEX dense_csv_slow_idx ON dense_csv_slow_ext USING inverted(content test_english, region test_english);

