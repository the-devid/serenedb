# scoring tests
# docs 51-200 have phrase duplicated so should get higher score
# and that should be not messed up during reading

query
SELECT a, BM25(tableoid) FROM dense_no_pk_slow_idx WHERE a < 90 AND c @@ ts_phrase('some row shares universal') ORDER BY a;
