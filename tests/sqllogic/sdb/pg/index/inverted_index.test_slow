# index backfill from external (json) table with large dataset
# exercises the JSON offset-seek path (ReadJSONFunctionPkLookup) at scale.

statement count 10000
CREATE TABLE json_idx_src AS
SELECT
  CASE
    WHEN s.n % 2 = 0 THEN
      'team member vedernikoff has ' || s.n::text || ' stocks'
    ELSE
      'team member cutelooked has ' || s.n::text || ' stocks'
  END AS fact,
  CASE
    WHEN s.n % 3 = 0 THEN 'department alpha'
    ELSE 'department beta'
  END AS dept
FROM generate_series(1, 10000) AS s(n);

statement count 10000
COPY json_idx_src TO '/tmp/${__DATABASE__}_json_idx_slow.jsonl' (FORMAT json);

statement ok
CREATE TABLE json_idx_ext(
  fact TEXT,
  dept TEXT
) WITH (
  PATH = '/tmp/${__DATABASE__}_json_idx_slow.jsonl'
);

statement ok
CREATE INDEX json_idx_ext_facts ON json_idx_ext USING inverted(fact test_english, dept test_english);

query
