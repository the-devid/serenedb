query
SELECT offsets_test_idx.id, OFFSETS(offsets_test_idx.body) AS bo
FROM offsets_test_idx
JOIN offsets_test2_idx ON offsets_test_idx.id = offsets_test2_idx.id
WHERE PHRASE(offsets_test_idx.body, 'fox') AND PHRASE(offsets_test2_idx.body, 'fox')
ORDER BY offsets_test_idx.id;
