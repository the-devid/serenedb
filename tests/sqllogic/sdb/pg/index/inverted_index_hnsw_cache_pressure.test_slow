hash-threshold 100

# Forces HNSW build under chunked-vector-cache pressure so the
# `ColumnDistance::symmetric_dis` path runs many times with i and j
# in non-pinned chunks.
#
# Bug shape (without the Pin/Unpin fix): symmetric_dis(i, j) did
# `a = cache->Get(i); b = cache->Get(j); dist(a, b)`. Get(j) can
# evict the chunk holding `a` (the slot's pin count is 0 between
# Get calls; s3-fifo touches `a` to freq=1; if `a`'s slot is at the
# front of the small queue when j needs a fresh chunk, ghost-evict
# erases it from the index, the duckdb::Vector buffer is freed, and
# `a` becomes dangling). On ASan the dangling read in `dist` trips a
# heap-use-after-free and the server aborts mid-build.
#
# d=128 makes chunk_rows = kChunkSizeFloats / d = 4*1024 / 128 = 32.
# 64 cache slots * 32 rows = 2048-row capacity; 6000 rows force
# eviction across the build. Vectors are spread across distance
# space so HNSW pruning (the consumer of symmetric_dis) is heavily
# exercised.

statement ok
CREATE TABLE vec (id INT PRIMARY KEY, emb FLOAT[128]);

statement ok
CREATE INDEX hnsw_idx ON vec USING inverted(emb hnsw (metric = 'l2'));

statement ok
INSERT INTO vec
SELECT i, list_transform(range(128), j -> ((i * 31 + j * 17) % 997)::FLOAT)::FLOAT[128]
FROM generate_series(1, 6000) i;

# Forces HNSWWriter::Build to run; ASan trips here on the unfixed
# code if the dangling read fires during build.
statement ok
VACUUM (UPDATE_INDEXES) vec;

# Sanity: index is queryable and returns the requested top-K.
query
SELECT COUNT(*) FROM (
  SELECT id FROM hnsw_idx
  ORDER BY emb <-> list_transform(range(128), j -> 100.0::FLOAT)::FLOAT[128]
  LIMIT 5
) t;
----
count
5

statement ok
DROP TABLE vec;
