hash-threshold 100

# End-to-end: INCLUDE'd ARRAY<FLOAT, N> column round-trips through new cs.
# Exercises the ARRAY composite type in the new cs columnstore: top level
# carries only validity, child column carries flattened elements.

statement ok
CREATE TABLE arr_t (
  pk INTEGER PRIMARY KEY,
  text_for_search VARCHAR,
  vec FLOAT[3]
)


statement ok
CREATE TEXT SEARCH DICTIONARY en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
)


statement ok
CREATE INDEX arr_t_idx ON arr_t USING inverted(pk, text_for_search en)
  INCLUDE (vec)


statement ok
INSERT INTO arr_t VALUES (1, 'first',  [1.0, 2.0, 3.0])


statement ok
INSERT INTO arr_t VALUES (2, 'second', [4.5, 5.5, 6.5])


statement ok
INSERT INTO arr_t VALUES (3, 'third',  [-1.0, 0.0, 1.0])


statement ok
VACUUM (UPDATE_INDEXES) arr_t


query
SELECT pk, vec FROM arr_t_idx WHERE text_for_search @@ ts_phrase('first')
ORDER BY pk;
----
pk	vec
1	{1,2,3}


query
SELECT pk, vec FROM arr_t_idx WHERE text_for_search @@ ts_phrase('second')
ORDER BY pk;
----
pk	vec
2	{4.5,5.5,6.5}


query
SELECT pk, vec FROM arr_t_idx WHERE text_for_search @@ ts_phrase('third')
ORDER BY pk;
----
pk	vec
3	{-1,0,1}
