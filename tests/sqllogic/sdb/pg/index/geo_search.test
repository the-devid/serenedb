# --- `<->` combined with tsquery + BM25 ranking ---
# Same shape as the ST_Distance_Centroid + boosted text test above,
# expressed with the operator-form synonym. Verifies the `<->` claim
# composes with @@ inside the same bool filter and keeps BM25 scoring
# attached to the text leaf.

query
SELECT id FROM places_idx
WHERE body @@ ('blue'::TSQUERY ^ 1000.0 || 'red')
  AND geo <-> '{"type":"Point","coordinates":[37.616,55.704]}' < 500.0
ORDER BY BM25(places_idx.tableoid) DESC, id
----
id
4
1
3
2


# --- EXPLAIN: geo predicate composes with @@ inside IRESEARCH_SCAN ---
# Locks the plan shape and the rendered filter tree:
#   - SearchScan claims both the body @@ leaf (Term) and the geo leaf
#     (GEO[..., op=Intersects, shape=S2Polygon]) into a single AND.
#   - BM25 in the projection attaches as the SearchScan's Score and adds
#     the virtual `sdb_inverted_index_score` column.
# Regressions in TryGetGeoDistanceCall, the geo printer in
# search_filter_printer.cpp, or the dual-prepare/scorer-attach plumbing
# would surface here.

query
EXPLAIN SELECT id, BM25(places_idx.tableoid) > 0 as has_score FROM places_idx
WHERE body @@ 'cafe'
  AND ST_Intersects(geo, '{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}')
ORDER BY id;
----
QUERY PLAN
┌───────────────────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│     places_idx.id ASC     │
│                           │
│          ~0 rows          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│         PROJECTION        │
│    ────────────────────   │
│             id            │
│         has_score         │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│     Index: places_idx     │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│ AND[Term(body(string)=cafe│
│  ) && GEO[geo(string), op │
│     =Intersects, shape    │
│        =S2Polygon]]       │
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│        Projections:       │
│             id            │
│  sdb_inverted_index_score │
│                           │
│          ~7 rows          │
└───────────────────────────┘


# --- EXPLAIN: `<->` + boosted text composes inside IRESEARCH_SCAN ---
# Locks the GEO_DISTANCE printer's range rendering (unbounded lower
# `*`, bounded upper `<500`) and confirms the `<->` operator binds
# through the same path as ST_Distance_Centroid -- both produce a
# GEO_DISTANCE leaf inside the AND. The OR wraps the `^1000.0`-boosted
# blue term together with the bare red term; current rendering doesn't
# surface the per-leaf boost factor (pre-existing printer limitation),
# so the OR shows the term pair only.

query
EXPLAIN SELECT id FROM places_idx
WHERE body @@ ('blue'::TSQUERY ^ 1000.0 || 'red')
  AND geo <-> '{"type":"Point","coordinates":[37.616,55.704]}' < 500.0
ORDER BY BM25(places_idx.tableoid) DESC, id;
----
QUERY PLAN
┌───────────────────────────┐
│         PROJECTION        │
│    ────────────────────   │
│             #0            │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│          ORDER_BY         │
│    ────────────────────   │
│          #1 DESC          │
│     places_idx.id ASC     │
│                           │
│           ~1 row          │
└─────────────┬─────────────┘
┌─────────────┴─────────────┐
│       IRESEARCH_SCAN      │
│    ────────────────────   │
│     Index: places_idx     │
│      Lookup: rocksdb      │
│                           │
│          Filter:          │
│    AND[GEO_DISTANCE[geo   │
│  (string), *, <500] && OR │
│  [Term(body(string)=blue) │
│  || Term(body(string)=red)│
│             ]]            │
│                           │
│           Score:          │
│    bm25(k1=1.2, b=0.75)   │
│                           │
│        Projections:       │
│             id            │
│  sdb_inverted_index_score │
│                           │
│          ~7 rows          │
└───────────────────────────┘


# --- geopoint analyzer: path mode ---
# `geopoint` with `latitude`/`longitude` set to slash-paths extracts the
# point coordinates from a configured location inside each JSON document.
# vpack::Slice::get(path) walks objects only -- numeric-string keys
# don't index arrays -- so paths must traverse object keys at every
# step (e.g. `loc/lat` for `{"loc": {"lat": ...}}`). Documents that
# don't have the configured paths or whose values aren't numbers are
# silently skipped at index time (GeoPointAnalyzer::ParsePoint returns
# false, no terms emitted). The same query operators (ST_Intersects,
# ST_Distance_Centroid, `<->`) work as on a `geojson_shape`-indexed
# column -- the discriminator in TryGetGeoDistanceCall and friends is
# column-info-based, not analyzer-specific.

statement ok
CREATE TABLE geo_pt (id INTEGER PRIMARY KEY, geo JSON)


statement ok
CREATE TEXT SEARCH DICTIONARY geopoint_path(
    template = 'geopoint',
    latitude = 'loc/lat',
    longitude = 'loc/lng'
)


statement ok
CREATE INDEX geo_pt_idx ON geo_pt USING inverted(id, geo geopoint_path)


# Cluster points (~100m from [37.616, 55.704]).

statement ok
INSERT INTO geo_pt VALUES (1, '{"name":"a","loc":{"lat":55.703900,"lng":37.615895}}')

statement ok
INSERT INTO geo_pt VALUES (2, '{"name":"b","loc":{"lat":55.704831,"lng":37.616297}}')

statement ok
INSERT INTO geo_pt VALUES (3, '{"name":"c","loc":{"lat":55.704610,"lng":37.617053}}')


# Far (~3.8km) and very-far (~15km) points.

statement ok
INSERT INTO geo_pt VALUES (4, '{"name":"d","loc":{"lat":55.715895,"lng":37.559509}}')

statement ok
INSERT INTO geo_pt VALUES (5, '{"name":"e","loc":{"lat":55.832144,"lng":37.701645}}')


# Malformed: missing the configured `loc` object. The analyzer returns
# false from ParsePoint and the row contributes no geo terms, so it
# must NOT appear in any geo query result.

statement ok
INSERT INTO geo_pt VALUES (6, '{"name":"orphan"}')

statement ok
VACUUM (UPDATE_INDEXES) geo_pt


# --- ST_Intersects + path-mode geopoint ---

query
SELECT id FROM geo_pt_idx
WHERE ST_Intersects(geo, '{"type":"Polygon","coordinates":[[[37.610,55.700],[37.620,55.700],[37.620,55.710],[37.610,55.710],[37.610,55.700]]]}')
ORDER BY id
----
id
1
2
3


