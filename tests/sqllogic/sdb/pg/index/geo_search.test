# --- `<->` on GEOMETRY column: very-far threshold isolates id=5 ---

query
SELECT id FROM geo_data_g_idx
WHERE geo <-> 'POINT(37.616 55.704)'::GEOMETRY('OGC:CRS84') > 10000.0
ORDER BY id
----
id
5


# --- `<->` on GEOMETRY column with GeoJSON-text centroid (mixed) ---

query
SELECT id FROM geo_data_g_idx
WHERE geo <-> '{"type":"Point","coordinates":[37.616,55.704]}' > 1000.0
ORDER BY id
----
id
4
