# --- geopoint analyzer: array mode (no paths) ---
# When `latitude` and `longitude` are both omitted, the analyzer enters
# `_from_array` mode: each indexed JSON value must be a 2-element
# [lat, lng] array (NOT GeoJSON's [lng, lat]). GeoPointAnalyzer::
# ParsePoint reads element 0 as latitude and element 1 as longitude.
# Wrong-arity / non-array values silently drop from the index.

statement ok
CREATE TABLE geo_pt_arr (id INTEGER PRIMARY KEY, geo JSON)


statement ok
CREATE TEXT SEARCH DICTIONARY geopoint_arr(
    template = 'geopoint'
)


statement ok
CREATE INDEX geo_pt_arr_idx ON geo_pt_arr USING inverted(id, geo geopoint_arr)


# Same five points as the path-mode table, encoded as [lat, lng] flat arrays.

statement ok
INSERT INTO geo_pt_arr VALUES (1, '[55.703900,37.615895]')

statement ok
INSERT INTO geo_pt_arr VALUES (2, '[55.704831,37.616297]')

statement ok
INSERT INTO geo_pt_arr VALUES (3, '[55.704610,37.617053]')

statement ok
INSERT INTO geo_pt_arr VALUES (4, '[55.715895,37.559509]')

statement ok
INSERT INTO geo_pt_arr VALUES (5, '[55.832144,37.701645]')


# Wrong-arity array: 3 elements -- ParsePoint rejects, row is dropped.

statement ok
INSERT INTO geo_pt_arr VALUES (6, '[55.704,37.616,0.0]')

statement ok
VACUUM (UPDATE_INDEXES) geo_pt_arr


