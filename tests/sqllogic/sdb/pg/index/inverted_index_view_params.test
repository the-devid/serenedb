hash-threshold 100
control substitution on

# View bodies with non-default reader parameters. CREATE INDEX must always
# succeed -- it streams via the standard reader. SELECT-with-materialise
# uses the lookup TF, which has to receive the same dialect/format params
# the streaming bind saw, otherwise the parsed rows diverge. When a param
# combination cannot be served by the lookup TF (e.g. compressed JSON,
# explicit `column_types`/`names` for CSV, hive partitioning for parquet),
# `ResolveViewFastPath` rejects it and SELECT falls through to the
# standard "fast-path not supported" error. Detection-only knobs
# (auto_detect, sample_size, files_to_sniff, auto_type_candidates,
# field_appearance_threshold, map_inference_threshold) and operational
# knobs (parallel, buffer_size, store_rejects, rejects_*) don't affect
# the materialize path because we already know columns + offsets.


statement ok
CREATE TEXT SEARCH DICTIONARY view_params_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true
);


# ============================================================================
# CSV: delim, quote, escape, header
# ============================================================================

# Semicolon-delimited CSV with header.
statement ok
COPY (SELECT 'a' AS k, 'pudge alpha' AS body
      UNION ALL SELECT 'b', 'manga beta'
      UNION ALL SELECT 'c', 'pudge gamma')
TO '/tmp/${__DATABASE__}_p_csv_delim.csv' (FORMAT CSV, DELIMITER ';', HEADER);

statement ok
CREATE VIEW p_csv_delim_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_delim.csv', delim=';', header=true);

statement ok
CREATE INDEX p_csv_delim_idx ON p_csv_delim_v
  USING inverted(k, body view_params_en);

query
SELECT k, body FROM p_csv_delim_idx ORDER BY k;
----
k	body
a	pudge alpha
b	manga beta
c	pudge gamma

query
SELECT k, body FROM p_csv_delim_idx WHERE body @@ ts_phrase('pudge') ORDER BY k;
----
k	body
a	pudge alpha
c	pudge gamma


# Pipe-delimited CSV without header (column names from auto-detect: column0,
# column1). header=false flows from view body to lookup.
statement ok
COPY (SELECT 1::int4 AS id, 'pudge solo' AS body)
TO '/tmp/${__DATABASE__}_p_csv_nohdr.csv' (FORMAT CSV, DELIMITER '|', HEADER FALSE);

statement ok
CREATE VIEW p_csv_nohdr_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_nohdr.csv', delim='|', header=false);

statement ok
CREATE INDEX p_csv_nohdr_idx ON p_csv_nohdr_v
  USING inverted(column0, column1 view_params_en);

query
SELECT column0, column1 FROM p_csv_nohdr_idx ORDER BY column0;
----
column0	column1
1	pudge solo


