      UNION ALL SELECT 2, 'manga av beta')
TO '/tmp/${__DATABASE__}_p_csv_av.csv' (FORMAT CSV, HEADER);

statement ok
CREATE VIEW p_csv_av_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_av.csv',
