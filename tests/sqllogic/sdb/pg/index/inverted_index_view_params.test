# ============================================================================
# Parquet: hive_partitioning -- glob with partition column synthesised
# ============================================================================

# Hive partitioning synthesises a `color` column from the path components
# `.../color=red/...` and `.../color=blue/...`. The resolver glob-mode
# fast path threads (file_index, file_row_number); the lookup TF reads
# just the data columns, so partition columns work as long as we don't
# index them.
statement ok
COPY (SELECT 1::int4 AS id, 'pudge hp alpha' AS body, 'red' AS color
      UNION ALL SELECT 2, 'manga hp beta', 'blue')
TO '/tmp/${__DATABASE__}_hive' (FORMAT PARQUET, PARTITION_BY (color));

statement ok
CREATE VIEW p_pq_hive_v AS
  SELECT * FROM read_parquet('/tmp/${__DATABASE__}_hive/**/*.parquet',
                              hive_partitioning=true);

statement ok
CREATE INDEX p_pq_hive_idx ON p_pq_hive_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_pq_hive_idx ORDER BY id;
----
id	body
1	pudge hp alpha
2	manga hp beta


# ============================================================================
# Parquet: file_row_number=true (already implicit virtual column)
# ============================================================================

# Promotes file_row_number to a real column. The lookup TF already projects
# file_row_number as the PK virtual; explicit projection should still work.
statement ok
COPY (SELECT 1::int4 AS id, 'pudge frn alpha' AS body
      UNION ALL SELECT 2, 'manga frn beta')
TO '/tmp/${__DATABASE__}_p_pq_frn.parquet' (FORMAT PARQUET);

statement ok
CREATE VIEW p_pq_frn_v AS
