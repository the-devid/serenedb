# ============================================================================
# CSV: dateformat -- non-default date pattern
# ============================================================================

# Without `dateformat='%d/%m/%Y'` DuckDB cannot parse '31/01/2026' as DATE.
# Both view-body bind and lookup re-bind need it to produce DATE not VARCHAR.
statement ok
COPY (SELECT 1::int4 AS id, '31/01/2026' AS d, 'pudge date alpha' AS body
      UNION ALL SELECT 2, '01/02/2026', 'manga date beta')
TO '/tmp/${__DATABASE__}_p_csv_date.csv' (FORMAT CSV, HEADER);

statement ok
CREATE VIEW p_csv_date_v AS
