----
id	body
1	pudge frn alpha
2	manga frn beta


# ============================================================================
# Params I previously labelled "out of scope" -- verifying that claim
# ============================================================================

# `decimal_separator=','` -- comma-decimal floats. COPY doesn't write
# alternate decimal separators, so emit the raw CSV via a single VARCHAR
# column with semicolon delim so commas don't conflict.
statement ok
COPY (SELECT 'id;x;body' AS line
      UNION ALL SELECT '1;1,5;pudge dec alpha'
      UNION ALL SELECT '2;2,75;manga dec beta')
TO '/tmp/${__DATABASE__}_p_csv_dec.csv' (FORMAT CSV, HEADER FALSE, QUOTE '');

statement ok
CREATE VIEW p_csv_dec_v AS
  SELECT * FROM read_csv('/tmp/${__DATABASE__}_p_csv_dec.csv',
                          header=true, delim=';', decimal_separator=',');

statement ok
CREATE INDEX p_csv_dec_idx ON p_csv_dec_v
  USING inverted(id, body view_params_en);

query
SELECT id, body FROM p_csv_dec_idx ORDER BY id;
----
id	body
1	pudge dec alpha
2	manga dec beta


