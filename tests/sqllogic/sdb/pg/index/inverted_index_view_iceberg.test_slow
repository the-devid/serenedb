control substitution on

# View-backed inverted index over iceberg, both shapes:
#   A: literal-args `iceberg_scan('s3://path', ...)`
#   B: catalog-attached `SELECT * FROM iceberg.s.t`
#
# Index reflects iceberg state at CREATE INDEX time; subsequent iceberg
# DML (INSERT/DELETE/UPDATE) is not picked up.


statement ok
CREATE OR REPLACE SECRET iceberg_${__DATABASE__} (
  TYPE S3,
  KEY_ID '${MINIO_ACCESS_KEY}',
  SECRET '${MINIO_SECRET_KEY}',
  ENDPOINT '${MINIO_HOST}:${MINIO_PORT}',
  URL_STYLE 'path',
  USE_SSL false,
  SCOPE 's3://${MINIO_BUCKET}/warehouse/${__DATABASE__}/'
);


statement ok
SET s3_use_ssl=false;


# REST-catalog warehouse has no version-hint.text; literal-args
# iceberg_scan needs version guessing to find current metadata.json.
statement ok
SET unsafe_enable_version_guessing=true;


# Per-${__DATABASE__} ATTACH alias: each run.sh invocation starts a new
# iceberg-rest on a fresh random port, so a process-global alias like
# `iceberg` would survive in serened's catalog with a stale ENDPOINT and the
# next run's `ATTACH IF NOT EXISTS` would silently keep the dead port. The
# DETACH-then-ATTACH below makes the test idempotent on the same instance,
# and the unique alias keeps parallel iceberg tests from stepping on each
# other's attachment.
statement ok
DETACH DATABASE IF EXISTS iceberg_${__DATABASE__};

statement ok
ATTACH '${ICEBERG_WAREHOUSE}' AS iceberg_${__DATABASE__} (
  TYPE ICEBERG,
  ENDPOINT '${ICEBERG_REST_URL}',
  AUTHORIZATION_TYPE 'none'
);


statement ok
CREATE TEXT SEARCH DICTIONARY view_ice_en(
    template = 'text',
    locale = 'en_US.UTF-8',
    case = 'none',
    stemming = false,
    accent = false,
    frequency = true,
    position = true,
    norm = true
);


# ============================================================================
# Per-${__DATABASE__} schema -- iceberg-rest's namespace is shared across all
# parallel tests in one run.sh, and the warehouse S3 path is keyed on the
# schema name, so the schema must be unique per test invocation. The session
# search_path puts `public` first (so bare CREATE VIEW/INDEX/TABLE land in
# serened's native catalog) and the iceberg schema second (so bare DML
# references to iceberg tables -- INSERT/DELETE/UPDATE/SELECT -- fall
# through search_path resolution to find them). Iceberg tables themselves
# are still created with explicit qualification because the view-local bind
# at CREATE VIEW time only sees the view's own catalog/schema, so anything
# inside a view body that references an iceberg table must be qualified
# regardless of session search_path.
# ============================================================================


statement ok
CREATE SCHEMA iceberg_${__DATABASE__}.${__DATABASE__};

statement ok
SET search_path TO public, iceberg_${__DATABASE__}.${__DATABASE__};


# ============================================================================
# S1 -- clean inserts only, no DML before index build.
# Shape A and Shape B should both classify as fast-path; count, PHRASE,
# materialisation, BM25, bare scan all match the source.
# ============================================================================


statement ok
CREATE TABLE iceberg_${__DATABASE__}.${__DATABASE__}.clean_t (id INTEGER, body TEXT);


statement count 6
INSERT INTO clean_t VALUES
  (1, 'pudge goes mid'),
  (2, 'anchin reads manga'),
  (3, 'pudge plays again'),
  (4, 'krivda writes sql'),
  (5, 'kostya types clickclack'),
  (6, 'gayazov plays mass effect');


# ----- S1 / Shape A: literal-args iceberg_scan view -----

statement ok
CREATE VIEW s1_lit AS SELECT * FROM iceberg_scan(
  's3://${MINIO_BUCKET}/warehouse/${__DATABASE__}/clean_t',
  allow_moved_paths=true);


statement ok
CREATE INDEX s1_lit_idx ON s1_lit USING inverted(id, body view_ice_en);


query
SELECT count(*) FROM s1_lit_idx;
----
count
6


query
SELECT count(*) FROM s1_lit_idx WHERE body @@ ts_phrase('pudge');
----
count
2


query
SELECT id, body FROM s1_lit_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id	body
1	pudge goes mid
3	pudge plays again


query
SELECT id, body FROM s1_lit_idx ORDER BY id;
----
id	body
1	pudge goes mid
2	anchin reads manga
3	pudge plays again
4	krivda writes sql
5	kostya types clickclack
6	gayazov plays mass effect


query
SELECT id, BM25(s1_lit_idx.tableoid) > 0 AS has_score
FROM   s1_lit_idx
WHERE  body @@ ts_phrase('pudge')
ORDER BY id;
----
id	has_score
1	t
3	t


# ----- S1 / Shape B: catalog-attached view -----

statement ok
CREATE VIEW s1_cat AS SELECT * FROM iceberg_${__DATABASE__}.${__DATABASE__}.clean_t;


statement ok
CREATE INDEX s1_cat_idx ON s1_cat USING inverted(id, body view_ice_en);


query
SELECT count(*) FROM s1_cat_idx;
----
count
6


query
SELECT count(*) FROM s1_cat_idx WHERE body @@ ts_phrase('pudge');
----
count
2


query
SELECT id, body FROM s1_cat_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
