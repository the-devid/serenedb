id	body
10	batch_a UPDATED row 10
110	batch_b UPDATED row 110
210	batch_c UPDATED row 210
310	batch_d UPDATED row 310
410	batch_e UPDATED row 410


# Each batch token matches 19 surviving rows (20 inserted - 1 deleted).
query
SELECT count(*) FROM s7_lit_idx WHERE body @@ ts_phrase('batch_a');
----
count
