# ============================================================================
# S4 -- mixed DML (the canonical scenario): INSERT + DELETE + UPDATE +
# INSERT + DELETE before the index. Manifest has: 3 data files (initial +
# update + insert) + 3 positional-delete files. PK = (file_index,
# file_row_number) where file_index spans all three data files.
# ============================================================================


statement ok
CREATE TABLE iceberg_${__DATABASE__}.${__DATABASE__}.mix_t (id INTEGER, body TEXT);


statement count 6
INSERT INTO mix_t VALUES
  (1, 'pudge goes mid'),
  (2, 'anchin reads manga'),
  (3, 'pudge plays again'),
  (4, 'krivda writes sql'),
  (5, 'kostya types clickclack'),
  (6, 'gayazov plays mass effect');


statement count 1
DELETE FROM mix_t WHERE id = 2;


statement count 1
UPDATE mix_t SET body = 'pudge solo mid (updated)' WHERE id = 1;


statement count 1
INSERT INTO mix_t VALUES (7, 'pudge new entry');


statement count 1
DELETE FROM mix_t WHERE id = 4;


# ----- S4 / Shape A -----

statement ok
CREATE VIEW s4_lit AS SELECT * FROM iceberg_scan(
  's3://${MINIO_BUCKET}/warehouse/${__DATABASE__}/mix_t',
  allow_moved_paths=true);


statement ok
CREATE INDEX s4_lit_idx ON s4_lit USING inverted(id, body view_ice_en);


query
SELECT count(*) FROM s4_lit_idx;
----
count
5


# Surviving rows form the bare scan in id order.
query
SELECT id, body FROM s4_lit_idx ORDER BY id;
----
id	body
1	pudge solo mid (updated)
3	pudge plays again
5	kostya types clickclack
6	gayazov plays mass effect
7	pudge new entry


# 'pudge' tokens: id=1 (updated), id=3, id=7. The pre-update token 'pudge
# goes mid' is gone (positional-delete on the original data file row 0).
query
SELECT id, body FROM s4_lit_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id	body
1	pudge solo mid (updated)
3	pudge plays again
7	pudge new entry


# 'updated' is unique to the post-update body for id=1.
query
SELECT id, body FROM s4_lit_idx WHERE body @@ ts_phrase('updated');
----
id	body
1	pudge solo mid (updated)


# 'goes' was only in the pre-update body of id=1 -- now positionally deleted.
query
SELECT id, body FROM s4_lit_idx WHERE body @@ ts_phrase('goes');
----
id	body


# Deleted ids: id=2 (manga) and id=4 (krivda) gone.
query
SELECT count(*) FROM s4_lit_idx WHERE body @@ ts_phrase('manga');
----
count
0


query
SELECT count(*) FROM s4_lit_idx WHERE body @@ ts_phrase('krivda');
----
count
0


# Inserted id=7 is present.
query
SELECT id, body FROM s4_lit_idx WHERE body @@ ts_phrase('new');
----
id	body
7	pudge new entry


# Cross-row PHRASE OR.
query
SELECT id FROM s4_lit_idx
WHERE body @@ ts_phrase('kostya') OR body @@ ts_phrase('gayazov')
ORDER BY id;
----
id
5
6


# BM25 over the post-DML index.
query
SELECT id, BM25(s4_lit_idx.tableoid) > 0 AS has_score
FROM   s4_lit_idx
WHERE  body @@ ts_phrase('pudge')
ORDER BY id;
----
id	has_score
