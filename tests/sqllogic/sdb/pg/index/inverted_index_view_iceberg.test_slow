# ============================================================================
# S7 -- multi-snapshot, larger workload: many INSERTs producing multiple
# data files, multiple DELETEs producing multiple positional-delete files.
# Verify count + PHRASE materialisation across many file groups.
# ============================================================================


statement ok
CREATE TABLE iceberg_${__DATABASE__}.${__DATABASE__}.big_t (id INTEGER, body TEXT);


# 5 batches of inserts -> 5 data files in the manifest.
statement count 20
INSERT INTO big_t
SELECT i, 'batch_a row ' || i::text FROM generate_series(1, 20) AS g(i);

statement count 20
INSERT INTO big_t
SELECT i + 100, 'batch_b row ' || i::text FROM generate_series(1, 20) AS g(i);

statement count 20
INSERT INTO big_t
SELECT i + 200, 'batch_c row ' || i::text FROM generate_series(1, 20) AS g(i);

statement count 20
INSERT INTO big_t
SELECT i + 300, 'batch_d row ' || i::text FROM generate_series(1, 20) AS g(i);

statement count 20
INSERT INTO big_t
SELECT i + 400, 'batch_e row ' || i::text FROM generate_series(1, 20) AS g(i);


# Delete one row from each batch -> 5 positional-delete files.
statement count 1
DELETE FROM big_t WHERE id = 5;

statement count 1
DELETE FROM big_t WHERE id = 105;

statement count 1
DELETE FROM big_t WHERE id = 205;

statement count 1
DELETE FROM big_t WHERE id = 305;

statement count 1
DELETE FROM big_t WHERE id = 405;


# Update one row from each batch -> 5 more positional deletes + 5 new files.
statement count 1
UPDATE big_t SET body = 'batch_a UPDATED row 10' WHERE id = 10;

statement count 1
UPDATE big_t SET body = 'batch_b UPDATED row 110' WHERE id = 110;

statement count 1
UPDATE big_t SET body = 'batch_c UPDATED row 210' WHERE id = 210;

statement count 1
UPDATE big_t SET body = 'batch_d UPDATED row 310' WHERE id = 310;

statement count 1
UPDATE big_t SET body = 'batch_e UPDATED row 410' WHERE id = 410;


# 100 inserted - 5 deleted = 95 surviving rows. The 5 updated rows count as
# updates (still 95 total rows), 5 with new bodies, 5 deleted.
query
SELECT count(*) FROM big_t;
----
count
95


# ----- S7 / Shape A -----

statement ok
CREATE VIEW s7_lit AS SELECT * FROM iceberg_scan(
  's3://${MINIO_BUCKET}/warehouse/${__DATABASE__}/big_t',
  allow_moved_paths=true);


statement ok
CREATE INDEX s7_lit_idx ON s7_lit USING inverted(id, body view_ice_en);


query
SELECT count(*) FROM s7_lit_idx;
