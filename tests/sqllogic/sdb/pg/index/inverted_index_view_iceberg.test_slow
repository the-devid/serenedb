3	pudge plays again


query
SELECT id, body FROM s1_cat_idx ORDER BY id;
----
id	body
1	pudge goes mid
2	anchin reads manga
3	pudge plays again
4	krivda writes sql
5	kostya types clickclack
6	gayazov plays mass effect


# Cross-shape consistency: same query → same answer.
query
SELECT id FROM s1_lit_idx WHERE body @@ ts_phrase('mass effect') ORDER BY id;
----
id
6


query
SELECT id FROM s1_cat_idx WHERE body @@ ts_phrase('mass effect') ORDER BY id;
----
id
6


# ----- S1 / Shape C: projection + cast over the catalog-attached view -----
# Exercises the same code paths as the parquet-side variants test: rename
# (id -> id_b), cast (TEXT -> TEXT, INTEGER -> BIGINT), and per-iceberg-file
# materialisation via the row-group-pruned reader.
statement ok
CREATE VIEW s1_cast AS
  SELECT id::BIGINT AS id_b, body AS text
  FROM iceberg_${__DATABASE__}.${__DATABASE__}.clean_t;


statement ok
CREATE INDEX s1_cast_idx ON s1_cast USING inverted(id_b, text view_ice_en);


query
SELECT count(*) FROM s1_cast_idx;
----
count
6


query
SELECT count(*) FROM s1_cast_idx WHERE text @@ ts_phrase('pudge');
----
count
2


query
SELECT id_b, text FROM s1_cast_idx WHERE text @@ ts_phrase('pudge') ORDER BY id_b;
----
id_b	text
1	pudge goes mid
3	pudge plays again


query
SELECT id_b, text FROM s1_cast_idx ORDER BY id_b;
----
id_b	text
1	pudge goes mid
2	anchin reads manga
3	pudge plays again
4	krivda writes sql
5	kostya types clickclack
6	gayazov plays mass effect


