query
SELECT count(*) FROM s7_lit_idx WHERE body @@ ts_phrase('batch_b');
----
count
19


query
SELECT count(*) FROM s7_lit_idx WHERE body @@ ts_phrase('batch_c');
----
count
19


query
SELECT count(*) FROM s7_lit_idx WHERE body @@ ts_phrase('batch_d');
----
count
19


query
SELECT count(*) FROM s7_lit_idx WHERE body @@ ts_phrase('batch_e');
----
count
19


# Deleted ids are absent.
query
SELECT count(*) FROM s7_lit_idx WHERE id IN (5, 105, 205, 305, 405);
----
count
0


# Sample materialisation for an updated row in each batch.
query
SELECT id, body FROM s7_lit_idx WHERE id = 10;
----
id	body
10	batch_a UPDATED row 10


query
SELECT id, body FROM s7_lit_idx WHERE id = 410;
----
id	body
410	batch_e UPDATED row 410


# Cross-batch PHRASE selection with explicit IN list.
query
SELECT id, body FROM s7_lit_idx
WHERE body @@ ts_phrase('UPDATED') AND id IN (10, 110, 210)
ORDER BY id;
----
id	body
10	batch_a UPDATED row 10
110	batch_b UPDATED row 110
210	batch_c UPDATED row 210


# PHRASE + range filter: DuckDB pushes id < 300 into get.table_filters;
# iresearch_plan reclaims it back into filter_summary so only updates
# from the first three batches survive.
query
SELECT id, body FROM s7_lit_idx
WHERE body @@ ts_phrase('UPDATED') AND id < 300
ORDER BY id;
----
id	body
10	batch_a UPDATED row 10
110	batch_b UPDATED row 110
210	batch_c UPDATED row 210


query
SELECT id, body FROM s7_lit_idx
WHERE body @@ ts_phrase('UPDATED') AND id >= 300
ORDER BY id;
----
id	body
310	batch_d UPDATED row 310
410	batch_e UPDATED row 410


# Bare-scan id range filter: count-scan rewrite bails out when there are
# table filters, the regular AGGREGATE+GET path applies the filter at the
# iceberg reader and counts the surviving rows.
query
SELECT count(*) FROM s7_lit_idx WHERE id <= 100;
----
count
19


query
SELECT count(*) FROM s7_lit_idx WHERE id BETWEEN 100 AND 300;
