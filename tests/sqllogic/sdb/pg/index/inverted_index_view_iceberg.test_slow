# ============================================================================
# S5 -- immutable-index promise: DML *after* CREATE INDEX is NOT reflected.
# After building the index, INSERT a row and DELETE another. The index must
# still report its as-of-build-time view.
# ============================================================================


statement ok
CREATE TABLE iceberg_${__DATABASE__}.${__DATABASE__}.imm_t (id INTEGER, body TEXT);


statement count 4
INSERT INTO imm_t VALUES
  (101, 'snapshot one'),
  (102, 'snapshot two'),
  (103, 'snapshot three'),
  (104, 'snapshot four');


# Build the index over the as-of-now state.
statement ok
CREATE VIEW s5_lit AS SELECT * FROM iceberg_scan(
  's3://${MINIO_BUCKET}/warehouse/${__DATABASE__}/imm_t',
  allow_moved_paths=true);


statement ok
CREATE INDEX s5_lit_idx ON s5_lit USING inverted(id, body view_ice_en);


# Modify iceberg AFTER index build.
statement count 1
INSERT INTO imm_t VALUES (999, 'snapshot post-build');


statement count 1
DELETE FROM imm_t WHERE id = 102;


# Iceberg view sees the post-DML state -- 4 rows.
query
SELECT count(*) FROM imm_t;
----
count
4


# But the index is frozen at build time -- still 4 rows, including id=102.
query
SELECT count(*) FROM s5_lit_idx;
----
count
4


query
SELECT id FROM s5_lit_idx WHERE body @@ ts_phrase('snapshot') ORDER BY id;
----
id
101
102
103
104


# Post-build INSERT is absent.
query
SELECT count(*) FROM s5_lit_idx WHERE id = 999;
----
count
0


# ============================================================================
# S6 -- named param round-trip: `allow_moved_paths=true` reaches the binder
# at materialisation time. Without B4's deferred-cast fix, the parser-level
# UNBOUND CAST target makes BindFastPathSource crash. Without B5's
# virtual-column patch, CREATE INDEX fails before backfill.
# ============================================================================


statement ok
CREATE TABLE iceberg_${__DATABASE__}.${__DATABASE__}.np_t (id INTEGER, body TEXT);


statement count 3
INSERT INTO np_t VALUES
  (1, 'named param one'),
  (2, 'named param two'),
  (3, 'named param three');


statement ok
