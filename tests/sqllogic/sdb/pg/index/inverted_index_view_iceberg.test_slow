# ============================================================================
# S8 -- equality deletes (regression for the iceberg D_ASSERT patch).
# Equality-delete files match by column value rather than (file_path, pos).
# Without our patch in iceberg_multi_file_reader.cpp:287/363 the index build
# trips `D_ASSERT(!col.identifier.IsNull())` because virtual columns
# (file_row_number / file_index) lack iceberg field-ids.
#
# Path-based fixture: REST catalog default produces positional deletes only,
# so we use the bundled equality_deletes fixture here -- it ships a v7
# table with two surviving rows (id 4, 5) after equality-delete files
# remove ids 1, 2, 3, 6.
# ============================================================================


statement ok
CREATE VIEW s8_lit AS SELECT * FROM iceberg_scan(
  '${ICEBERG_FIXTURES}/equality_deletes/warehouse/mydb/mytable',
  allow_moved_paths=true);


statement ok
CREATE INDEX s8_lit_idx ON s8_lit USING inverted(id, name view_ice_en);


# Iceberg's view: 2 rows after equality deletes.
query
SELECT count(*) FROM s8_lit;
----
count
2


query
SELECT count(*) FROM s8_lit_idx;
----
count
2


query
SELECT id, name FROM s8_lit ORDER BY id;
----
id	name
4	d
5	e


query
SELECT id, name FROM s8_lit_idx ORDER BY id;
----
id	name
4	d
5	e


# Names of equality-deleted rows must NOT appear in the index.
query
SELECT count(*) FROM s8_lit_idx WHERE name @@ ts_phrase('a');
----
count
0


query
SELECT count(*) FROM s8_lit_idx WHERE name @@ ts_phrase('b');
----
count
0


query
SELECT count(*) FROM s8_lit_idx WHERE name @@ ts_phrase('c');
----
count
0


query
SELECT count(*) FROM s8_lit_idx WHERE name @@ ts_phrase('f');
----
count
0


# Surviving names materialise correctly.
query
SELECT id, name FROM s8_lit_idx WHERE name @@ ts_phrase('d');
----
id	name
4	d


query
SELECT id, name FROM s8_lit_idx WHERE name @@ ts_phrase('e');
----
id	name
5	e


# ============================================================================
# S9 -- bare full-scan correctness for catalog-attached. Without B2's
# fix to PKFullScanInitGlobal, this would crash (nullptr deref on
# bind_data.table->GetId()) for non-fast-path views; for catalog-attached
# fast-path views the bare scan goes through MakeViewFastPathScanFunction
# and returns the underlying iceberg rows.
# ============================================================================


# Use the s4 mix_t catalog view; bare scan should match the iceberg view.
query
SELECT id, body FROM s4_cat ORDER BY id;
----
id	body
1	pudge solo mid (updated)
3	pudge plays again
5	kostya types clickclack
6	gayazov plays mass effect
7	pudge new entry


# Bare scan via the index returns the same rows.
query
SELECT id, body FROM s4_cat_idx ORDER BY id;
----
id	body
1	pudge solo mid (updated)
3	pudge plays again
5	kostya types clickclack
6	gayazov plays mass effect
7	pudge new entry


# Combine PHRASE + bare-style projection of all index columns.
query
SELECT id, body FROM s4_cat_idx WHERE body @@ ts_phrase('pudge') ORDER BY id;
----
id	body
1	pudge solo mid (updated)
3	pudge plays again
7	pudge new entry


# ============================================================================
# S10 -- JOIN: combine an iceberg-backed indexed view with a native
# rocksdb table by id. Verifies the index returns row schemas suitable
# for downstream ops.
# ============================================================================


statement ok
CREATE TABLE local_meta (id INTEGER PRIMARY KEY, who TEXT);


statement count 5
INSERT INTO local_meta VALUES
  (1, 'admin'),
  (3, 'editor'),
  (5, 'viewer'),
  (6, 'viewer'),
  (7, 'admin');


query
SELECT m.id, m.who, idx.body
FROM   local_meta m
JOIN   s4_lit_idx idx ON m.id = idx.id
WHERE  idx.body @@ ts_phrase('pudge')
ORDER BY m.id;
----
id	who	body
1	admin	pudge solo mid (updated)
3	editor	pudge plays again
7	admin	pudge new entry


query
SELECT m.id, m.who, idx.body
FROM   local_meta m
JOIN   s4_cat_idx idx ON m.id = idx.id
WHERE  idx.body @@ ts_phrase('pudge')
ORDER BY m.id;
----
id	who	body
1	admin	pudge solo mid (updated)
3	editor	pudge plays again
7	admin	pudge new entry


# UNION between local rocksdb rows and iceberg-indexed rows.
query
SELECT id, who AS label FROM local_meta WHERE id <= 3
UNION ALL
SELECT id, body AS label FROM s4_cat_idx WHERE body @@ ts_phrase('pudge')
ORDER BY id, label;
----
id	label
1	admin
1	pudge solo mid (updated)
3	editor
3	pudge plays again
7	pudge new entry


