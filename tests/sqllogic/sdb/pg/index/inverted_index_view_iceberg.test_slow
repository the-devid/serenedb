# ============================================================================
# S3 -- UPDATE before index build. Iceberg implements UPDATE as
# positional-delete-old + insert-new-into-new-file. The index must:
#   1. Not return the old body.
#   2. Return the new body (from a different data file with file_index != 0).
# ============================================================================


statement ok
CREATE TABLE iceberg_${__DATABASE__}.${__DATABASE__}.upd_t (id INTEGER, body TEXT);


statement count 4
INSERT INTO upd_t VALUES
  (10, 'old body for ten'),
  (20, 'old body for twenty'),
  (30, 'unchanged thirty'),
  (40, 'old body for forty');


statement count 1
UPDATE upd_t SET body = 'new body for ten' WHERE id = 10;

statement count 1
UPDATE upd_t SET body = 'new body for forty (refreshed)' WHERE id = 40;


# ----- S3 / Shape A -----

statement ok
CREATE VIEW s3_lit AS SELECT * FROM iceberg_scan(
  's3://${MINIO_BUCKET}/warehouse/${__DATABASE__}/upd_t',
  allow_moved_paths=true);


statement ok
CREATE INDEX s3_lit_idx ON s3_lit USING inverted(id, body view_ice_en);


query
SELECT count(*) FROM s3_lit_idx;
----
count
4


# 'new' appears in 2 updated rows.
query
SELECT count(*) FROM s3_lit_idx WHERE body @@ ts_phrase('new');
----
count
2


# 'old' bodies for id=10/40 are positionally deleted; id=20 was not updated
# and its 'old body for twenty' is still live.
query
SELECT id, body FROM s3_lit_idx WHERE body @@ ts_phrase('old') ORDER BY id;
----
id	body
20	old body for twenty


query
SELECT id, body FROM s3_lit_idx WHERE body @@ ts_phrase('new') ORDER BY id;
----
id	body
10	new body for ten
40	new body for forty (refreshed)


query
SELECT id, body FROM s3_lit_idx WHERE body @@ ts_phrase('unchanged') ORDER BY id;
----
id	body
30	unchanged thirty


query
SELECT id, body FROM s3_lit_idx ORDER BY id;
----
id	body
10	new body for ten
20	old body for twenty
30	unchanged thirty
40	new body for forty (refreshed)


